---
export interface TimelineEvent {
  year: string;
  title: string;
  description: string;
}

export interface Props {
  variant?: 'vertical' | 'alternating';
  events: TimelineEvent[];
  class?: string;
}

const { variant = 'vertical', events, class: className } = Astro.props;
---

{
  variant === 'vertical' && (
    <div class:list={['relative mx-auto max-w-2xl', className]}>
      <div class="absolute left-4 top-0 h-full w-px bg-neutral-200" />
      <div class="space-y-12">
        {events.map((event) => (
          <div class="relative pl-12">
            <div class="absolute left-2.5 top-1 h-3 w-3 rounded-full border-2 border-primary-600 bg-white" />
            <span class="text-sm font-semibold text-primary-600">
              {event.year}
            </span>
            <h3 class="mt-1 font-heading text-lg font-semibold text-neutral-900">
              {event.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-600">
              {event.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  )
}

{
  variant === 'alternating' && (
    <div class:list={['relative mx-auto max-w-4xl', className]}>
      <div class="absolute left-4 top-0 h-full w-px bg-neutral-200 md:left-1/2 md:-translate-x-1/2" />
      <div class="space-y-12">
        {events.map((event, i) => (
          <div
            class:list={[
              'relative grid grid-cols-1 gap-4 pl-10 md:pl-0 md:grid-cols-2',
              i % 2 === 0 ? 'md:text-right' : '',
            ]}
          >
            <div
              class:list={[
                'px-6',
                i % 2 === 0 ? 'md:order-1' : 'md:order-2',
              ]}
            >
              <span class="text-sm font-semibold text-primary-600">
                {event.year}
              </span>
              <h3 class="mt-1 font-heading text-lg font-semibold text-neutral-900">
                {event.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-neutral-600">
                {event.description}
              </p>
            </div>
            <div class={i % 2 === 0 ? 'md:order-2' : 'md:order-1'} />
            <div class="absolute left-4 top-1 h-3 w-3 rounded-full border-2 border-primary-600 bg-white md:left-1/2 md:-translate-x-1/2" />
          </div>
        ))}
      </div>
    </div>
  )
}
