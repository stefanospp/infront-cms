---
export interface Props {
  heading: string;
  description?: string;
  buttonText: string;
  buttonHref: string;
  class?: string;
}

const { heading, description, buttonText, buttonHref, class: className } =
  Astro.props;
---

<section
  class:list={[
    'bg-primary-600 px-4 py-16 sm:px-6 sm:py-20 lg:px-8',
    className,
  ]}
>
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="font-heading text-3xl font-bold tracking-tight text-white sm:text-4xl">
      {heading}
    </h2>
    {description && (
      <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-primary-100">
        {description}
      </p>
    )}
    <div class="mt-8">
      <a
        href={buttonHref}
        class="inline-flex items-center rounded-lg border-2 border-white bg-white px-8 py-3.5 text-base font-semibold text-primary-700 shadow-sm hover:bg-primary-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        {buttonText}
      </a>
    </div>
  </div>
</section>
