---
export interface CardItem {
  title: string;
  description: string;
  image?: string;
  href?: string;
}

export interface Props {
  variant: 'two-column' | 'three-column' | 'four-column' | 'masonry' | 'list';
  cards: CardItem[];
  class?: string;
}

const { variant, cards, class: className } = Astro.props;

const gridClass =
  variant === 'two-column'
    ? 'grid grid-cols-1 gap-8 sm:grid-cols-2'
    : variant === 'three-column'
      ? 'grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3'
      : variant === 'four-column'
        ? 'grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4'
        : variant === 'list'
          ? 'space-y-4'
          : 'columns-1 gap-8 space-y-8 sm:columns-2 lg:columns-3';
---

<div class:list={[gridClass, className]}>
  {
    cards.map((card) => {
      const isListVariant = variant === 'list';

      const CardContent = isListVariant ? (
        <div class="group flex items-start gap-4 rounded-lg border border-neutral-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md">
          {card.image && (
            <div class="h-16 w-16 flex-shrink-0 overflow-hidden rounded-lg">
              <img
                src={card.image}
                alt={card.title}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
          )}
          <div>
            <h3 class="font-heading text-base font-semibold text-neutral-900">
              {card.title}
            </h3>
            <p class="mt-1 text-sm leading-relaxed text-neutral-600">
              {card.description}
            </p>
          </div>
        </div>
      ) : (
        <div
          class:list={[
            'group overflow-hidden border border-neutral-200 bg-white shadow-sm transition-shadow hover:shadow-md',
            variant === 'masonry' ? 'break-inside-avoid rounded-xl' : 'rounded-xl',
          ]}
        >
          {card.image && (
            <div class="aspect-video overflow-hidden">
              <img
                src={card.image}
                alt={card.title}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-6">
            <h3 class="font-heading text-lg font-semibold text-neutral-900">
              {card.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-600">
              {card.description}
            </p>
          </div>
        </div>
      );

      return card.href ? (
        <a href={card.href} class="block no-underline">
          {CardContent}
        </a>
      ) : (
        CardContent
      );
    })
  }
</div>
