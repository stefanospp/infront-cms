---
export interface HoursEntry {
  day: string;
  hours: string;
}

export interface Props {
  hours: HoursEntry[];
  heading?: string;
  class?: string;
}

const { hours, heading = 'Opening Hours', class: className } = Astro.props;
---

<div class:list={['rounded-xl border border-neutral-200 bg-white p-6 shadow-sm', className]}>
  <h3 class="mb-4 font-heading text-lg font-semibold text-neutral-900">
    {heading}
  </h3>
  <dl class="space-y-3">
    {
      hours.map((entry) => (
        <div class="flex items-center justify-between text-sm">
          <dt class="font-medium text-neutral-800">{entry.day}</dt>
          <dd class="text-neutral-600">{entry.hours}</dd>
        </div>
      ))
    }
  </dl>
</div>
