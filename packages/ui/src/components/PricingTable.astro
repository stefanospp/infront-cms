---
export interface PricingPlan {
  name: string;
  price: string;
  period?: string;
  description?: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
  highlighted?: boolean;
}

export interface Props {
  variant?: 'two-column' | 'three-column';
  plans: PricingPlan[];
  highlightedLabel?: string;
  class?: string;
}

const { variant = 'three-column', plans, highlightedLabel = 'Popular', class: className } = Astro.props;

const gridClass =
  variant === 'two-column'
    ? 'grid grid-cols-1 gap-8 sm:grid-cols-2 max-w-4xl'
    : 'grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 max-w-6xl';
---

<div class:list={[gridClass, 'mx-auto', className]}>
  {
    plans.map((plan) => (
      <div
        class:list={[
          'relative flex flex-col overflow-hidden rounded-xl border p-8',
          plan.highlighted
            ? 'border-primary-600 bg-white shadow-lg ring-1 ring-primary-600'
            : 'border-neutral-200 bg-white shadow-sm',
        ]}
      >
        {plan.highlighted && (
          <div class="absolute right-4 top-4 rounded-full bg-primary-600 px-3 py-1 text-xs font-semibold text-white">
            {highlightedLabel}
          </div>
        )}
        <h3 class="font-heading text-xl font-semibold text-neutral-900">
          {plan.name}
        </h3>
        <div class="mt-4 flex items-baseline gap-1">
          <span class="font-heading text-4xl font-bold text-neutral-900">
            {plan.price}
          </span>
          {plan.period && (
            <span class="text-sm text-neutral-500">/{plan.period}</span>
          )}
        </div>
        {plan.description && (
          <p class="mt-3 text-sm text-neutral-600">{plan.description}</p>
        )}
        <ul class="mt-6 flex-1 space-y-3">
          {plan.features.map((feature) => (
            <li class="flex items-start gap-2 text-sm text-neutral-700">
              <svg
                class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              {feature}
            </li>
          ))}
        </ul>
        <a
          href={plan.ctaHref}
          class:list={[
            'mt-8 block rounded-lg px-6 py-3 text-center text-sm font-semibold transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2',
            plan.highlighted
              ? 'bg-primary-600 text-white hover:bg-primary-700 focus-visible:outline-primary-600'
              : 'bg-neutral-100 text-neutral-900 hover:bg-neutral-200 focus-visible:outline-neutral-600',
          ]}
        >
          {plan.ctaText}
        </a>
      </div>
    ))
  }
</div>
