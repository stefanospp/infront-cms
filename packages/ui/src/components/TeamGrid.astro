---
export interface TeamMember {
  name: string;
  role: string;
  bio?: string;
  photo?: string;
  email?: string;
}

export interface Props {
  variant?: 'default' | 'compact' | 'detailed';
  members: TeamMember[];
  class?: string;
}

const { variant = 'default', members, class: className } = Astro.props;
---

{
  variant === 'default' && (
    <div class:list={['grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3', className]}>
      {members.map((member) => (
        <div class="overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm">
          {member.photo && (
            <div class="aspect-square overflow-hidden">
              <img src={member.photo} alt={member.name} class="h-full w-full object-cover" loading="lazy" />
            </div>
          )}
          <div class="p-6">
            <h3 class="font-heading text-lg font-semibold text-neutral-900">{member.name}</h3>
            <p class="mt-1 text-sm font-medium text-primary-600">{member.role}</p>
            {member.bio && <p class="mt-3 text-sm leading-relaxed text-neutral-600">{member.bio}</p>}
            {member.email && (
              <a href={`mailto:${member.email}`} class="mt-4 inline-block text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
                {member.email}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  )
}

{
  variant === 'compact' && (
    <div class:list={['grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-4', className]}>
      {members.map((member) => (
        <div class="text-center">
          {member.photo && (
            <div class="mx-auto mb-3 h-20 w-20 overflow-hidden rounded-full">
              <img src={member.photo} alt={member.name} class="h-full w-full object-cover" loading="lazy" />
            </div>
          )}
          <h3 class="font-heading text-sm font-semibold text-neutral-900">{member.name}</h3>
          <p class="text-xs text-neutral-500">{member.role}</p>
        </div>
      ))}
    </div>
  )
}

{
  variant === 'detailed' && (
    <div class:list={['space-y-8', className]}>
      {members.map((member) => (
        <div class="flex flex-col gap-6 rounded-xl border border-neutral-200 bg-white p-6 shadow-sm sm:flex-row">
          {member.photo && (
            <div class="h-32 w-32 flex-shrink-0 overflow-hidden rounded-xl">
              <img src={member.photo} alt={member.name} class="h-full w-full object-cover" loading="lazy" />
            </div>
          )}
          <div>
            <h3 class="font-heading text-xl font-semibold text-neutral-900">{member.name}</h3>
            <p class="mt-1 text-sm font-medium text-primary-600">{member.role}</p>
            {member.bio && <p class="mt-3 text-base leading-relaxed text-neutral-600">{member.bio}</p>}
            {member.email && (
              <a href={`mailto:${member.email}`} class="mt-3 inline-block text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
                {member.email}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  )
}
