---
export interface FeatureItem {
  title: string;
  description: string;
  icon?: string;
  image?: string;
}

export interface Props {
  variant?: 'grid' | 'alternating' | 'icon-list';
  features: FeatureItem[];
  class?: string;
}

const { variant = 'grid', features, class: className } = Astro.props;
---

{
  variant === 'grid' && (
    <div class:list={['grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3', className]}>
      {features.map((f) => (
        <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm">
          {f.icon && (
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-primary-50 text-primary-600">
              <span class="text-2xl">{f.icon}</span>
            </div>
          )}
          <h3 class="font-heading text-lg font-semibold text-neutral-900">
            {f.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-600">
            {f.description}
          </p>
        </div>
      ))}
    </div>
  )
}

{
  variant === 'alternating' && (
    <div class:list={['space-y-16 lg:space-y-24', className]}>
      {features.map((f, i) => (
        <div
          class:list={[
            'mx-auto grid max-w-7xl items-center gap-8 lg:grid-cols-2 lg:gap-16',
            i % 2 === 1 && 'lg:direction-rtl',
          ]}
        >
          <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
            <h3 class="font-heading text-2xl font-bold text-neutral-900 sm:text-3xl">
              {f.title}
            </h3>
            <p class="mt-4 text-base leading-relaxed text-neutral-600">
              {f.description}
            </p>
          </div>
          {f.image && (
            <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
              <img
                src={f.image}
                alt={f.title}
                class="rounded-xl shadow-md"
                loading="lazy"
              />
            </div>
          )}
        </div>
      ))}
    </div>
  )
}

{
  variant === 'icon-list' && (
    <div class:list={['space-y-6', className]}>
      {features.map((f) => (
        <div class="flex items-start gap-4">
          {f.icon && (
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary-50 text-primary-600">
              <span class="text-xl">{f.icon}</span>
            </div>
          )}
          <div>
            <h3 class="font-heading text-base font-semibold text-neutral-900">
              {f.title}
            </h3>
            <p class="mt-1 text-sm leading-relaxed text-neutral-600">
              {f.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  )
}
