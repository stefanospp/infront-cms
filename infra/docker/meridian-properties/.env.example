# Directus instance configuration
# Copy this file to .env and fill in the values

# Port to expose Directus on the host
PORT=8055

# Directus application keys (generate with: openssl rand -hex 32)
KEY=replace-with-random-key
SECRET=replace-with-random-secret

# Database credentials
DB_USER=directus
DB_PASSWORD=replace-with-secure-password

# Admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-secure-password

# Public-facing URL for this Directus instance
PUBLIC_URL=https://cms.example.com
