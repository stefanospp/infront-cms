# Directus instance for Nikolas Petrou
# Copy to .env and fill in values

PORT=8060

# Generate with: openssl rand -hex 32
KEY=replace-with-random-key
SECRET=replace-with-random-secret

# Database credentials
DB_USER=directus
DB_PASSWORD=replace-with-secure-password

# Admin account
ADMIN_EMAIL=hello@nikolaspetrou.com
ADMIN_PASSWORD=replace-with-secure-password

# Public-facing URL
PUBLIC_URL=https://cms.nikolaspetrou.com
