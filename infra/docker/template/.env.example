# Directus instance configuration
# Copy this file to .env and fill in the values

# Port to expose Directus on the host
PORT=8055

# Directus application keys (generate with: openssl rand -hex 32)
KEY=replace-with-random-key
SECRET=replace-with-random-secret

# Database credentials
DB_USER=directus
DB_PASSWORD=replace-with-secure-password

# Admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-secure-password

# Public-facing URL for this Directus instance
PUBLIC_URL=https://cms.example.com

# R2 Storage — shared infront-uploads bucket, path-separated per client
# Credentials from Cloudflare R2 API token (infront-platform-cdn)
SLUG=replace-with-client-slug
STORAGE_S3_KEY=replace-with-r2-access-key-id
STORAGE_S3_SECRET=replace-with-r2-secret-access-key
STORAGE_S3_BUCKET=infront-uploads
STORAGE_S3_ENDPOINT=https://0d1eacba26b2f60ce76fd618ba21afa6.r2.cloudflarestorage.com

# Email — centralised via Resend SMTP (shared across all Directus instances)
# Uses the infront.cy domain. API key from Resend dashboard.
EMAIL_FROM=noreply@infront.cy
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.resend.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=resend
EMAIL_SMTP_PASSWORD=replace-with-resend-api-key
