---
import { universityExams } from '../lib/university';

const featured = universityExams.slice(0, 4);
---

<section id="university" class="py-24 px-6 bg-slate-900 text-white">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <div class="w-16 h-1 bg-[#fff33b] mx-auto mb-8"></div>
      <h2 class="text-5xl font-black mb-4">
        UNIVERSITY & <span class="text-[#fff33b]">MEDICAL SCHOOL.</span>
      </h2>
      <p class="text-gray-400 font-medium max-w-2xl mx-auto text-lg">
        Exam preparation and application support for universities in the UK, Ireland, Netherlands, Czech Republic, Germany, and beyond.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {featured.map((exam) => (
        <a href={`/university/${exam.slug}`} class="border-2 border-gray-700 p-8 hover:border-[#fff33b] transition-colors bg-slate-800 no-underline flex flex-col">
          <div class="flex items-center justify-between mb-4">
            <span class="text-[#fff33b] text-xs font-black uppercase tracking-widest">{exam.region}</span>
            <span
              class="text-[10px] font-black uppercase tracking-widest px-2 py-1 text-black"
              style={`background: ${exam.color};`}
            >
              {exam.shortName}
            </span>
          </div>
          <h3 class="text-2xl font-black mb-4 text-white">{exam.name}</h3>
          <p class="text-gray-400 text-sm mb-6 leading-relaxed line-clamp-3 flex-1">{exam.description}</p>
          <div class="flex items-center justify-between pt-4 border-t border-gray-700 mt-auto">
            <span class="text-xs font-semibold text-gray-500">{exam.timeline}</span>
            <span class="text-xs font-black uppercase tracking-wider text-white">View →</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="/university" class="inline-flex items-center gap-2 border-2 border-gray-600 text-white font-bold uppercase tracking-wider text-sm px-8 py-4 hover:border-[#fff33b] hover:text-[#fff33b] transition-colors no-underline">
        View All Programmes
      </a>
    </div>
  </div>
</section>
