---
import CourseFilter from '../islands/CourseFilter.tsx';
import { getCourses } from '../lib/cms';
import { examPeriods } from '../lib/courses';

interface Props { draft?: boolean; }
const { draft } = Astro.props;
const courses = await getCourses(draft ? { draft: true } : undefined);
const filterCourses = courses.map((c) => ({
  slug: c.slug,
  name: c.name,
  description: c.description,
  dates: c.dates,
  subject: c.subject,
  level: c.level,
  season: c.season,
  examBoard: c.examBoard,
  schools: c.schools,
  classSize: c.classSize,
  color: c.color,
  status: c.status,
}));
---

<section class="py-16 px-6 bg-gray-50">
  <div class="max-w-7xl mx-auto">
    <CourseFilter courses={filterCourses} examPeriods={examPeriods} client:visible />
  </div>
</section>
