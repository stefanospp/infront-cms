---
import MobileMenu from '../islands/MobileMenu.tsx';

const links = [
  { label: 'About', href: '/about' },
  { label: 'Subjects', href: '/subjects' },
  { label: 'Courses', href: '/courses' },
  { label: 'University', href: '/university' },
  { label: 'Resources', href: '/resources' },
];
---

<header class="fixed top-0 w-full bg-white/95 backdrop-blur-sm z-50 border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3" aria-label="Theorium — Home">
      <div class="w-10 h-10 bg-[#fff33b] border-2 border-black flex items-center justify-center font-black text-black text-lg">Th</div>
      <div class="font-black text-xl tracking-tight">THEORIUM</div>
    </a>

    <nav aria-label="Main navigation" class="hidden md:flex items-center gap-8 font-bold text-sm uppercase tracking-wider">
      {links.map((link) => (
        <a href={link.href} class="hover:text-blue-800 transition-colors">{link.label}</a>
      ))}
      <a href="/contact" class="btn-brutal px-6 py-2 text-sm">Get in touch</a>
    </nav>

    <MobileMenu links={links} client:load />
  </div>
</header>
