---
interface Props {
  heading: string;
  highlight?: string;
  highlightColor?: 'yellow' | 'green' | 'pink' | 'blue';
  description: string;
}

const { heading, highlight, highlightColor = 'yellow', description } = Astro.props;
---

<section class="pt-32 pb-16 px-6 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <h1 class="text-5xl lg:text-7xl font-black mb-4 tracking-tight uppercase">
      {heading}{highlight && <> <span class={`highlight-box highlight-${highlightColor}`}>{highlight}</span></>}
    </h1>
    <p class="text-xl font-medium text-gray-600 max-w-2xl leading-relaxed">
      {description}
    </p>
  </div>
</section>
