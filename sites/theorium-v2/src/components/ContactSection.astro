---
import ContactForm from '../islands/ContactForm.tsx';

interface Props {
  showHeading?: boolean;
}

const { showHeading = false } = Astro.props;
---

<section id="contact" class="py-24 px-6 bg-gray-50 border-t border-gray-200">
  <div class="max-w-2xl mx-auto">
    {showHeading && (
      <div class="text-center mb-12">
        <div class="section-divider centered" aria-hidden="true"></div>
        <h2 class="text-5xl font-black mb-4">GET IN <span class="highlight-box highlight-blue">TOUCH.</span></h2>
        <p class="text-gray-500 font-medium">Send a message or reach out directly.</p>
      </div>
    )}

    <div class="mb-12 flex flex-col items-center text-center">
      <div class="flex items-center gap-5">
        <a href="https://wa.me/35799000000" class="contact-icon" aria-label="Message on WhatsApp" title="WhatsApp">
          <img src="/icons/whatsapp.svg" alt="" />
        </a>
        <a href="viber://chat?number=35799000000" class="contact-icon" aria-label="Message on Viber" title="Viber">
          <img src="/icons/viber.svg" alt="" />
        </a>
        <a href="mailto:theodora@theorium.cy" class="contact-icon" aria-label="Send email" title="Email">
          <img src="/icons/email.svg" alt="" />
        </a>
      </div>
      <span class="text-xs font-medium text-gray-400 mt-3">Usually replies within 2 hours</span>
      <p class="text-sm font-bold text-gray-500 mt-6">Larnaca, Cyprus</p>
    </div>

    <ContactForm client:visible />
  </div>
</section>
