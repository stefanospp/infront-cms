---
import { getHomeSections, type FetchOptions } from '../lib/cms';

interface Props { draft?: boolean; }
const { draft } = Astro.props;
const opts: FetchOptions | undefined = draft ? { draft: true } : undefined;

const fallback = {
  badge: 'In-Person in Larnaca · Online Europe-Wide',
  heading: 'SCIENCE.',
  headingHighlight: 'EVERY LEVEL.',
  subheading: 'One-on-one after-school lessons for students at <span class="font-bold text-gray-900">American Academy</span>, <span class="font-bold text-gray-900">Pascal</span>, <span class="font-bold text-gray-900">MedHigh</span>, <span class="font-bold text-gray-900">The English School</span>, and <span class="font-bold text-gray-900">Forum</span>. From IGCSE to university entrance — including medical school admissions.',
  stats: [{ text: '150+ Students' }, { text: 'IGCSE to A-Level' }, { text: 'Medical School Prep' }],
  ctaText: 'View Courses',
  ctaHref: '/courses',
};

const homeSections = await getHomeSections(opts);
const hero = homeSections?.hero ?? fallback;
const badge = hero.badge || fallback.badge;
const heading = hero.heading || fallback.heading;
const headingHighlight = hero.headingHighlight || fallback.headingHighlight;
const subheading = hero.subheading || fallback.subheading;
const stats = hero.stats?.length ? hero.stats : fallback.stats;
const ctaText = hero.ctaText || fallback.ctaText;
const ctaHref = hero.ctaHref || fallback.ctaHref;
---

<section class="pt-32 pb-20 px-6 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="inline-flex items-center gap-2 bg-gray-100 text-gray-700 px-4 py-2 text-xs font-semibold uppercase tracking-widest mb-6 rounded-full">
      {badge.split('·').map((part, i) => (
        <>
          {i > 0 && <span class="text-gray-300">&bull;</span>}
          <span>{part.trim()}</span>
        </>
      ))}
    </div>

    <h1 class="text-6xl lg:text-8xl font-black leading-[0.9] mb-6 tracking-tight max-w-4xl">
      {heading}<br />
      <span class="highlight-box highlight-yellow">{headingHighlight}</span>
    </h1>

    <p class="text-xl font-medium text-gray-600 mb-8 max-w-2xl leading-relaxed" set:html={subheading} />

    <div class="flex flex-wrap gap-4 mb-8">
      <a href={ctaHref} class="btn-brutal px-8 py-4">{ctaText}</a>
    </div>

    <ul class="flex items-center gap-6 text-sm font-medium text-gray-500 uppercase tracking-wide list-none p-0 m-0" aria-label="Key facts">
      {stats.map((s) => <li>{s.text}</li>)}
    </ul>
  </div>
</section>
