---
import SchoolTabs from '../islands/SchoolTabs.tsx';
import { schoolData } from '../lib/subjects';

interface Props {
  showHeading?: boolean;
}

const { showHeading = true } = Astro.props;
---

<section id="subjects" class="py-24 px-6 bg-gray-50">
  <div class="max-w-7xl mx-auto">
    {showHeading && (
      <div class="mb-12">
        <div class="section-divider" aria-hidden="true"></div>
        <h2 class="text-5xl font-black mb-4 uppercase tracking-tight">
          Your School. <span class="highlight-box highlight-pink">Your Subjects.</span>
        </h2>
        <p class="text-gray-600 font-medium max-w-2xl">
          Lessons tailored to the specific curriculum, exam board, and syllabus at each school.
        </p>
      </div>
    )}

    <SchoolTabs schoolData={schoolData} client:visible />
  </div>
</section>
