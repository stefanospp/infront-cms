---
import { getCourses } from '../lib/cms';

const allCourses = await getCourses();
const featured = allCourses.slice(0, 3);
---

<section id="courses" class="py-24 px-6 bg-white">
  <div class="max-w-5xl mx-auto">
    <div class="mb-16">
      <div class="section-divider" aria-hidden="true"></div>
      <h2 class="text-5xl font-black mb-4">REVISION <span class="highlight-box highlight-yellow">COURSES.</span></h2>
      <p class="text-gray-600 font-medium max-w-2xl">
        Structured group revision for IGCSE, A-Level, and IB sciences. Small classes, exam-focused, real results.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {featured.map((course) => (
        <a href={`/courses/${course.slug}`} class="border-2 border-gray-200 bg-white p-5 flex flex-col transition-all hover:border-gray-400 hover:translate-y-[-2px] hover:shadow-[4px_4px_0px_#e5e7eb] no-underline">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-black uppercase tracking-widest text-gray-400">
              {course.level}
            </span>
            <span
              class="text-[10px] font-black uppercase tracking-widest px-2 py-1 shrink-0"
              style={`background: ${course.color};`}
            >
              {course.dates}
            </span>
          </div>

          <h3 class="text-lg font-black mb-1 leading-tight text-gray-900">{course.name}</h3>
          <div class="flex gap-2 mb-3">
            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{course.subject}</span>
            <span class="text-[10px] text-gray-300">|</span>
            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{course.season}</span>
          </div>

          <p class="text-sm text-gray-600 font-medium leading-relaxed mb-4 line-clamp-3 flex-1">
            {course.description}
          </p>

          <div class="flex items-center justify-between pt-3 border-t border-gray-100 mt-auto">
            <div class="flex items-center gap-3">
              <span class="text-xs font-semibold text-gray-500">{course.classSize}</span>
              {course.status === 'enrolling' ? (
                <span class="text-[10px] font-black uppercase tracking-wider text-green-600">Enrolling</span>
              ) : (
                <span class="text-[10px] font-black uppercase tracking-wider text-gray-400">Coming soon</span>
              )}
            </div>
            <span class="text-xs font-black uppercase tracking-wider text-gray-900">View &rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="/courses" class="btn-brutal px-8 py-4">View All Courses</a>
    </div>
  </div>
</section>
