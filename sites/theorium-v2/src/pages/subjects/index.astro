---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import PageHero from '../../components/PageHero.astro';
import SubjectGrid from '../../components/SubjectGrid.astro';
import UniversitySection from '../../components/UniversitySection.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Subjects — Theorium" description="Biology, Chemistry, and Physics tuition tailored to your school's curriculum and exam board.">
  <Nav />
  <main id="main-content">
    <PageHero
      heading="Our"
      highlight="Subjects."
      highlightColor="pink"
      description="Biology, Chemistry, and Physics — tailored to your school's curriculum, exam board, and syllabus."
    />
    <SubjectGrid showHeading={false} />
    <UniversitySection />
  </main>
  <Footer />
</Layout>
