---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getSubjects, getCourses } from '../../lib/cms';
import { subjectDetails as fallbackSubjects } from '../../lib/subjects';
import { courses as fallbackCourses } from '../../lib/courses';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  let subjects;
  try { subjects = await getSubjects(); } catch { subjects = fallbackSubjects; }
  return subjects.map((s) => ({ params: { slug: s.slug } }));
};

const { slug } = Astro.params;
let allSubjects, allCourses;
try { allSubjects = await getSubjects(); } catch { allSubjects = fallbackSubjects; }
try { allCourses = await getCourses(); } catch { allCourses = fallbackCourses; }

const subject = allSubjects.find((s) => s.slug === slug);
if (!subject) {
  return Astro.redirect('/subjects');
}

const relatedCourses = allCourses
  .filter((c) => c.subject === subject.name || c.subject === 'All Sciences')
  .slice(0, 3);

const otherSubjects = allSubjects.filter((s) => s.slug !== subject.slug);

const highlightColor = subject.slug === 'biology' ? 'pink' : subject.slug === 'chemistry' ? 'yellow' : 'green';
---

<Layout
  title={`${subject.name} — Theorium`}
  description={`${subject.name} tuition for IGCSE, A-Level, and IB. ${subject.tagline}`}
>
  <Nav />
  <main id="main-content">
    <!-- Hero -->
    <section class="pt-32 pb-12 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <a href="/subjects" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-gray-400 hover:text-gray-900 mb-6 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Back to subjects
        </a>

        <div class="flex items-center gap-3 mb-4">
          <span
            class="text-xs font-black uppercase tracking-widest px-3 py-1"
            style={`background: ${subject.color};`}
          >
            {subject.code}
          </span>
        </div>

        <h1 class="text-5xl lg:text-6xl font-black mb-4 tracking-tight">
          {subject.name}<span class="highlight-box highlight-yellow">.</span>
        </h1>
        <p class="text-xl text-gray-600 font-medium max-w-2xl">{subject.tagline}</p>
      </div>
    </section>

    <!-- Content -->
    <section class="pb-16 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Main content -->
          <div class="md:col-span-2">
            <p class="text-lg text-gray-700 font-medium leading-relaxed mb-12">
              {subject.fullDescription}
            </p>

            <!-- Levels -->
            {subject.levels.map((level, i) => {
              const colors = ['highlight-yellow', 'highlight-green', 'highlight-pink'];
              return (
                <div class="mb-10">
                  <div class="flex items-center gap-3 mb-4">
                    <h2 class="text-xl font-black uppercase tracking-tight">
                      {level.name} <span class={`highlight-box ${colors[i % colors.length]}`}>Topics</span>
                    </h2>
                    <div class="flex gap-2">
                      {level.examBoards.map((board) => (
                        <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider border border-gray-200 px-2 py-0.5">{board}</span>
                      ))}
                    </div>
                  </div>
                  <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-2">
                    {level.topics.map((topic) => (
                      <li class="flex items-start gap-3 text-gray-700 font-medium">
                        <span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>
                        {topic}
                      </li>
                    ))}
                  </ul>
                </div>
              );
            })}

            <!-- Why study -->
            <div class="mb-10">
              <h2 class="text-xl font-black uppercase tracking-tight mb-4">
                Why Study <span class={`highlight-box highlight-${highlightColor}`}>{subject.name}</span>
              </h2>
              <ul class="space-y-2">
                {subject.whyStudy.map((reason) => (
                  <li class="flex items-start gap-3 text-gray-700 font-medium">
                    <span class="text-green-600 font-black mt-0.5 shrink-0">&#10003;</span>
                    {reason}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Sidebar -->
          <div>
            <div class="border-2 border-gray-200 p-5 sticky top-24">
              <h3 class="text-sm font-black uppercase tracking-widest text-gray-400 mb-4">At a Glance</h3>
              <div class="space-y-3 text-sm">
                <div class="flex justify-between border-b border-gray-100 pb-2">
                  <span class="font-semibold text-gray-500">Subject</span>
                  <span class="font-bold text-gray-900">{subject.name}</span>
                </div>
                <div class="flex justify-between border-b border-gray-100 pb-2">
                  <span class="font-semibold text-gray-500">Levels</span>
                  <span class="font-bold text-gray-900 text-right">{subject.levels.map((l) => l.name).join(', ')}</span>
                </div>
                <div class="flex justify-between border-b border-gray-100 pb-2">
                  <span class="font-semibold text-gray-500">Exam Boards</span>
                  <span class="font-bold text-gray-900 text-right">
                    {[...new Set(subject.levels.flatMap((l) => l.examBoards))].join(', ')}
                  </span>
                </div>
                <div class="border-b border-gray-100 pb-2">
                  <span class="font-semibold text-gray-500">Schools</span>
                  <div class="mt-1 flex flex-wrap gap-1">
                    {subject.schools.map((school) => (
                      <span class="text-[10px] font-bold text-gray-600 bg-gray-100 px-2 py-0.5">{school}</span>
                    ))}
                  </div>
                </div>
              </div>

              <a href="/contact" class="btn-brutal w-full justify-center px-6 py-3 mt-6 text-sm">Enquire Now</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Related courses -->
    {relatedCourses.length > 0 && (
      <section class="py-16 bg-gray-50 border-t border-gray-200">
        <div class="max-w-7xl mx-auto px-6">
          <h2 class="text-2xl font-black uppercase tracking-tight mb-6">
            {subject.name} <span class="highlight-box highlight-blue">Courses</span>
          </h2>
          <div class="grid md:grid-cols-3 gap-4">
            {relatedCourses.map((rc) => (
              <a href={`/courses/${rc.slug}`} class="border-2 border-gray-200 bg-white p-5 flex flex-col transition-all hover:border-gray-400 hover:translate-y-[-2px] hover:shadow-[4px_4px_0px_#e5e7eb] no-underline">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs font-black uppercase tracking-widest text-gray-400">{rc.level}</span>
                  <span class="text-[10px] font-black uppercase tracking-widest px-2 py-1 shrink-0" style={`background: ${rc.color};`}>{rc.dates}</span>
                </div>
                <h3 class="text-lg font-black mb-1 leading-tight text-gray-900">{rc.name}</h3>
                <p class="text-sm text-gray-600 font-medium leading-relaxed line-clamp-2 flex-1">{rc.description}</p>
                <div class="flex items-center justify-between pt-3 border-t border-gray-100 mt-auto">
                  <span class="text-xs font-semibold text-gray-500">{rc.classSize}</span>
                  <span class="text-xs font-black uppercase tracking-wider text-gray-900">View →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Other subjects -->
    <section class="py-16 bg-white border-t border-gray-200">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-2xl font-black uppercase tracking-tight mb-6">
          Other <span class="highlight-box highlight-green">Subjects</span>
        </h2>
        <div class="grid md:grid-cols-2 gap-4">
          {otherSubjects.map((os) => (
            <a href={`/subjects/${os.slug}`} class="border-2 border-gray-200 bg-white p-5 flex items-center justify-between transition-all hover:border-gray-400 hover:translate-y-[-2px] hover:shadow-[4px_4px_0px_#e5e7eb] no-underline">
              <div>
                <span class="text-xs font-black uppercase tracking-widest px-2 py-1 mr-2" style={`background: ${os.color};`}>{os.code}</span>
                <span class="text-xl font-black text-gray-900">{os.name}</span>
                <p class="text-sm text-gray-500 font-medium mt-1">{os.tagline}</p>
              </div>
              <span class="text-xs font-black uppercase tracking-wider text-gray-900 shrink-0 ml-4">View →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
