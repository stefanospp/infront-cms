---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — Theorium" description="Get in touch with Theorium for private science tutoring in Larnaca, Cyprus. WhatsApp, Viber, or send a message.">
  <Nav />
  <main id="main-content">
    <PageHero
      heading="Contact"
      highlight="Us."
      highlightColor="blue"
      description="Send a message or reach out directly via WhatsApp or Viber."
    />
    <ContactSection />
  </main>
  <Footer />
</Layout>
