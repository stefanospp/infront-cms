---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Terms & Conditions — Theorium" description="Theorium terms and conditions for tutoring services and website use.">
  <Nav />
  <main id="main-content">
    <PageHero
      heading="Terms &"
      highlight="Conditions."
      highlightColor="pink"
      description="Terms governing the use of our website and tutoring services."
    />

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6 space-y-10">
        <p class="text-sm text-gray-400 font-medium">Last updated: March 2026</p>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">1. <span class="highlight-box highlight-yellow">Services</span></h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            Theorium provides private science tutoring services in Biology, Chemistry, and Physics at IGCSE, A-Level, and IB levels. Services are delivered in-person in Larnaca, Cyprus and online via video conferencing. Group revision courses and one-on-one sessions are available as described on this website.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">2. Booking & <span class="highlight-box highlight-green">Payment</span></h2>
          <ul class="space-y-2 text-gray-700 font-medium">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>All bookings are confirmed once payment is received</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Payment terms and methods will be communicated at the time of booking</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Course fees are published on individual course pages where applicable</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Fees for one-on-one sessions are agreed upon before sessions begin</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">3. Cancellations & Refunds</h2>
          <ul class="space-y-2 text-gray-700 font-medium">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Individual sessions may be rescheduled with at least 24 hours' notice</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Sessions cancelled with less than 24 hours' notice may be charged in full</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Group course refunds are available up to 7 days before the course starts</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>No refunds are provided once a group course has begun</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">4. Online Sessions</h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            Online sessions are conducted via Zoom or an agreed video conferencing platform. It is the student's responsibility to ensure a stable internet connection and a suitable learning environment. Sessions may be recorded for the student's personal revision use only, with prior agreement.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">5. Intellectual <span class="highlight-box highlight-blue">Property</span></h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            All materials provided by Theorium — including revision notes, worksheets, presentations, and course content — are the intellectual property of Theorium. Materials are provided for the student's personal use only and may not be reproduced, distributed, or shared without written permission.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">6. Website Use</h2>
          <ul class="space-y-2 text-gray-700 font-medium">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>This website is provided for informational purposes about Theorium's tutoring services</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Free resources are provided for personal educational use only</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>We reserve the right to modify or remove content at any time</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Course availability, schedules, and pricing are subject to change</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">7. Limitation of Liability</h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            Theorium provides tutoring and educational support services. We do not guarantee specific exam results or grades. While we are committed to delivering high-quality tuition, academic outcomes depend on many factors including the student's effort, attendance, and engagement.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">8. Governing Law</h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            These terms are governed by the laws of the Republic of Cyprus. Any disputes shall be subject to the jurisdiction of the courts of Cyprus.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">9. Contact</h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            For any questions about these terms, contact us at <a href="mailto:theodora@theorium.cy" class="font-black hover:underline">theodora@theorium.cy</a>.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
