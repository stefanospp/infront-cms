---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import ResourceFilter from '../islands/ResourceFilter.tsx';
import Footer from '../components/Footer.astro';
import { resources } from '../lib/resources';
---

<Layout title="Free Resources — Theorium" description="Free past papers, revision notes, and worksheets for IGCSE, A-Level, and IB Biology, Chemistry, and Physics.">
  <Nav />
  <main id="main-content">
    <PageHero
      heading="Free"
      highlight="Resources."
      highlightColor="blue"
      description="Past papers, revision notes, worksheets, and reference materials to support your science studies."
    />

    <section class="py-16 px-6 bg-gray-50">
      <div class="max-w-7xl mx-auto">
        <ResourceFilter resources={resources} client:visible />
      </div>
    </section>
  </main>
  <Footer />
</Layout>
