---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCourses } from '../../lib/cms';
import { courses as fallbackCourses, getCourseBySlug as getFallbackCourse, getRelatedCourses as getFallbackRelated } from '../../lib/courses';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  let courseList;
  try {
    courseList = await getCourses();
  } catch {
    courseList = fallbackCourses;
  }
  return courseList.map((course) => ({
    params: { slug: course.slug },
  }));
};

const { slug } = Astro.params;
let allCourses;
try {
  allCourses = await getCourses();
} catch {
  allCourses = fallbackCourses;
}
const course = allCourses.find((c) => c.slug === slug);

if (!course) {
  return Astro.redirect('/courses');
}

const related = allCourses
  .filter((c) => c.slug !== course.slug && (c.subject === course.subject || c.season === course.season))
  .slice(0, 3);
---

<Layout
  title={`${course.name} — Theorium`}
  description={course.description}
>
  <Nav />
  <main id="main-content">
    <!-- Hero -->
    <section class="pt-32 pb-12 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <a href="/courses" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-gray-400 hover:text-gray-900 mb-6 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Back to courses
        </a>

        <div class="flex items-center gap-3 mb-4 flex-wrap">
          <span class="text-xs font-black uppercase tracking-widest text-gray-400">{course.level}</span>
          <span
            class="text-[10px] font-black uppercase tracking-widest px-2 py-1"
            style={`background: ${course.color};`}
          >
            {course.dates}
          </span>
          {course.status === 'enrolling' ? (
            <span class="text-[10px] font-black uppercase tracking-wider text-green-600">Enrolling</span>
          ) : (
            <span class="text-[10px] font-black uppercase tracking-wider text-gray-400">Coming soon</span>
          )}
        </div>

        <h1 class="text-4xl lg:text-5xl font-black mb-4 tracking-tight">{course.name}</h1>

        <div class="flex flex-wrap gap-2 mb-8">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider border border-gray-200 px-3 py-1">{course.subject}</span>
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider border border-gray-200 px-3 py-1">{course.season}</span>
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider border border-gray-200 px-3 py-1">{course.examBoard}</span>
        </div>
      </div>
    </section>

    <!-- Details -->
    <section class="pb-16">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Main content -->
          <div class="md:col-span-2">
            <p class="text-lg text-gray-700 font-medium leading-relaxed mb-10">
              {course.fullDescription}
            </p>

            <!-- Topics covered -->
            <div class="mb-10">
              <h2 class="text-xl font-black uppercase tracking-tight mb-4">Topics <span class="highlight-box highlight-green">Covered</span></h2>
              <ul class="space-y-2">
                {course.topics.map((topic) => (
                  <li class="flex items-start gap-3 text-gray-700 font-medium">
                    <span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>
                    {topic}
                  </li>
                ))}
              </ul>
            </div>

            <!-- What you get -->
            <div class="mb-10">
              <h2 class="text-xl font-black uppercase tracking-tight mb-4">What You <span class="highlight-box highlight-pink">Get</span></h2>
              <ul class="space-y-2">
                {course.whatYouGet.map((item) => (
                  <li class="flex items-start gap-3 text-gray-700 font-medium">
                    <span class="text-green-600 font-black mt-0.5 shrink-0">&#10003;</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Sidebar -->
          <div>
            <div class="border-2 border-gray-200 p-5 sticky top-24">
              {course.price && (
                <div class="mb-5 pb-5 border-b-2 border-gray-200">
                  <div class="text-3xl font-black">{course.price}</div>
                  {course.priceNote && (
                    <div class="text-xs font-medium text-gray-400 mt-1">{course.priceNote}</div>
                  )}
                </div>
              )}

              <h3 class="text-sm font-black uppercase tracking-widest text-gray-400 mb-4">Details</h3>
              <div class="space-y-3 text-sm">
                <div class="flex justify-between border-b border-gray-100 pb-2">
                  <span class="font-semibold text-gray-500">Duration</span>
                  <span class="font-bold text-gray-900">{course.duration}</span>
                </div>
                <div class="flex justify-between border-b border-gray-100 pb-2">
                  <span class="font-semibold text-gray-500">Schedule</span>
                  <span class="font-bold text-gray-900 text-right">{course.schedule}</span>
                </div>
                <div class="flex justify-between border-b border-gray-100 pb-2">
                  <span class="font-semibold text-gray-500">Class Size</span>
                  <span class="font-bold text-gray-900">{course.classSize}</span>
                </div>
                <div class="flex justify-between border-b border-gray-100 pb-2">
                  <span class="font-semibold text-gray-500">Exam Board</span>
                  <span class="font-bold text-gray-900">{course.examBoard}</span>
                </div>
                {course.schools.length < 5 && (
                  <div class="flex justify-between border-b border-gray-100 pb-2">
                    <span class="font-semibold text-gray-500">Schools</span>
                    <span class="font-bold text-gray-900 text-right">{course.schools.join(', ')}</span>
                  </div>
                )}
              </div>

              <a href="/contact" class="btn-brutal w-full justify-center px-6 py-3 mt-6 text-sm">Enquire Now</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Related courses -->
    {related.length > 0 && (
      <section class="py-16 bg-gray-50 border-t border-gray-200">
        <div class="max-w-7xl mx-auto px-6">
          <h2 class="text-2xl font-black uppercase tracking-tight mb-6">Related <span class="highlight-box highlight-blue">Courses</span></h2>
          <div class="grid md:grid-cols-3 gap-4">
            {related.map((rc) => (
              <a href={`/courses/${rc.slug}`} class="border-2 border-gray-200 bg-white p-5 flex flex-col transition-all hover:border-gray-400 hover:translate-y-[-2px] hover:shadow-[4px_4px_0px_#e5e7eb] no-underline">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs font-black uppercase tracking-widest text-gray-400">{rc.level}</span>
                  <span class="text-[10px] font-black uppercase tracking-widest px-2 py-1 shrink-0" style={`background: ${rc.color};`}>{rc.dates}</span>
                </div>
                <h3 class="text-lg font-black mb-1 leading-tight text-gray-900">{rc.name}</h3>
                <div class="flex gap-2 mb-3">
                  <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{rc.subject}</span>
                  <span class="text-[10px] text-gray-300">|</span>
                  <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{rc.season}</span>
                </div>
                <p class="text-sm text-gray-600 font-medium leading-relaxed line-clamp-2 flex-1">{rc.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
  <Footer />
</Layout>
