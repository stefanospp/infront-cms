---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import PageHero from '../../components/PageHero.astro';
import CourseTimeline from '../../components/CourseTimeline.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Courses — Theorium" description="Revision courses for IGCSE, A-Level, and IB sciences. Easter intensives, summer school, mock exam prep, and UCAT preparation in Larnaca, Cyprus.">
  <Nav />
  <main id="main-content">
    <PageHero
      heading="Revision"
      highlight="Courses."
      highlightColor="yellow"
      description="Structured group revision for IGCSE, A-Level, and IB sciences. Small classes, exam-focused, real results."
    />
    <CourseTimeline />
  </main>
  <Footer />
</Layout>
