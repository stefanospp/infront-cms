---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { value: '10+', label: 'Years Teaching' },
  { value: '500+', label: 'Students Taught' },
  { value: '3', label: 'Science Subjects' },
  { value: '11', label: 'Schools Covered' },
];

const qualifications = [
  { title: 'BSc in Biological Sciences', institution: 'University of [Placeholder]', year: '20XX' },
  { title: 'PGCE / Teaching Qualification', institution: 'University of [Placeholder]', year: '20XX' },
  { title: 'MSc in Science Education', institution: 'University of [Placeholder]', year: '20XX' },
];

const philosophy = [
  {
    title: 'Exam-First Approach',
    description: 'Every lesson is built around how the exam works — not just the content. Students learn to read questions, structure answers, and maximise marks using real past papers and mark schemes.',
  },
  {
    title: 'Small Groups, Individual Attention',
    description: 'Group classes are capped at 8–10 students. Everyone gets their questions answered. One-on-one sessions are available for students who need focused support.',
  },
  {
    title: 'Curriculum-Aligned',
    description: 'No generic worksheets. Every lesson follows the exact syllabus your school uses — Cambridge, Edexcel, IB, or AQA. The topics, the depth, the exam format — all matched to your board.',
  },
  {
    title: 'Beyond the Grade',
    description: 'Grades matter, but so does understanding. Students who genuinely understand the science perform better under pressure, retain knowledge longer, and are better prepared for university.',
  },
];
---

<Layout title="About — Theorium" description="Meet Theodora — private science tutor in Larnaca, Cyprus. 10+ years teaching Biology, Chemistry, and Physics at IGCSE, A-Level, and IB.">
  <Nav />
  <main id="main-content">
    <PageHero
      heading="About"
      highlight="Theodora."
      highlightColor="green"
      description="The person behind the science."
    />

    <!-- Bio -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-12">
          <div class="md:col-span-2">
            <p class="text-lg text-gray-700 font-medium leading-relaxed mb-6">
              [Theodora's bio — 2-3 paragraphs about her background, what drove her to teaching, and her approach to science tuition. This content will be replaced with real copy.]
            </p>
            <p class="text-lg text-gray-700 font-medium leading-relaxed mb-6">
              With over a decade of experience teaching Biology, Chemistry, and Physics to students across Cyprus, Theodora has developed a teaching method built around one principle: if you understand how the exam works, you perform better. Every lesson connects theory to exam questions — past papers, mark schemes, examiner reports — so students know exactly what's expected.
            </p>
            <p class="text-lg text-gray-700 font-medium leading-relaxed">
              Based in Larnaca with online sessions available across Europe, Theodora works with students from 11 private schools covering Cambridge, Edexcel, IB, and AQA exam boards. From IGCSE through to A-Level and university entrance exam preparation, the focus is always the same: deep understanding, practical exam skills, and real results.
            </p>
          </div>

          <!-- Photo placeholder + stats -->
          <div>
            <div class="bg-gray-100 border-2 border-gray-200 aspect-[3/4] mb-6 flex items-center justify-center">
              <span class="text-sm font-bold text-gray-400 uppercase tracking-wider">Photo</span>
            </div>
            <div class="grid grid-cols-2 gap-3">
              {stats.map((stat) => (
                <div class="border-2 border-gray-200 p-3 text-center">
                  <div class="text-2xl font-black">{stat.value}</div>
                  <div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Teaching Philosophy -->
    <section class="py-16 bg-gray-50 border-t border-gray-200">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-3xl font-black uppercase tracking-tight mb-8">
          Teaching <span class="highlight-box highlight-pink">Philosophy</span>
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          {philosophy.map((item, i) => {
            const colors = ['#fff33b', '#b8ff6b', '#ffb3c6', '#a8e8ff'];
            return (
              <div class="border-l-4 pl-6 py-2" style={`border-color: ${colors[i % colors.length]};`}>
                <h3 class="text-lg font-black mb-2">{item.title}</h3>
                <p class="text-sm text-gray-600 font-medium leading-relaxed">{item.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Qualifications -->
    <section class="py-16 bg-white border-t border-gray-200">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-3xl font-black uppercase tracking-tight mb-8">
          Qualifications & <span class="highlight-box highlight-blue">Experience</span>
        </h2>
        <div class="space-y-4 max-w-2xl">
          {qualifications.map((q) => (
            <div class="flex items-start gap-4 border-b border-gray-100 pb-4">
              <span class="text-sm font-black text-gray-300 shrink-0 w-12">{q.year}</span>
              <div>
                <div class="font-black">{q.title}</div>
                <div class="text-sm text-gray-500 font-medium">{q.institution}</div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-sm text-gray-400 font-medium mt-6">
          [Additional certifications, professional development, and memberships can be added here.]
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-gray-50 border-t border-gray-200">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-black uppercase tracking-tight mb-4">
          Ready to <span class="highlight-box highlight-yellow">Start?</span>
        </h2>
        <p class="text-gray-600 font-medium max-w-xl mx-auto mb-8">
          Get in touch to discuss your goals and find the right programme for you.
        </p>
        <a href="/contact" class="btn-brutal px-8 py-4">Get In Touch</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
