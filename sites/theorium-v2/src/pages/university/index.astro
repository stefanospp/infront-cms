---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import PageHero from '../../components/PageHero.astro';
import Footer from '../../components/Footer.astro';
import { universityExams } from '../../lib/university';
---

<Layout title="University & Medical School — Theorium" description="UCAT, BMAT, SAT, and AP preparation for university entrance. Medical school admissions support in Cyprus.">
  <Nav />
  <main id="main-content">
    <PageHero
      heading="University"
      highlight="& Medical."
      highlightColor="green"
      description="Preparation for entrance exams and admissions to universities in the UK, US, Netherlands, Germany, and Cyprus."
    />

    <section class="py-16 px-6 bg-gray-50">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-4">
          {universityExams.map((exam) => (
            <a
              href={`/university/${exam.slug}`}
              class="border-2 border-gray-200 bg-white p-6 flex flex-col transition-all hover:border-gray-400 hover:translate-y-[-2px] hover:shadow-[4px_4px_0px_#e5e7eb] no-underline"
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-black uppercase tracking-widest text-gray-400">{exam.region}</span>
                <span
                  class="text-[10px] font-black uppercase tracking-widest px-2 py-1 shrink-0"
                  style={`background: ${exam.color};`}
                >
                  {exam.shortName}
                </span>
              </div>

              <h2 class="text-xl font-black mb-1 leading-tight text-gray-900">{exam.name}</h2>
              <div class="flex gap-2 mb-3">
                <span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{exam.forWho}</span>
              </div>

              <p class="text-sm text-gray-600 font-medium leading-relaxed mb-4 line-clamp-3 flex-1">
                {exam.description}
              </p>

              <div class="flex items-center justify-between pt-3 border-t border-gray-100 mt-auto">
                <span class="text-xs font-semibold text-gray-500">{exam.timeline}</span>
                <span class="text-xs font-black uppercase tracking-wider text-gray-900">View →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
