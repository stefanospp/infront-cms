---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy — Theorium" description="Theorium privacy policy. How we collect, use, and protect your personal data.">
  <Nav />
  <main id="main-content">
    <PageHero
      heading="Privacy"
      highlight="Policy."
      highlightColor="blue"
      description="How we collect, use, and protect your personal data."
    />

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6 space-y-10">
        <p class="text-sm text-gray-400 font-medium">Last updated: March 2026</p>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">1. Who We <span class="highlight-box highlight-yellow">Are</span></h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            Theorium is a private science tutoring service operated by Theodora [Surname], based in Larnaca, Cyprus. When we refer to "we", "us", or "our" in this policy, we mean Theorium.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">2. Information We <span class="highlight-box highlight-green">Collect</span></h2>
          <p class="text-gray-700 font-medium leading-relaxed mb-3">We collect the following information when you use our website or contact us:</p>
          <ul class="space-y-2 text-gray-700 font-medium">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Name, email address, and phone number (when you submit the contact form)</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>School name (when voluntarily provided)</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Messages and enquiries you send us</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Basic analytics data (pages visited, device type) if analytics are enabled</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">3. How We Use Your <span class="highlight-box highlight-pink">Data</span></h2>
          <ul class="space-y-2 text-gray-700 font-medium">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>To respond to your enquiries and provide information about our services</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>To schedule and manage tutoring sessions</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>To improve our website and services</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>We do not sell, rent, or share your personal data with third parties for marketing purposes</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">4. Data Storage & Security</h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            Your data is stored securely and processed in accordance with applicable data protection laws. Contact form submissions are transmitted over encrypted connections (HTTPS). We retain your data only for as long as necessary to fulfil the purposes described above.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">5. Cookies</h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            This website uses essential cookies required for the site to function. If analytics are enabled, we may use privacy-respecting analytics tools that do not track individual users. No advertising or third-party tracking cookies are used.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">6. Your Rights</h2>
          <p class="text-gray-700 font-medium leading-relaxed mb-3">Under GDPR and applicable Cyprus data protection law, you have the right to:</p>
          <ul class="space-y-2 text-gray-700 font-medium">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Access the personal data we hold about you</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Request correction or deletion of your data</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Withdraw consent at any time</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-gray-900 rounded-full mt-2 shrink-0"></span>Lodge a complaint with the Office of the Commissioner for Personal Data Protection in Cyprus</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-black uppercase tracking-tight mb-3">7. Contact</h2>
          <p class="text-gray-700 font-medium leading-relaxed">
            For any questions about this privacy policy or to exercise your rights, contact us at <a href="mailto:theodora@theorium.cy" class="font-black hover:underline">theodora@theorium.cy</a>.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
