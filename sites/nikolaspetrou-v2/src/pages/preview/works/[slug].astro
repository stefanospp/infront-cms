---
export const prerender = false;

import InnerLayout from '../../../layouts/InnerLayout.astro';
import PreviewBanner from '../../../components/PreviewBanner.astro';
import { getProject, getProjects } from '../../../lib/payload';

const { slug } = Astro.params;
const draft = { draft: true };

const [project, allProjects] = await Promise.all([
  getProject(slug!, draft),
  getProjects(draft),
]);

if (!project) {
  return Astro.redirect('/preview/works');
}

const currentIndex = allProjects.findIndex((p) => p.slug === project.slug);
const nextProject = allProjects[(currentIndex + 1) % allProjects.length];
---

<InnerLayout title={project.title} description={`${project.title} — ${project.category}`} dark noindex>
  <PreviewBanner />
  <!-- Full-screen video hero -->
  <section class="relative h-[70vh] md:h-[85vh] overflow-hidden -mt-24 md:-mt-32">
    <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline>
      <source src={project.video_url} type={project.video_url.endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
    <div class="absolute bottom-8 left-4 md:left-8 z-10">
      <span class="text-label opacity-50 block mb-4">{project.category} / {project.year}</span>
      <h1 class="text-giant text-white mix-blend-difference">{project.title}</h1>
    </div>
  </section>

  <!-- Project details -->
  <section class="px-4 md:px-8 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <span class="text-label opacity-40 block mb-4">Category</span>
        <p class="text-lg">{project.category}</p>
      </div>
      <div>
        <span class="text-label opacity-40 block mb-4">Year</span>
        <p class="text-lg">{project.year}</p>
      </div>
      <div>
        <span class="text-label opacity-40 block mb-4">Role</span>
        <p class="text-lg">{project.role || 'Director, Cinematographer'}</p>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="px-4 md:px-8 py-16 md:py-24 border-t border-white/10 max-w-3xl">
    <p class="text-xl leading-relaxed opacity-70">
      {project.fullDescription || 'A cinematic exploration capturing the essence of movement and emotion. This project pushed the boundaries of visual storytelling through careful composition, natural lighting, and an authentic approach to every frame.'}
    </p>
  </section>

  <!-- Full video embed -->
  <section class="px-4 md:px-8 py-12 md:py-16">
    <div class="relative aspect-video overflow-hidden bg-black/50">
      <video class="w-full h-full object-cover" controls playsinline preload="metadata">
        <source src={project.video_url} type={project.video_url.endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
      </video>
    </div>
  </section>

  <!-- Next project -->
  <section class="px-4 md:px-8 py-16 md:py-24 border-t border-white/10">
    <span class="text-label opacity-40 block mb-6">(Next Project)</span>
    <a href={`/preview/works/${nextProject!.slug}`} class="group cursor-hover block">
      <h2 class="text-huge hover:opacity-70 transition-opacity">{nextProject!.title}</h2>
      <span class="text-label opacity-40 mt-2 block">{nextProject!.category} / {nextProject!.year}</span>
    </a>
  </section>

  <!-- Back to works -->
  <section class="px-4 md:px-8 py-16 md:py-24">
    <a href="/preview/works" class="text-label border border-white/30 px-6 py-3 cursor-hover hover:bg-white hover:text-black transition-all inline-block">
      All Works
    </a>
  </section>
</InnerLayout>
