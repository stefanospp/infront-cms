---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';

const navLinks = [
  { label: 'Works', href: '/works' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About — Nikolas Petrou</title>
    <meta name="description" content="About Nikolas Petrou — Videographer & Content Creator" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-black text-white overflow-x-hidden" style="cursor:none">
    <div class="cursor-ring" id="cursorRing"></div>
    <div class="cursor-dot" id="cursorDot"></div>

    <Navigation links={navLinks} />

    <!-- Full-screen video background (fixed) -->
    <div class="about-video-bg">
      <video autoplay muted loop playsinline>
        <source src="https://cdn.pixabay.com/video/2022/08/16/128015-740186542_large.mp4" type="video/mp4" />
      </video>
      <div class="about-video-overlay"></div>
    </div>

    <!-- Scrolling credits content -->
    <div class="about-credits" id="aboutCredits">
      <!-- Spacer so video is visible first -->
      <div class="h-screen"></div>

      <div class="credits-block">
        <span class="text-label opacity-40">Directed by</span>
        <h2 class="credits-name">Nikolas Petrou</h2>
      </div>

      <div class="credits-block">
        <span class="text-label opacity-40">Based in</span>
        <h2 class="credits-title">Cyprus</h2>
      </div>

      <div class="credits-block">
        <span class="text-label opacity-40">Specialising in</span>
        <h2 class="credits-title">Cinematic Storytelling</h2>
        <h2 class="credits-title">Aerial Cinematography</h2>
        <h2 class="credits-title">Brand Content</h2>
        <h2 class="credits-title">Documentary Film</h2>
      </div>

      <div class="credits-block credits-block-text">
        <span class="text-label opacity-40 block mb-6">(About)</span>
        <p class="credits-body">
          I'm a videographer and content creator with a passion for visual storytelling.
          Every project begins with understanding the story — then finding the most
          compelling way to bring it to life.
        </p>
        <p class="credits-body">
          With experience across commercial campaigns, documentaries, brand content,
          and aerial cinematography, I bring a cinematic eye to every frame. From
          pre-production planning to final colour grade, I'm involved at every stage.
        </p>
      </div>

      <div class="credits-block">
        <span class="text-label opacity-40">Experience</span>
        <div class="credits-stat-row">
          <div>
            <span class="credits-stat">5+</span>
            <span class="text-label opacity-40">Years</span>
          </div>
          <div>
            <span class="credits-stat">50+</span>
            <span class="text-label opacity-40">Projects</span>
          </div>
          <div>
            <span class="credits-stat">20+</span>
            <span class="text-label opacity-40">Clients</span>
          </div>
        </div>
      </div>

      <div class="credits-block">
        <span class="text-label opacity-40">Process</span>
        <div class="credits-process">
          <div>
            <h3 class="credits-process-title">Pre-Production</h3>
            <p class="credits-process-desc">Concept, scripting, location scouting</p>
          </div>
          <div>
            <h3 class="credits-process-title">Production</h3>
            <p class="credits-process-desc">Direction, cinematography, sound</p>
          </div>
          <div>
            <h3 class="credits-process-title">Post-Production</h3>
            <p class="credits-process-desc">Editing, colour grading, finishing</p>
          </div>
        </div>
      </div>

      <div class="credits-block">
        <span class="text-label opacity-40">Equipment</span>
        <h2 class="credits-title">Sony FX6</h2>
        <h2 class="credits-title">DJI Inspire 3</h2>
        <h2 class="credits-title">DaVinci Resolve</h2>
      </div>

      <div class="credits-block">
        <span class="text-label opacity-40">Get in Touch</span>
        <a href="/contact" class="credits-name cursor-hover hover:opacity-70 transition-opacity">
          Let's Work Together
        </a>
      </div>

      <!-- Footer -->
      <footer class="px-4 md:px-8 py-8 md:py-12 border-t border-white/10 text-center">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <a href="/" class="font-bold tracking-[0.25em] text-base cursor-hover">
            NI<span style="display:inline-block;transform:scaleX(-1);margin-left:-0.35em">K</span>
          </a>
          <div class="flex gap-6">
            <a href="/works" class="text-label cursor-hover hover:opacity-50 transition-opacity">Works</a>
            <a href="/services" class="text-label cursor-hover hover:opacity-50 transition-opacity">Services</a>
            <a href="/contact" class="text-label cursor-hover hover:opacity-50 transition-opacity">Contact</a>
          </div>
          <div class="text-label opacity-40">&copy; {new Date().getFullYear()} Nikolas Petrou</div>
        </div>
      </footer>
    </div>

    <style>
      .about-video-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
      }

      .about-video-bg video {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .about-video-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
      }

      .about-credits {
        position: relative;
        z-index: 1;
      }

      .credits-block {
        min-height: 70vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 4rem 1rem;
      }

      @media (min-width: 768px) {
        .credits-block {
          padding: 4rem 2rem;
          min-height: 80vh;
        }
      }

      .credits-name {
        font-size: clamp(2.5rem, 8vw, 7rem);
        font-weight: 600;
        letter-spacing: -0.04em;
        text-transform: uppercase;
        line-height: 0.95;
        margin-top: 1rem;
        text-decoration: none;
        color: #fff;
      }

      .credits-title {
        font-size: clamp(1.5rem, 4vw, 3.5rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin-top: 0.5rem;
        opacity: 0.8;
      }

      .credits-block-text {
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
      }

      .credits-body {
        font-size: clamp(1rem, 1.5vw, 1.2rem);
        line-height: 1.8;
        opacity: 0.6;
        margin-bottom: 1.5rem;
      }

      .credits-stat-row {
        display: flex;
        justify-content: center;
        gap: 3rem;
        margin-top: 2rem;
      }

      .credits-stat {
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 600;
        display: block;
        margin-bottom: 0.5rem;
      }

      .credits-process {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        margin-top: 2rem;
      }

      @media (min-width: 768px) {
        .credits-process {
          flex-direction: row;
          justify-content: center;
          gap: 4rem;
        }
      }

      .credits-process-title {
        font-size: 1.25rem;
        font-weight: 500;
        margin-bottom: 0.5rem;
      }

      .credits-process-desc {
        font-size: 0.875rem;
        opacity: 0.4;
      }
    </style>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Fade in each credits block as it scrolls into view
      document.querySelectorAll('.credits-block').forEach((block) => {
        gsap.from(block.children, {
          y: 40,
          opacity: 0,
          duration: 1,
          stagger: 0.15,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: block,
            start: 'top 80%',
            toggleActions: 'play none none none',
          },
        });
      });

      // Cursor
      const cursorRing = document.getElementById('cursorRing')!;
      const cursorDot = document.getElementById('cursorDot')!;
      let mouseX = 0, mouseY = 0, ringX = 0, ringY = 0, dotX = 0, dotY = 0;

      document.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

      function animateCursor() {
        ringX += (mouseX - ringX) * 0.15; ringY += (mouseY - ringY) * 0.15;
        cursorRing.style.left = ringX + 'px'; cursorRing.style.top = ringY + 'px';
        dotX += (mouseX - dotX) * 0.5; dotY += (mouseY - dotY) * 0.5;
        cursorDot.style.left = dotX + 'px'; cursorDot.style.top = dotY + 'px';
        requestAnimationFrame(animateCursor);
      }
      animateCursor();

      document.querySelectorAll('.cursor-hover').forEach((el) => {
        el.addEventListener('mouseenter', () => cursorRing.classList.add('hover'));
        el.addEventListener('mouseleave', () => cursorRing.classList.remove('hover'));
      });

      if (window.matchMedia('(pointer: coarse)').matches) {
        document.body.style.cursor = 'auto';
        cursorRing.style.display = 'none';
        cursorDot.style.display = 'none';
      }
    </script>
  </body>
</html>
