---
import '../styles/global.css';
import V2Layout from '../layouts/V2Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import ProjectList from '../components/ProjectList.astro';
import HorizontalScroll from '../components/HorizontalScroll.astro';
import ServiceList from '../components/ServiceList.astro';
import Clients from '../components/Clients.astro';
import Footer from '../components/Footer.astro';
import { getProjects, getServices, getClients, getSiteSettings, getHomeSections } from '../lib/payload';
import type { Project, Service, Client, SiteSettings, HomeSections } from '../lib/payload';

let projects: Project[];
let services: Service[];
let clients: Client[];
let settings: SiteSettings;
let homeSections: HomeSections;

try {
  [projects, services, clients, settings, homeSections] = await Promise.all([
    getProjects(),
    getServices(),
    getClients(),
    getSiteSettings(),
    getHomeSections(),
  ]);
} catch {
  // Fallback data when Payload is not running
  settings = {
    siteName: 'Nikolas Petrou',
    tagline: 'Capturing moments that move.',
    navLinks: [
      { label: 'Works', href: '/works' },
      { label: 'About', href: '/about' },
      { label: 'Contact', href: '/contact' },
    ],
    contact: { email: 'hello@nikolaspetrou.com' },
    social: { instagram: '#', vimeo: '#', youtube: '#' },
  };

  homeSections = {
    hero: {
      heading: 'Nikolas Petrou',
      subtext: 'Capturing moments that move.',
      video_url: 'https://cdn.infront.cy/nikolaspetrou/videos/landing-page.webm',
    },
    works: { label: '(Selected Works)' },
    horizontalScroll: {
      words: [
        { word: 'Cinematic' },
        { word: 'Authentic' },
        { word: 'Visual' },
        { word: 'Stories' },
        { word: 'Capture' },
        { word: 'Movement' },
        { word: 'Emotion' },
      ],
    },
    services: { label: '(Services)' },
    clients: { label: '(Selected Clients)' },
    footer: {
      label: '(Get in Touch)',
      ctaLine1: "LET'S",
      ctaLine2: 'WORK',
      ctaLine3: 'TOGETHER',
      video_url: 'https://cdn.pixabay.com/video/2024/05/23/213425_large.mp4',
      email: 'hello@nikolaspetrou.com',
      socialLinks: [
        { label: 'Instagram', href: '#' },
        { label: 'Vimeo', href: '#' },
        { label: 'YouTube', href: '#' },
      ],
    },
  };

  projects = [
    {
      id: '1',
      title: 'Coastal',
      slug: 'coastal',
      category: 'Videography',
      year: 2024,
      video_url:
        'https://cdn.pixabay.com/video/2016/05/12/3127-166335864_large.mp4',
      order: 1,
    },
    {
      id: '2',
      title: 'Stay True to Yourself',
      slug: 'stay-true',
      category: 'Creative Direction',
      year: 2024,
      video_url:
        'https://cdn.pixabay.com/video/2022/11/22/140111-774507949_large.mp4',
      order: 2,
    },
    {
      id: '3',
      title: 'Aerial Perspectives',
      slug: 'aerial-perspectives',
      category: 'Drone Operation',
      year: 2024,
      video_url:
        'https://cdn.pixabay.com/video/2024/06/29/218714_large.mp4',
      order: 3,
    },
    {
      id: '4',
      title: 'Underwater World',
      slug: 'underwater-world',
      category: 'Documentary',
      year: 2023,
      video_url:
        'https://cdn.pixabay.com/video/2025/04/29/275633_large.mp4',
      order: 4,
    },
    {
      id: '5',
      title: 'Golden Hour',
      slug: 'golden-hour',
      category: 'Brand Content',
      year: 2023,
      video_url:
        'https://cdn.pixabay.com/video/2022/11/11/138588-770315514_large.mp4',
      order: 5,
    },
  ];

  services = [
    {
      id: '1',
      title: 'Video Production',
      description:
        'Commercial and documentary filmmaking with cinematic quality. From concept to final delivery.',
      video_url:
        'https://cdn.pixabay.com/video/2024/05/23/213425_large.mp4',
      order: 1,
    },
    {
      id: '2',
      title: 'Creative Direction',
      description:
        'Creative direction and visual storytelling. Guiding projects from initial concept through to final cut.',
      video_url:
        'https://cdn.pixabay.com/video/2022/11/22/140111-774507949_large.mp4',
      order: 2,
    },
    {
      id: '3',
      title: 'Content Creation',
      description:
        'Brand content planning and social media visual strategies that drive engagement and growth.',
      video_url:
        'https://cdn.pixabay.com/video/2024/06/29/218714_large.mp4',
      order: 3,
    },
    {
      id: '4',
      title: 'Post Production',
      description:
        'Color grading, editing, and finishing with meticulous attention to detail and craft.',
      video_url:
        'https://cdn.pixabay.com/video/2025/04/29/275633_large.mp4',
      order: 4,
    },
  ];

  clients = [
    { id: '1', name: 'Patagonia', type: 'Brand Campaign', year: 2024, video_url: 'https://cdn.pixabay.com/video/2016/05/12/3127-166335864_large.mp4', order: 1 },
    { id: '2', name: 'GoPro', type: 'Action Sports Content', year: 2024, video_url: 'https://cdn.pixabay.com/video/2022/11/22/140111-774507949_large.mp4', order: 2 },
    { id: '3', name: 'Sony', type: 'Product Launch Films', year: 2023, video_url: 'https://cdn.pixabay.com/video/2024/06/29/218714_large.mp4', order: 3 },
    { id: '4', name: 'DJI', type: 'Aerial Cinematography', year: 2023, video_url: 'https://cdn.pixabay.com/video/2025/04/29/275633_large.mp4', order: 4 },
    { id: '5', name: 'National Geographic', type: 'Documentary Series', year: 2023, video_url: 'https://cdn.pixabay.com/video/2022/11/11/138588-770315514_large.mp4', order: 5 },
  ];
}

const navLinks = settings.navLinks;

const videoUrls = projects.map((p) => p.video_url);
const words = homeSections.horizontalScroll.words.map((w, i) => ({
  word: w.word,
  videoUrl: w.videoUrl || videoUrls[i % videoUrls.length],
}));
const clientItems = clients.map((c) => ({
  name: c.name,
  videoUrl: c.video_url || videoUrls[clients.indexOf(c) % videoUrls.length],
}));

const footerSocial = homeSections.footer.socialLinks;
---

<V2Layout title={`${settings.siteName} — Videographer`}>
  <Navigation links={navLinks} />
  <Hero
    heading={homeSections.hero.heading}
    subtext={homeSections.hero.subtext}
    videoUrl={homeSections.hero.video_url}
  />
  <ProjectList projects={projects} label={homeSections.works.label} />
  <HorizontalScroll words={words} />
  <ServiceList services={services} label={homeSections.services.label} />
  <Clients clients={clientItems} label={homeSections.clients.label} />
  <Footer
    email={homeSections.footer.email}
    social={footerSocial}
    videoUrl={homeSections.footer.video_url}
    label={homeSections.footer.label}
    ctaLine1={homeSections.footer.ctaLine1}
    ctaLine2={homeSections.footer.ctaLine2}
    ctaLine3={homeSections.footer.ctaLine3}
  />
</V2Layout>
