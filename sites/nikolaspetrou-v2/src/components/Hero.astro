---
interface Props {
  heading: string;
  subtext: string;
  videoUrl: string;
}

const { heading, subtext, videoUrl } = Astro.props;
const [firstName, lastName] = heading.split(' ');
---

<header class="hero-video-wrapper">
  <video muted loop playsinline preload="auto" id="heroVideo">
    <source src={videoUrl} type={videoUrl.endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
  </video>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <h1 class="text-giant">{firstName}<br />{lastName}</h1>
    <p class="hero-subtext">{subtext}</p>
  </div>

  <div class="hero-scroll-indicator">
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="12" y1="5" x2="12" y2="19"></line>
      <polyline points="19 12 12 19 5 12"></polyline>
    </svg>
  </div>
</header>

<script>
  import { gsap } from 'gsap';

  const heroVideo = document.getElementById('heroVideo') as HTMLVideoElement;

  // --- Video visibility management ---
  if (heroVideo) {
    let isVisible = true;
    let revealed = false;

    function tryPlay() {
      if (revealed && isVisible && !document.hidden) {
        heroVideo.play().catch(() => {});
      }
    }

    const heroObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          isVisible = entry.isIntersecting;
          if (isVisible) tryPlay();
          else heroVideo.pause();
        });
      },
      { threshold: 0.1 },
    );
    heroObserver.observe(heroVideo.closest('.hero-video-wrapper')!);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) heroVideo.pause();
      else tryPlay();
    });

    // --- Triggered by the loader overlay when it's done ---
    document.addEventListener('hero:reveal', () => {
      revealed = true;
      heroVideo.play().catch(() => {});

      // Start GSAP animations only after reveal
      gsap.fromTo('.hero-content .text-giant',
        { y: 80, opacity: 0 },
        { y: 0, opacity: 1, duration: 1.6, ease: 'power4.out', delay: 0.2 },
      );

      gsap.fromTo('.hero-subtext',
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.6 },
      );

      gsap.fromTo('.hero-scroll-indicator',
        { opacity: 0, y: -10 },
        { opacity: 1, y: 0, duration: 1, ease: 'power2.out', delay: 1.2 },
      );
    });
  }

  // Hide hero content until reveal
  gsap.set('.hero-content .text-giant', { y: 80, opacity: 0 });
  gsap.set('.hero-subtext', { y: 20, opacity: 0 });
  gsap.set('.hero-scroll-indicator', { opacity: 0, y: -10 });
</script>
