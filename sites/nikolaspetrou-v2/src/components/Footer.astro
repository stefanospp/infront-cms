---
interface Props {
  email: string;
  social: { label: string; href: string }[];
  videoUrl?: string;
  label?: string;
  ctaLine1?: string;
  ctaLine2?: string;
  ctaLine3?: string;
}

const { email, social, videoUrl, label = '(Get in Touch)', ctaLine1 = "LET'S", ctaLine2 = 'WORK', ctaLine3 = 'TOGETHER' } = Astro.props;
const year = new Date().getFullYear();
---

<section id="contact" class="footer-section">
  <div class="footer-cta-area">
    <span class="text-label footer-label">{label}</span>

    <a href={`mailto:${email}`} class="footer-cta-link cursor-hover">
      <!-- Video layer -->
      <video class="footer-video" muted loop playsinline preload="none">
        {videoUrl && <source src={videoUrl} type="video/mp4" />}
      </video>

      <!-- Black overlay with knockout text — Desktop -->
      <div class="footer-knockout footer-knockout-desktop">
        <svg class="footer-svg" viewBox="0 0 1200 400" preserveAspectRatio="xMinYMid slice">
          <defs>
            <mask id="textMask">
              <rect width="100%" height="100%" fill="white" />
              <text x="0" y="130" class="footer-svg-text">{ctaLine1}</text>
              <text x="0" y="260" class="footer-svg-text">{ctaLine2}</text>
              <text x="0" y="390" class="footer-svg-text">{ctaLine3}</text>
            </mask>
          </defs>
          <rect width="100%" height="100%" fill="black" mask="url(#textMask)" />
        </svg>
      </div>
      <!-- Black overlay with knockout text — Mobile -->
      <div class="footer-knockout footer-knockout-mobile">
        <svg class="footer-svg" viewBox="0 0 600 400" preserveAspectRatio="xMinYMid slice">
          <defs>
            <mask id="textMaskMobile">
              <rect width="100%" height="100%" fill="white" />
              <text x="0" y="110" class="footer-svg-text-mobile">{ctaLine1}</text>
              <text x="0" y="220" class="footer-svg-text-mobile">{ctaLine2}</text>
              <text x="0" y="330" class="footer-svg-text-mobile">{ctaLine3}</text>
            </mask>
          </defs>
          <rect width="100%" height="100%" fill="black" mask="url(#textMaskMobile)" />
        </svg>
      </div>
    </a>
  </div>

  <div
    class="flex flex-col md:flex-row justify-between items-start md:items-end pt-16 border-t border-white/20"
  >
    <div class="flex gap-8 mb-8 md:mb-0">
      {
        social.map((link) => (
          <a href={link.href} class="text-label cursor-hover hover:opacity-50 transition-opacity">
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="text-label opacity-50">&copy; {year} Nikolas Petrou · Built by <a href="https://infront.cy" target="_blank" rel="noopener" class="cursor-hover hover:opacity-100 transition-opacity">infront.cy</a></div>
  </div>
</section>

<style>
  .footer-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2rem 1rem;
    background: #000;
    color: #fff;
  }

  @media (min-width: 768px) {
    .footer-section {
      padding: 4rem 2rem;
    }
  }

  .footer-cta-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .footer-label {
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 2rem;
    display: block;
  }

  .footer-cta-link {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 1;
    overflow: hidden;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .footer-cta-link:hover {
    opacity: 0.85;
  }

  .footer-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .footer-knockout {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .footer-svg {
    width: 100%;
    height: 100%;
  }

  .footer-svg-text {
    font-family: 'Inter', sans-serif;
    font-size: 140px;
    font-weight: 700;
    letter-spacing: -0.04em;
    fill: black;
  }

  .footer-svg-text-mobile {
    font-family: 'Inter', sans-serif;
    font-size: 90px;
    font-weight: 700;
    letter-spacing: -0.04em;
    fill: black;
  }

  /* Show desktop SVG by default, hide mobile */
  .footer-knockout-mobile {
    display: none;
  }
  .footer-knockout-desktop {
    display: block;
  }

  @media (max-width: 767px) {
    .footer-knockout-desktop {
      display: none;
    }
    .footer-knockout-mobile {
      display: block;
    }

    .footer-cta-link {
      aspect-ratio: 3 / 2;
    }

    .footer-label {
      margin-bottom: 1rem;
    }
  }
</style>

<script>
  const footer = document.getElementById('contact');
  const video = footer?.querySelector('.footer-video') as HTMLVideoElement;

  if (footer && video) {
    // Preload video when footer is ~600px away
    let preloaded = false;
    const preloadObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !preloaded) {
            video.preload = 'auto';
            video.load();
            preloaded = true;
            preloadObserver.unobserve(footer);
          }
        });
      },
      { rootMargin: '600px 0px' },
    );
    preloadObserver.observe(footer);

    // Play/pause when visible
    const playObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            video.play();
          } else {
            video.pause();
          }
        });
      },
      { threshold: 0.1 },
    );
    playObserver.observe(footer);
  }
</script>
