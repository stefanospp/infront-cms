---
interface Props {
  email: string;
  social: { label: string; href: string }[];
  videoUrl?: string;
}

const { email, social, videoUrl } = Astro.props;
const year = new Date().getFullYear();
---

<section id="contact" class="footer-section">
  <div class="footer-cta-area">
    <span class="text-label footer-label">(Get in Touch)</span>

    <a href={`mailto:${email}`} class="footer-cta-link cursor-hover">
      <!-- Video layer -->
      <video class="footer-video" muted loop playsinline autoplay preload="auto">
        {videoUrl && <source src={videoUrl} type="video/mp4" />}
      </video>

      <!-- Black overlay with knockout text -->
      <div class="footer-knockout">
        <svg class="footer-svg" viewBox="0 0 1200 400" preserveAspectRatio="xMinYMid slice">
          <defs>
            <mask id="textMask">
              <!-- White = visible, Black = hidden. Fill rect white, text black = cutout -->
              <rect width="100%" height="100%" fill="white" />
              <text x="0" y="130" class="footer-svg-text">LET'S</text>
              <text x="0" y="260" class="footer-svg-text">WORK</text>
              <text x="0" y="390" class="footer-svg-text">TOGETHER</text>
            </mask>
          </defs>
          <!-- Black rect with text cut out, revealing video beneath -->
          <rect width="100%" height="100%" fill="black" mask="url(#textMask)" />
        </svg>
      </div>
    </a>
  </div>

  <div
    class="flex flex-col md:flex-row justify-between items-start md:items-end pt-16 border-t border-white/20"
  >
    <div class="flex gap-8 mb-8 md:mb-0">
      {
        social.map((link) => (
          <a href={link.href} class="text-label cursor-hover hover:opacity-50 transition-opacity">
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="text-label opacity-50">&copy; {year} Nikolas Petrou</div>
  </div>
</section>

<style>
  .footer-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 4rem 2rem;
    background: #000;
    color: #fff;
  }

  .footer-cta-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .footer-label {
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 2rem;
    display: block;
  }

  .footer-cta-link {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 1;
    overflow: hidden;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .footer-cta-link:hover {
    opacity: 0.85;
  }

  .footer-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .footer-knockout {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .footer-svg {
    width: 100%;
    height: 100%;
  }

  .footer-svg-text {
    font-family: 'Inter', sans-serif;
    font-size: 140px;
    font-weight: 700;
    letter-spacing: -0.04em;
    fill: black;
  }
</style>

<script>
  const footer = document.getElementById('contact');
  const video = footer?.querySelector('.footer-video') as HTMLVideoElement;

  if (footer && video) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            video.play();
          } else {
            video.pause();
          }
        });
      },
      { threshold: 0.1 },
    );
    observer.observe(footer);
  }
</script>
