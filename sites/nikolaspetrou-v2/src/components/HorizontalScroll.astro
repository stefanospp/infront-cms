---
interface WordItem {
  word: string;
  videoUrl?: string;
}

interface Props {
  words: WordItem[];
}

const { words } = Astro.props;
---

<section class="word-slides" id="wordSlides">
  {
    words.map((item, i) => (
      <div class="word-slide" data-video={item.videoUrl || ''} data-index={i}>
        <video class="word-slide-video" muted loop playsinline preload="none" />
        <div class="word-slide-overlay" />
        <div class="word-slide-content">
          <span class="word-slide-text">{item.word}</span>
        </div>
      </div>
    ))
  }

  <!-- Progress -->
  <div class="word-progress" id="wordProgress">
    <div class="word-progress-track">
      <div class="word-progress-fill" id="wordProgressFill"></div>
    </div>
    <div class="word-progress-count">
      <span id="wordCurrent">01</span>
      <span class="word-progress-sep">/</span>
      <span>{String(words.length).padStart(2, '0')}</span>
    </div>
  </div>
</section>

<style>
  .word-slides {
    position: relative;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: #000;
  }

  /* When pinned by ScrollTrigger, ensure full coverage on iOS Safari */
  .word-slides.pin-spacer,
  .word-slides[style*="position: fixed"] {
    height: 100vh !important;
    height: 100dvh !important;
  }

  .word-slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    z-index: 0;
    transition: opacity 0.6s ease;
  }

  .word-slide.active {
    opacity: 1;
    z-index: 2;
  }

  /* Video — use -webkit-transform for iOS Safari */
  .word-slide-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.8s ease;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }

  .word-slide-video.loaded {
    opacity: 1;
  }

  /* Ken Burns — desktop only (causes rendering glitches on iOS) */
  @media (pointer: fine) {
    .word-slide.active .word-slide-video {
      animation: kenBurns 5s ease-out forwards;
    }
  }

  @keyframes kenBurns {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }

  .word-slide-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  .word-slide-content {
    position: relative;
    z-index: 2;
    overflow: hidden;
  }

  .word-slide-text {
    font-size: clamp(2rem, 12vw, 14rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: #fff;
    white-space: nowrap;
    display: block;
    -webkit-transform: translateZ(0);
  }

  /* Text transitions — use translate3d for iOS GPU acceleration */
  .word-slide .word-slide-text {
    -webkit-transform: translate3d(0, 100%, 0);
    transform: translate3d(0, 100%, 0);
    transition: -webkit-transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .word-slide.active .word-slide-text {
    -webkit-transform: translate3d(0, 0, 0);
    transform: translate3d(0, 0, 0);
  }

  .word-slide.exiting .word-slide-text {
    -webkit-transform: translate3d(0, -100%, 0);
    transform: translate3d(0, -100%, 0);
    transition: -webkit-transform 0.4s cubic-bezier(0.7, 0, 0.84, 0),
                transform 0.4s cubic-bezier(0.7, 0, 0.84, 0);
  }

  /* Flash cut between slides */
  .word-slides::after {
    content: "";
    position: absolute;
    inset: 0;
    background: #fff;
    z-index: 5;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.12s ease;
  }

  .word-slides.flash::after {
    opacity: 0.06;
  }

  /* Progress — faint */
  .word-progress {
    position: absolute;
    bottom: 1.5rem;
    right: 1rem;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .word-progress {
      bottom: 3rem;
      right: 2.5rem;
      gap: 1.5rem;
    }
  }

  .word-progress-track {
    width: 60px;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .word-progress-track {
      width: 120px;
    }
  }

  .word-progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: rgba(255, 255, 255, 0.3);
    transition: width 0.4s ease;
  }

  .word-progress-count {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.2);
    font-variant-numeric: tabular-nums;
  }

  .word-progress-sep {
    margin: 0 0.15em;
    opacity: 0.3;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section = document.getElementById('wordSlides');
  const slides = document.querySelectorAll('.word-slide');
  const totalSlides = slides.length;
  const progressFill = document.getElementById('wordProgressFill');
  const currentCount = document.getElementById('wordCurrent');
  let prevIndex = -1;

  if (section && totalSlides > 0) {
    const isMobile = window.matchMedia('(pointer: coarse)').matches || window.innerWidth < 768;
    const scrollPerSlide = window.innerHeight * (isMobile ? 0.55 : 0.6);
    const totalScroll = scrollPerSlide * totalSlides;

    // Set first slide active
    slides[0]?.classList.add('active');
    prevIndex = 0;

    // Eagerly preload first slide's video
    const firstVideo = slides[0]?.querySelector('.word-slide-video') as HTMLVideoElement;
    const firstSrc = slides[0]?.getAttribute('data-video');
    if (firstVideo && firstSrc) {
      firstVideo.src = firstSrc;
      firstVideo.preload = 'auto';
      firstVideo.load();
      firstVideo.addEventListener('canplay', () => {
        firstVideo.classList.add('loaded');
        firstVideo.play().catch(() => {});
      }, { once: true });
    }

    // Preload remaining videos when section is near
    // On mobile: load only next slide ahead (iOS limits simultaneous videos)
    // On desktop: load all at once
    let videosLoaded = false;
    const loadedSlides = new Set([0]);

    function loadSlideVideo(index: number) {
      if (index < 0 || index >= totalSlides || loadedSlides.has(index)) return;
      const slide = slides[index];
      const video = slide?.querySelector('.word-slide-video') as HTMLVideoElement;
      const src = slide?.getAttribute('data-video');
      if (video && src && !video.src) {
        video.src = src;
        video.preload = 'auto';
        video.load();
        video.addEventListener('canplay', () => video.classList.add('loaded'), { once: true });
        loadedSlides.add(index);
      }
    }

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !videosLoaded) {
            videosLoaded = true;
            if (isMobile) {
              // Load just the next slide ahead
              loadSlideVideo(1);
            } else {
              // Desktop: load all
              for (let i = 1; i < totalSlides; i++) loadSlideVideo(i);
            }
            sectionObserver.unobserve(section);
          }
        });
      },
      { rootMargin: '800px 0px' },
    );
    sectionObserver.observe(section);

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: () => `+=${totalScroll}`,
      pin: true,
      pinSpacing: true,
      scrub: 0.5,
      invalidateOnRefresh: true,
      onUpdate: (self) => {
        const progress = self.progress;
        const currentIndex = Math.min(
          Math.floor(progress * totalSlides),
          totalSlides - 1,
        );

        // Update progress bar
        const fillPercent = ((currentIndex + 1) / totalSlides) * 100;
        if (progressFill) progressFill.style.width = `${fillPercent}%`;
        if (currentCount) currentCount.textContent = String(currentIndex + 1).padStart(2, '0');

        if (currentIndex !== prevIndex) {
          // Flash cut
          section!.classList.add('flash');
          setTimeout(() => section!.classList.remove('flash'), 120);

          // Exit previous
          if (prevIndex >= 0 && prevIndex < totalSlides) {
            const prevSlide = slides[prevIndex];
            const prevVideo = prevSlide?.querySelector('.word-slide-video') as HTMLVideoElement;
            prevSlide?.classList.remove('active');
            prevSlide?.classList.add('exiting');
            prevVideo?.pause();
            setTimeout(() => prevSlide?.classList.remove('exiting'), 400);
          }

          // Pause ALL videos first (iOS only allows 1 playing)
          if (isMobile) {
            slides.forEach((s) => {
              const v = s.querySelector('.word-slide-video') as HTMLVideoElement;
              v?.pause();
            });
          }

          // Activate current
          const currentSlide = slides[currentIndex];
          const currentVideo = currentSlide?.querySelector('.word-slide-video') as HTMLVideoElement;
          currentSlide?.classList.remove('exiting');
          currentSlide?.classList.add('active');
          currentVideo?.play().catch(() => {});

          // Preload next slide on mobile
          if (isMobile) {
            loadSlideVideo(currentIndex + 1);
          }

          prevIndex = currentIndex;
        }
      },
    });

    // Explicitly play first video
    const initialVideo = slides[0]?.querySelector('.word-slide-video') as HTMLVideoElement;
    if (initialVideo?.src) {
      initialVideo.play().catch(() => {});
    }

    // Pause all videos when tab is hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        slides.forEach((s) => {
          const v = s.querySelector('.word-slide-video') as HTMLVideoElement;
          v?.pause();
        });
      } else if (prevIndex >= 0) {
        const activeVideo = slides[prevIndex]?.querySelector('.word-slide-video') as HTMLVideoElement;
        activeVideo?.play().catch(() => {});
      }
    });

    // iOS Safari: refresh ScrollTrigger when viewport resizes (toolbar show/hide)
    if (isMobile) {
      let resizeTimer: ReturnType<typeof setTimeout>;
      const visualViewport = window.visualViewport;
      if (visualViewport) {
        visualViewport.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => {
            ScrollTrigger.refresh();
          }, 100);
        });
      }
    }
  }
</script>
