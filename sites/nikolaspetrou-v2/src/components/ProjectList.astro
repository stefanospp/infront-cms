---
interface Project {
  title: string;
  slug?: string;
  category: string;
  year: number;
  video_url: string;
}

interface Props {
  projects: Project[];
  label?: string;
}

const { projects, label = '(Selected Works)' } = Astro.props;
---

<section id="works" class="py-16 px-4 md:py-32 md:px-8 min-h-screen">
  <div class="mb-16">
    <span class="text-label opacity-50">{label}</span>
  </div>

  <div class="projects-wrapper">
    <div class="project-list">
      {
        projects.map((project, i) => (
          <a
            href={project.slug ? `/works/${project.slug}` : '#'}
            class:list={[
              'project-item cursor-hover block no-underline text-inherit',
              i === projects.length - 1 && 'border-b border-black/10',
            ]}
            data-video={project.video_url}
          >
            <div class="project-video">
              <video muted loop playsinline preload="none" />
            </div>
            <div class="flex justify-between items-end relative z-10 w-full pb-4 md:pb-6 px-4 md:px-0">
              <div>
                <h3 class="project-title">{project.title}</h3>
                <div class="project-meta">
                  {project.category} / {project.year}
                </div>
              </div>
              <span class="text-label opacity-30 hidden md:inline">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<script>
  const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

  if (isTouchDevice) {
    document.querySelectorAll('.project-item').forEach((item) => {
      const videoEl = item.querySelector('.project-video video') as HTMLVideoElement;
      const videoSrc = item.getAttribute('data-video');
      let loaded = false;
      let ready = false;

      // Preload video when item is 300px from viewport
      const preloadObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !loaded && videoSrc) {
              videoEl.src = videoSrc;
              videoEl.preload = 'auto';
              videoEl.load();
              videoEl.addEventListener('canplay', () => { ready = true; }, { once: true });
              loaded = true;
              preloadObserver.unobserve(item);
            }
          });
        },
        { rootMargin: '300px 0px' },
      );
      preloadObserver.observe(item);

      // Play/pause when visible
      const playObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              item.classList.add('video-active');
              if (ready) {
                videoEl.play().catch(() => {});
              } else if (loaded) {
                videoEl.addEventListener('canplay', () => {
                  ready = true;
                  if (item.classList.contains('video-active')) {
                    videoEl.play().catch(() => {});
                  }
                }, { once: true });
              }
            } else {
              item.classList.remove('video-active');
              videoEl.pause();
            }
          });
        },
        { threshold: 0.3 },
      );
      playObserver.observe(item);
    });
  } else {
    // Desktop: preload + hover
    document.querySelectorAll('.project-item').forEach((item) => {
      const videoEl = item.querySelector('.project-video video') as HTMLVideoElement;
      const videoSrc = item.getAttribute('data-video');
      let videoTimer: ReturnType<typeof setTimeout> | null = null;
      let loaded = false;

      const preloadObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !loaded && videoSrc) {
              videoEl.src = videoSrc;
              videoEl.preload = 'auto';
              videoEl.load();
              loaded = true;
              preloadObserver.unobserve(item);
            }
          });
        },
        { rootMargin: '500px 0px' },
      );
      preloadObserver.observe(item);

      item.addEventListener('mouseenter', () => {
        document.getElementById('cursorRing')?.classList.add('hover');
        if (!loaded && videoSrc) {
          videoEl.src = videoSrc;
          videoEl.load();
          loaded = true;
        }
        videoTimer = setTimeout(() => {
          videoEl.play();
          item.classList.add('video-active');
        }, 400);
      });

      item.addEventListener('mouseleave', () => {
        document.getElementById('cursorRing')?.classList.remove('hover');
        if (videoTimer) clearTimeout(videoTimer);
        item.classList.remove('video-active');
        videoEl.pause();
      });
    });
  }
</script>
