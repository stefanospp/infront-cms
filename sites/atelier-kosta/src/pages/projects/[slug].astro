---
import "../../styles/global.css";
import FullWidth from '@agency/ui/layouts/FullWidth.astro';
import { getDirectusImageUrl } from '@agency/utils';
import { getProjects, getProjectBySlug } from '../../lib/directus';
import config from '../../../site.config';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((p: any) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const project = await getProjectBySlug(slug!);

if (!project) {
  return Astro.redirect('/404');
}

const p = project as any;

const title = p.title;
const description = p.description
  ? p.description.replace(/<[^>]+>/g, '').slice(0, 160)
  : `${p.title} — architecture project by Atelier Kosta in ${p.location ?? 'Cyprus'}.`;

const featuredImage = p.featured_image && config.cms?.url
  ? getDirectusImageUrl(config.cms.url, p.featured_image, { width: 1600, height: 900, fit: 'cover', format: 'webp' })
  : undefined;

const galleryImages = (p.gallery ?? []).map((id: string) =>
  config.cms?.url ? getDirectusImageUrl(config.cms.url, id, { width: 1200, height: 800, fit: 'cover', format: 'webp' }) : ''
).filter(Boolean);

const awards: string[] = p.awards ?? [];

function formatProjectType(type: string | null | undefined): string {
  if (!type) return '';
  return type.charAt(0).toUpperCase() + type.slice(1);
}
---

<FullWidth title={title} description={description} config={config}>
  {/* Full-width hero image */}
  {featuredImage && (
    <div class="relative h-[70vh] min-h-[500px] w-full">
      <img
        src={featuredImage}
        alt={p.title}
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-neutral-950/60 to-transparent" />
    </div>
  )}

  {/* Project content — editorial layout */}
  <section class="px-6 py-16 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-16 lg:grid-cols-[1fr_280px]">
        {/* Main content */}
        <div>
          {!featuredImage && (
            <div class="mb-8 h-px w-16 bg-primary-400" aria-hidden="true" />
          )}

          <h1 class="font-heading text-4xl font-light text-neutral-900 sm:text-5xl lg:text-6xl">
            {p.title}
          </h1>

          {p.description && (
            <div class="mt-10 max-w-prose text-lg font-light leading-relaxed text-neutral-600" set:html={p.description} />
          )}

          {/* Image gallery */}
          {galleryImages.length > 0 && (
            <div class="mt-16">
              <h2 class="mb-8 text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">Gallery</h2>
              <div class="grid gap-4 sm:grid-cols-2">
                {galleryImages.map((src: string, i: number) => (
                  <div class:list={[
                    'overflow-hidden',
                    i === 0 ? 'sm:col-span-2' : '',
                  ]}>
                    <img
                      src={src}
                      alt={`${p.title} — Photo ${i + 1}`}
                      class="w-full object-cover"
                      loading="lazy"
                    />
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* Metadata sidebar */}
        <aside class="lg:sticky lg:top-28 lg:self-start">
          <div class="border-l border-neutral-200 pl-8">
            <h2 class="sr-only">Project Details</h2>
            <dl class="space-y-6">
              {p.location && (
                <div>
                  <dt class="text-[10px] font-medium uppercase tracking-[0.3em] text-neutral-400">Location</dt>
                  <dd class="mt-1 text-sm text-neutral-800">{p.location}</dd>
                </div>
              )}
              {p.year && (
                <div>
                  <dt class="text-[10px] font-medium uppercase tracking-[0.3em] text-neutral-400">Year</dt>
                  <dd class="mt-1 text-sm text-neutral-800">{p.year}</dd>
                </div>
              )}
              {p.area_sqm && (
                <div>
                  <dt class="text-[10px] font-medium uppercase tracking-[0.3em] text-neutral-400">Area</dt>
                  <dd class="mt-1 text-sm text-neutral-800">{p.area_sqm} m²</dd>
                </div>
              )}
              {p.project_type && (
                <div>
                  <dt class="text-[10px] font-medium uppercase tracking-[0.3em] text-neutral-400">Type</dt>
                  <dd class="mt-1 text-sm text-neutral-800">{formatProjectType(p.project_type)}</dd>
                </div>
              )}
              {awards.length > 0 && (
                <div>
                  <dt class="text-[10px] font-medium uppercase tracking-[0.3em] text-neutral-400">Awards</dt>
                  <dd class="mt-2 space-y-1">
                    {awards.map((award) => (
                      <p class="text-sm text-neutral-800">{award}</p>
                    ))}
                  </dd>
                </div>
              )}
            </dl>

            <div class="mt-10">
              <a
                href="/contact"
                class="block w-full border border-neutral-900 px-6 py-3 text-center text-sm font-medium uppercase tracking-[0.15em] text-neutral-900 transition-all hover:bg-neutral-900 hover:text-white"
              >
                Discuss a project
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {/* Back to projects */}
  <section class="border-t border-neutral-200 px-6 py-12 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-6xl">
      <a href="/projects" class="inline-flex items-center gap-2 text-sm font-medium uppercase tracking-[0.15em] text-neutral-600 transition-colors hover:text-neutral-900">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 15.75L3 12m0 0l3.75-3.75M3 12h18" />
        </svg>
        All Projects
      </a>
    </div>
  </section>
</FullWidth>
