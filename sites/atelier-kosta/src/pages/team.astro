---
import "../styles/global.css";
import FullWidth from '@agency/ui/layouts/FullWidth.astro';
import Hero from '@agency/ui/components/Hero.astro';
import { getDirectusImageUrl } from '@agency/utils';
import { getTeamMembers } from '../lib/directus';
import config from '../../site.config';

const title = 'Team';
const description = 'Meet the architects and designers behind Atelier Kosta.';

const rawMembers = await getTeamMembers();
const members = rawMembers.map((m: any) => ({
  name: m.name,
  role: m.role,
  bio: m.bio ?? undefined,
  photo: m.photo && config.cms?.url
    ? getDirectusImageUrl(config.cms.url, m.photo, { width: 600, height: 750, fit: 'cover', format: 'webp' })
    : undefined,
  email: m.email ?? undefined,
}));
---

<FullWidth title={title} description={description} config={config}>
  <Hero
    variant="minimal"
    heading="Team"
    subheading="The people behind the work."
  />

  <section class="px-6 pb-24 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-6xl">
      {members.length > 0 ? (
        <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
          {members.map((member) => (
            <div>
              {member.photo ? (
                <div class="aspect-[4/5] overflow-hidden">
                  <img
                    src={member.photo}
                    alt={member.name}
                    class="h-full w-full object-cover grayscale transition-all duration-500 hover:grayscale-0"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="aspect-[4/5] bg-neutral-200" />
              )}
              <div class="mt-6">
                <h2 class="font-heading text-2xl font-light text-neutral-900">{member.name}</h2>
                {member.role && (
                  <p class="mt-1 text-sm font-medium uppercase tracking-[0.15em] text-neutral-500">{member.role}</p>
                )}
                {member.bio && (
                  <p class="mt-4 text-sm font-light leading-relaxed text-neutral-600">{member.bio}</p>
                )}
                {member.email && (
                  <a href={`mailto:${member.email}`} class="mt-3 inline-block text-sm text-neutral-500 transition-colors hover:text-neutral-900">
                    {member.email}
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="py-16 text-center">
          <h2 class="font-heading text-3xl font-light text-neutral-900">Team profiles coming soon</h2>
          <p class="mx-auto mt-4 max-w-md text-neutral-600">
            Get in touch to learn more about the studio.
          </p>
        </div>
      )}
    </div>
  </section>

  {/* Join */}
  <section class="border-t border-neutral-200 px-6 py-24 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-heading text-3xl font-light text-neutral-900">Join Atelier Kosta</h2>
      <p class="mx-auto mt-4 max-w-xl text-base font-light text-neutral-600">
        We're always interested in hearing from talented architects and designers.
        Send your portfolio to <a href="mailto:careers@atelierkosta.cy" class="text-neutral-900 underline underline-offset-4">careers@atelierkosta.cy</a>.
      </p>
    </div>
  </section>
</FullWidth>
