---
import "../styles/global.css";
import FullWidth from '@agency/ui/layouts/FullWidth.astro';
import Hero from '@agency/ui/components/Hero.astro';
import Section from '@agency/ui/components/Section.astro';
import { getDirectusImageUrl } from '@agency/utils';
import { getProjects, getTestimonials, getStats } from '../lib/directus';
import config from '../../site.config';

const title = config.seo.defaultTitle;
const description = config.seo.defaultDescription;

const rawProjects = await getProjects({ limit: 4 });
const projects = rawProjects.map((p: any) => ({
  title: p.title,
  slug: p.slug,
  location: p.location,
  year: p.year,
  projectType: p.project_type,
  image: p.featured_image && config.cms?.url
    ? getDirectusImageUrl(config.cms.url, p.featured_image, { width: 800, height: 600, fit: 'cover', format: 'webp' })
    : undefined,
}));

const rawTestimonials = await getTestimonials();
const testimonials = rawTestimonials.map((t: any) => ({
  quote: t.quote,
  author: t.author,
  role: t.role ?? undefined,
}));

const rawStats = await getStats();
const stats = rawStats.map((s: any) => ({
  value: s.value,
  label: s.label,
  suffix: s.suffix ?? undefined,
}));
---

<FullWidth title={title} description={description} config={config}>
  <Hero
    variant="fullscreen"
    heading="Atelier Kosta"
    subheading="Architecture rooted in place. Design shaped by light, material, and the rhythms of Mediterranean life."
    ctaText="View Projects"
    ctaHref="/projects"
    backgroundImage="/images/hero-home.jpg"
  />

  {/* Selected Projects */}
  <section class="px-6 py-24 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-7xl">
      <div class="mb-16 flex items-end justify-between">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">Portfolio</p>
          <h2 class="mt-3 font-heading text-4xl font-light text-neutral-900 sm:text-5xl">Selected Projects</h2>
        </div>
        <a href="/projects" class="hidden text-sm font-medium uppercase tracking-[0.15em] text-neutral-600 transition-colors hover:text-neutral-900 sm:inline-flex items-center gap-2">
          View All
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>

      {projects.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2">
          {projects.map((project, i) => (
            <a
              href={`/projects/${project.slug}`}
              class:list={[
                'group relative block overflow-hidden',
                i === 0 ? 'md:col-span-2 aspect-[21/9]' : 'aspect-[4/3]',
              ]}
            >
              {project.image ? (
                <img
                  src={project.image}
                  alt={project.title}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              ) : (
                <div class="h-full w-full bg-neutral-200" />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/70 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
              <div class="absolute bottom-0 left-0 right-0 translate-y-4 p-6 opacity-0 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100 sm:p-8">
                <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary-300">
                  {project.location} {project.year && `\u2014 ${project.year}`}
                </p>
                <h3 class="mt-2 font-heading text-2xl font-light text-white sm:text-3xl">{project.title}</h3>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="grid gap-6 md:grid-cols-2">
          <div class="md:col-span-2 aspect-[21/9] bg-neutral-200 flex items-center justify-center">
            <p class="text-neutral-500">Projects coming soon</p>
          </div>
        </div>
      )}
    </div>
  </section>

  {/* Stats */}
  {stats.length > 0 && (
    <section class="border-y border-neutral-200 px-6 py-20 sm:px-12 lg:px-20">
      <div class="mx-auto grid max-w-5xl grid-cols-2 gap-12 md:grid-cols-4">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="font-heading text-4xl font-light text-neutral-900 sm:text-5xl">
              {stat.value}{stat.suffix ?? ''}
            </p>
            <p class="mt-2 text-sm font-medium uppercase tracking-[0.15em] text-neutral-500">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {/* Philosophy */}
  <section class="px-6 py-24 sm:px-12 lg:px-20">
    <div class="mx-auto grid max-w-6xl gap-16 lg:grid-cols-2">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">Philosophy</p>
        <h2 class="mt-3 font-heading text-4xl font-light text-neutral-900 sm:text-5xl">Design with intention</h2>
      </div>
      <div class="flex flex-col justify-center">
        <p class="text-lg font-light leading-relaxed text-neutral-600">
          Every project begins with the site — its light, its contours, the way people move through it. We believe architecture should feel inevitable, as if the building has always belonged to its place.
        </p>
        <p class="mt-6 text-lg font-light leading-relaxed text-neutral-600">
          Our studio works across residential, commercial, and interior projects, bringing the same rigour and sensitivity to a private villa as to a public institution.
        </p>
        <a href="/studio" class="mt-8 inline-flex items-center gap-2 text-sm font-medium uppercase tracking-[0.15em] text-neutral-800 transition-colors hover:text-primary-600">
          About our studio
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  {/* Testimonials */}
  {testimonials.length > 0 && (
    <section class="bg-neutral-900 px-6 py-24 sm:px-12 lg:px-20">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">What our clients say</p>
        <blockquote class="mt-10">
          <p class="font-heading text-2xl font-light italic leading-relaxed text-white sm:text-3xl">
            "{testimonials[0]?.quote}"
          </p>
          <footer class="mt-8">
            <p class="text-sm font-medium text-neutral-300">{testimonials[0]?.author}</p>
            {testimonials[0]?.role && (
              <p class="mt-1 text-sm text-neutral-500">{testimonials[0].role}</p>
            )}
          </footer>
        </blockquote>
      </div>
    </section>
  )}

  {/* CTA */}
  <section class="px-6 py-24 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-heading text-4xl font-light text-neutral-900 sm:text-5xl">Start a conversation</h2>
      <p class="mx-auto mt-6 max-w-xl text-lg font-light text-neutral-600">
        Every great building begins with a conversation. Tell us about your vision, and let's explore what's possible together.
      </p>
      <div class="mt-10">
        <a
          href="/contact"
          class="inline-flex items-center gap-3 border border-neutral-900 px-8 py-4 text-sm font-medium uppercase tracking-[0.2em] text-neutral-900 transition-all hover:bg-neutral-900 hover:text-white"
        >
          Book Consultation
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</FullWidth>
