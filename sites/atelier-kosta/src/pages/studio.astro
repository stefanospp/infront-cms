---
import "../styles/global.css";
import FullWidth from '@agency/ui/layouts/FullWidth.astro';
import Hero from '@agency/ui/components/Hero.astro';
import config from '../../site.config';

const title = 'Studio';
const description = 'Learn about Atelier Kosta — our philosophy, approach, and awards in architecture and interior design.';

const awards = [
  { year: '2025', title: 'Cyprus Architecture Award', category: 'Residential — Villa Akamas' },
  { year: '2024', title: 'Mediterranean Design Prize', category: 'Interior Design — Engomi Lofts' },
  { year: '2023', title: 'European Property Award', category: 'Best Architecture Single Residence, Cyprus' },
  { year: '2021', title: 'ArchDaily Building of the Year — Shortlisted', category: 'Houses Category' },
];
---

<FullWidth title={title} description={description} config={config}>
  <Hero
    variant="minimal"
    heading="Studio"
    subheading="Architecture shaped by the Mediterranean — light, material, and a deep respect for context."
  />

  {/* Philosophy */}
  <section class="px-6 pb-24 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-16 lg:grid-cols-2">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">About</p>
          <h2 class="mt-3 font-heading text-4xl font-light text-neutral-900 sm:text-5xl">
            Architecture as a dialogue with place
          </h2>
        </div>
        <div class="space-y-6 text-lg font-light leading-relaxed text-neutral-600">
          <p>
            Founded in 2015 by Andreas Kosta, Atelier Kosta is a boutique architecture studio based in the old city of Nicosia. We design buildings that respond to the specific qualities of their site — the angle of the sun, the texture of the surrounding landscape, the culture and history embedded in the ground.
          </p>
          <p>
            Our work spans residential homes, commercial spaces, and interior transformations. Whether a courtyard house in the Troodos foothills or a gallery space in the capital, we approach every project with the same rigour: deep listening, material honesty, and an unwavering attention to how people inhabit space.
          </p>
          <p>
            We believe the best architecture doesn't shout. It breathes. It frames a view. It catches the evening light in a way that makes you pause.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Approach */}
  <section class="border-y border-neutral-200 px-6 py-24 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-6xl">
      <p class="text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">Approach</p>
      <h2 class="mt-3 mb-16 font-heading text-4xl font-light text-neutral-900">How we work</h2>
      <div class="grid gap-12 sm:grid-cols-3">
        <div>
          <p class="font-heading text-5xl font-light text-neutral-300">01</p>
          <h3 class="mt-4 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900">Listen</h3>
          <p class="mt-3 text-sm font-light leading-relaxed text-neutral-600">
            Every project starts with understanding — the site, the brief, the way you live. We spend time in the landscape before drawing a single line.
          </p>
        </div>
        <div>
          <p class="font-heading text-5xl font-light text-neutral-300">02</p>
          <h3 class="mt-4 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900">Design</h3>
          <p class="mt-3 text-sm font-light leading-relaxed text-neutral-600">
            We iterate through sketch, model, and material study. Our designs are tested against light, climate, and the practical demands of daily life.
          </p>
        </div>
        <div>
          <p class="font-heading text-5xl font-light text-neutral-300">03</p>
          <h3 class="mt-4 text-sm font-medium uppercase tracking-[0.15em] text-neutral-900">Build</h3>
          <p class="mt-3 text-sm font-light leading-relaxed text-neutral-600">
            We stay involved through construction, working closely with craftspeople and contractors to ensure the built reality matches the design intent.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Awards Timeline */}
  <section class="px-6 py-24 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-medium uppercase tracking-[0.3em] text-neutral-500">Recognition</p>
      <h2 class="mt-3 mb-16 font-heading text-4xl font-light text-neutral-900">Awards & Press</h2>
      <div class="space-y-0">
        {awards.map((award) => (
          <div class="flex gap-8 border-t border-neutral-200 py-6">
            <span class="w-16 shrink-0 font-heading text-2xl font-light text-neutral-400">{award.year}</span>
            <div>
              <p class="text-sm font-medium text-neutral-900">{award.title}</p>
              <p class="mt-1 text-sm text-neutral-500">{award.category}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-neutral-900 px-6 py-24 sm:px-12 lg:px-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-heading text-4xl font-light text-white sm:text-5xl">Let's build something together</h2>
      <p class="mx-auto mt-6 max-w-xl text-lg font-light text-neutral-400">
        We take on a limited number of projects each year to ensure every client receives our full attention.
      </p>
      <div class="mt-10">
        <a
          href="/contact"
          class="inline-flex items-center gap-3 border border-white/30 px-8 py-4 text-sm font-medium uppercase tracking-[0.2em] text-white transition-all hover:border-white hover:bg-white hover:text-neutral-900"
        >
          Book Consultation
        </a>
      </div>
    </div>
  </section>
</FullWidth>
