---
export interface Props {
  variant: 'centered' | 'split' | 'fullscreen' | 'minimal' | 'video';
  heading: string;
  subheading?: string;
  ctaText?: string;
  ctaHref?: string;
  backgroundImage?: string;
  backgroundVideo?: string;
  class?: string;
}

const {
  heading,
  subheading,
  ctaText,
  ctaHref,
  backgroundImage,
  class: className,
} = Astro.props;
---

<section
  class:list={[
    'relative flex min-h-screen items-end justify-start overflow-hidden',
    className,
  ]}
>
  {/* Background image with architectural grain overlay */}
  <div class="absolute inset-0 z-0">
    {backgroundImage ? (
      <img
        src={backgroundImage}
        alt=""
        class="h-full w-full object-cover"
        loading="eager"
      />
    ) : (
      <div class="h-full w-full bg-neutral-900" />
    )}
    {/* Cinematic gradient — dark at bottom for text, lighter at top */}
    <div class="absolute inset-0 bg-gradient-to-t from-neutral-950/90 via-neutral-900/40 to-transparent" />
  </div>

  {/* Content — bottom-left aligned, architectural editorial feel */}
  <div class="relative z-10 w-full px-6 pb-16 pt-48 sm:px-12 sm:pb-24 lg:px-20 lg:pb-32">
    <div class="max-w-4xl">
      {/* Thin accent line */}
      <div class="mb-8 h-px w-16 bg-primary-300" aria-hidden="true" />

      <h1 class="font-heading text-5xl font-light tracking-wide text-white sm:text-6xl lg:text-7xl xl:text-8xl">
        {heading}
      </h1>

      {subheading && (
        <p class="mt-6 max-w-xl text-base font-light leading-relaxed tracking-wide text-neutral-300 sm:text-lg">
          {subheading}
        </p>
      )}

      {ctaText && ctaHref && (
        <div class="mt-10">
          <a
            href={ctaHref}
            class="inline-flex items-center gap-3 border border-white/30 bg-transparent px-8 py-4 text-sm font-medium uppercase tracking-[0.2em] text-white transition-all hover:border-white hover:bg-white hover:text-neutral-900"
          >
            {ctaText}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>
      )}
    </div>
  </div>

  {/* Scroll indicator — bottom center */}
  <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2" aria-hidden="true">
    <div class="animate-scroll-hint flex flex-col items-center gap-2">
      <span class="text-[10px] font-medium uppercase tracking-[0.3em] text-white/50">Scroll</span>
      <svg class="h-5 w-5 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
      </svg>
    </div>
  </div>
</section>
