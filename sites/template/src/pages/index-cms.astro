---
import "../styles/global.css";
import FullWidth from '@agency/ui/layouts/FullWidth.astro';
import Hero from '@agency/ui/components/Hero.astro';
import Section from '@agency/ui/components/Section.astro';
import CardGrid from '@agency/ui/components/CardGrid.astro';
import Testimonials from '@agency/ui/components/Testimonials.astro';
import StatsCounter from '@agency/ui/components/StatsCounter.astro';
import LogoCloud from '@agency/ui/components/LogoCloud.astro';
import CTA from '@agency/ui/components/CTA.astro';
import { getDirectusImageUrl } from '@agency/utils';
import { getServices, getTestimonials, getStats, getClients } from '../lib/directus';
import config from '../../site.config';

const title = config.seo.defaultTitle;
const description = config.seo.defaultDescription;

const rawServices = await getServices();
const services = rawServices.map((s: any) => ({
  title: s.title,
  description: s.description ?? '',
  image: s.image && config.cms?.url
    ? getDirectusImageUrl(config.cms.url, s.image, { width: 600, format: 'webp' })
    : undefined,
  href: s.href ?? '/contact',
}));

const rawTestimonials = await getTestimonials();
const testimonials = rawTestimonials.map((t: any) => ({
  quote: t.quote,
  author: t.author,
  role: t.role ?? undefined,
  image: t.image && config.cms?.url
    ? getDirectusImageUrl(config.cms.url, t.image, { width: 100, height: 100, fit: 'cover', format: 'webp' })
    : undefined,
}));

const rawStats = await getStats();
const stats = rawStats.map((s: any) => ({
  value: s.value,
  label: s.label,
  prefix: s.prefix ?? undefined,
  suffix: s.suffix ?? undefined,
}));

const rawClients = await getClients();
const clients = rawClients.map((c: any) => ({
  name: c.name,
  image: c.logo && config.cms?.url
    ? getDirectusImageUrl(config.cms.url, c.logo, { height: 60, format: 'webp' })
    : '',
  href: c.href ?? undefined,
}));
---

<FullWidth title={title} description={description} config={config}>
  <Hero
    variant={config.theme.heroDefault}
    heading={config.name}
    subheading={config.tagline}
    ctaText={config.nav.cta?.label ?? 'Get in Touch'}
    ctaHref={config.nav.cta?.href ?? '/contact'}
  />

  {services.length > 0 && (
    <Section heading="Our Services" subheading="What we offer" id="services">
      <CardGrid variant="three-column" cards={services} />
    </Section>
  )}

  {stats.length > 0 && (
    <Section background="primary">
      <StatsCounter variant="inline" stats={stats} />
    </Section>
  )}

  {testimonials.length > 0 && (
    <Section background="light">
      <Testimonials testimonials={testimonials} />
    </Section>
  )}

  {clients.length > 0 && (
    <Section>
      <LogoCloud heading="Trusted by" logos={clients} />
    </Section>
  )}

  <CTA
    heading="Ready to get started?"
    description="Let's talk about your project and see how we can help."
    buttonText="Contact Us"
    buttonHref="/contact"
  />
</FullWidth>
