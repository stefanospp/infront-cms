---
import SingleColumn from '@agency/ui/layouts/SingleColumn.astro';
import config from '../../site.config';
---

<SingleColumn title="Page Not Found" description="The page you're looking for doesn't exist." config={config}>
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="text-6xl font-heading font-bold text-neutral-900 mb-4">404</h1>
    <p class="text-xl text-neutral-600 mb-8">
      Sorry, the page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center rounded-lg bg-primary-600 px-6 py-3 text-white font-semibold hover:bg-primary-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-600 focus:ring-offset-2"
    >
      Go back home
    </a>
  </div>
</SingleColumn>
