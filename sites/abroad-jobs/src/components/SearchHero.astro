---
import { INDUSTRIES } from '../lib/validation';

export interface Props {
  query?: string;
  country?: string;
  industry?: string;
  jobCount?: number;
}

const { query = '', country = '', industry = '', jobCount = 0 } = Astro.props;

const industries = INDUSTRIES;
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-600 via-primary-700 to-primary-900 px-4 py-14 sm:px-6 sm:py-20">
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.08)_0%,transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_80%,rgba(255,255,255,0.05)_0%,transparent_50%)]"></div>

  <div class="relative mx-auto max-w-3xl text-center">
    <h1 class="text-3xl font-bold tracking-tight text-white sm:text-5xl">
      Your next career move<br class="hidden sm:block" /> starts abroad
    </h1>
    <p class="mt-4 text-base text-primary-200 sm:text-lg">
      {jobCount > 0 ? `${jobCount} jobs with visa sponsorship and relocation support` : 'Jobs with visa sponsorship and relocation support'}
    </p>

    <!-- Search form -->
    <form method="get" action="/" class="mt-8">
      <div class="flex flex-col gap-3 sm:flex-row">
        <div class="relative flex-1">
          <svg
            class="pointer-events-none absolute left-3.5 top-1/2 h-5 w-5 -translate-y-1/2 text-neutral-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            type="search"
            name="q"
            value={query}
            placeholder="Job title, company, or keyword..."
            class="w-full rounded-xl border-0 bg-white py-3.5 pl-11 pr-4 text-sm text-neutral-900 shadow-lg placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-white/30"
          />
        </div>
        <button
          type="submit"
          class="rounded-xl bg-accent-500 px-6 py-3.5 text-sm font-semibold text-white shadow-lg hover:bg-accent-600 active:bg-accent-700 transition-colors sm:w-auto"
        >
          Search jobs
        </button>
      </div>

      <!-- Filters -->
      <div class="mt-3 flex flex-col gap-3 sm:flex-row">
        <div class="flex-1">
          <label for="country-filter" class="sr-only">Country</label>
          <input
            type="text"
            id="country-filter"
            name="country"
            value={country}
            placeholder="Filter by country..."
            list="country-suggestions"
            class="w-full rounded-xl border-0 bg-white/15 px-4 py-2.5 text-sm text-white placeholder:text-primary-200 backdrop-blur-sm focus:bg-white/25 focus:outline-none focus:ring-2 focus:ring-white/20 transition-colors"
          />
          <datalist id="country-suggestions">
            <option value="Germany" />
            <option value="Netherlands" />
            <option value="Portugal" />
            <option value="Spain" />
            <option value="Switzerland" />
            <option value="Sweden" />
            <option value="Denmark" />
            <option value="Norway" />
            <option value="Estonia" />
            <option value="United Arab Emirates" />
            <option value="Qatar" />
            <option value="Japan" />
            <option value="Singapore" />
            <option value="Australia" />
            <option value="Maldives" />
          </datalist>
        </div>
        <div class="flex-1">
          <label for="industry-filter" class="sr-only">Industry</label>
          <select
            id="industry-filter"
            name="industry"
            class="w-full rounded-xl border-0 bg-white/15 px-4 py-2.5 text-sm text-white backdrop-blur-sm focus:bg-white/25 focus:outline-none focus:ring-2 focus:ring-white/20 transition-colors [&>option]:bg-white [&>option]:text-neutral-900"
          >
            <option value="" class="bg-white text-neutral-900">All industries</option>
            {industries.map((ind) => (
              <option value={ind} selected={industry === ind} class="bg-white text-neutral-900">{ind}</option>
            ))}
          </select>
        </div>
      </div>
    </form>
  </div>
</section>
