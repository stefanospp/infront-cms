---
import type { INDUSTRIES } from '../lib/validation';

export interface Props {
  query?: string;
  country?: string;
  industry?: string;
  jobCount?: number;
}

const { query = '', country = '', industry = '', jobCount = 0 } = Astro.props;

const industries: string[] = [
  'Hospitality & Tourism',
  'Renewable Energy',
  'Digital Marketing',
  'Finance & Fintech',
  'Healthcare',
  'Education',
  'Construction',
  'Technology',
  'Other',
];
---

<section class="border-b border-neutral-200 bg-neutral-50 px-4 py-12 sm:px-6 sm:py-16">
  <div class="mx-auto max-w-3xl text-center">
    <h1 class="text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
      Find jobs abroad with relocation support
    </h1>
    <p class="mt-3 text-lg text-neutral-500">
      {jobCount > 0 ? `${jobCount} open positions worldwide` : 'Browse open positions worldwide'}
    </p>

    <!-- Search form -->
    <form method="get" action="/" class="mt-8">
      <div class="flex flex-col gap-3 sm:flex-row">
        <div class="relative flex-1">
          <svg
            class="pointer-events-none absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 text-neutral-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input
            type="search"
            name="q"
            value={query}
            placeholder="Job title, company, or keyword..."
            class="w-full rounded-lg border border-neutral-300 bg-white py-3 pl-10 pr-4 text-sm text-neutral-900 placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
          />
        </div>
        <button
          type="submit"
          class="rounded-lg bg-primary-700 px-6 py-3 text-sm font-medium text-white hover:bg-primary-800 transition-colors sm:w-auto"
        >
          Search
        </button>
      </div>

      <!-- Filters -->
      <div class="mt-3 flex flex-col gap-3 sm:flex-row">
        <div class="flex-1">
          <label for="country-filter" class="sr-only">Country</label>
          <input
            type="text"
            id="country-filter"
            name="country"
            value={country}
            placeholder="Country..."
            list="country-suggestions"
            class="w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 text-sm text-neutral-700 placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
          />
          <datalist id="country-suggestions">
            <option value="Germany" />
            <option value="Netherlands" />
            <option value="Portugal" />
            <option value="Spain" />
            <option value="Switzerland" />
            <option value="Sweden" />
            <option value="Denmark" />
            <option value="Norway" />
            <option value="Estonia" />
            <option value="United Arab Emirates" />
            <option value="Qatar" />
            <option value="Japan" />
            <option value="Singapore" />
            <option value="Australia" />
            <option value="Maldives" />
          </datalist>
        </div>
        <div class="flex-1">
          <label for="industry-filter" class="sr-only">Industry</label>
          <select
            id="industry-filter"
            name="industry"
            class="w-full rounded-lg border border-neutral-200 bg-white px-3 py-2 text-sm text-neutral-700 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
          >
            <option value="">All industries</option>
            {industries.map((ind) => (
              <option value={ind} selected={industry === ind}>{ind}</option>
            ))}
          </select>
        </div>
      </div>
    </form>
  </div>
</section>
