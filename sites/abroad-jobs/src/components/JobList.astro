---
import type { Job } from '../lib/schema';
import JobCard from './JobCard.astro';
import LoadMore from '../islands/LoadMore';

export interface Props {
  jobs: Job[];
  hasMore?: boolean;
  query?: string;
  country?: string;
  industry?: string;
  page?: number;
}

const { jobs, hasMore = false, query = '', country = '', industry = '', page = 1 } = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
  {jobs.length === 0 ? (
    <div class="py-16 text-center">
      <p class="text-lg text-neutral-400">No jobs match your search.</p>
      <a href="/" class="mt-3 inline-block text-sm text-primary-600 hover:text-primary-700 transition-colors">
        Clear filters
      </a>
    </div>
  ) : (
    <div class="space-y-4" id="job-list">
      {jobs.map((job) => (
        <JobCard job={job} />
      ))}
    </div>
  )}

  {hasMore && (
    <LoadMore
      client:visible
      query={query}
      country={country}
      industry={industry}
      initialPage={page}
    />
  )}
</section>
