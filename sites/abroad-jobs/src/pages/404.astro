---
import '../styles/global.css';
import SiteLayout from '../layouts/SiteLayout.astro';
import config from '../../site.config';
---

<SiteLayout title="Page Not Found" description="The page you're looking for doesn't exist." config={config}>
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <p class="text-7xl font-bold text-primary-600">404</p>
    <h1 class="mt-4 text-3xl font-bold text-neutral-900">Page not found</h1>
    <p class="mt-3 text-lg text-neutral-600 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="mt-8 flex gap-4">
      <a
        href="/"
        class="rounded-lg bg-primary-600 px-6 py-3 text-sm font-semibold text-white hover:bg-primary-700 transition-colors"
      >
        Browse jobs
      </a>
      <a
        href="/post"
        class="rounded-lg border border-neutral-300 bg-white px-6 py-3 text-sm font-semibold text-neutral-700 hover:bg-neutral-50 transition-colors"
      >
        Post a job
      </a>
    </div>
  </div>
</SiteLayout>
