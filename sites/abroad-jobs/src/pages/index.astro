---
import '../styles/global.css';
import SiteLayout from '../layouts/SiteLayout.astro';
import SearchHero from '../components/SearchHero.astro';
import JobList from '../components/JobList.astro';
import config from '../../site.config';
import { getDb, mapRawJob } from '../lib/db';
import { jobs } from '../lib/schema';
import { eq, desc, and, like, gt, sql } from 'drizzle-orm';
import { searchParamsSchema } from '../lib/validation';
import { env } from 'cloudflare:workers';

export const prerender = false;

// Cache SSR response for 60 seconds with stale-while-revalidate
Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=60, stale-while-revalidate=300');

const params = searchParamsSchema.safeParse({
  q: Astro.url.searchParams.get('q') || undefined,
  country: Astro.url.searchParams.get('country') || undefined,
  industry: Astro.url.searchParams.get('industry') || undefined,
  page: Astro.url.searchParams.get('page') || undefined,
});

const { q = '', country = '', industry = '', page = 1, limit = 50 } = params.success ? params.data : { q: '', country: '', industry: '', page: 1, limit: 50 };

const db = getDb(env.DB);
const now = Math.floor(Date.now() / 1000);

let results: (typeof jobs.$inferSelect)[];
let total: number;

if (q) {
  // Full-text search via FTS5
  // Sanitize FTS5 query: strip quotes and operators, wrap each term in double quotes for literal matching
  const ftsQuery = q
    .replace(/['"]/g, '')
    .replace(/\b(AND|OR|NOT|NEAR)\b/gi, '')
    .replace(/[*^(){}:]/g, '')
    .trim()
    .split(/\s+/)
    .filter(Boolean)
    .map((term) => `"${term}"`)
    .join(' ');

  const whereClause = `
    jobs_fts MATCH ?
    AND j.is_live = 1
    AND (j.expires_at IS NULL OR j.expires_at > ?)
    ${country ? 'AND j.country = ?' : ''}
    ${industry ? 'AND j.industry = ?' : ''}
  `;

  const bindParams: unknown[] = [ftsQuery, now];
  if (country) bindParams.push(country);
  if (industry) bindParams.push(industry);

  const dataQuery = `
    SELECT j.* FROM jobs j
    JOIN jobs_fts f ON j.id = f.rowid
    WHERE ${whereClause}
    ORDER BY rank
    LIMIT ? OFFSET ?
  `;
  const countQuery = `
    SELECT COUNT(*) as cnt FROM jobs j
    JOIN jobs_fts f ON j.id = f.rowid
    WHERE ${whereClause}
  `;

  // Use D1 batch API to run both queries in a single round-trip
  const [dataResult, countResult] = await env.DB.batch([
    env.DB.prepare(dataQuery).bind(...bindParams, limit + 1, (page - 1) * limit),
    env.DB.prepare(countQuery).bind(...bindParams),
  ]);
  results = (dataResult.results ?? []).map((r) => mapRawJob(r as Record<string, unknown>));
  total = (countResult.results?.[0] as Record<string, unknown> | undefined)?.cnt as number ?? 0;
} else {
  // Standard filtered query — run data + count in parallel
  const conditions = [
    eq(jobs.isLive, 1),
    sql`(${jobs.expiresAt} IS NULL OR ${jobs.expiresAt} > ${now})`,
  ];
  if (country) conditions.push(eq(jobs.country, country));
  if (industry) conditions.push(eq(jobs.industry, industry));

  const [dataResults, countResult] = await Promise.all([
    db
      .select()
      .from(jobs)
      .where(and(...conditions))
      .orderBy(desc(jobs.createdAt))
      .limit(limit + 1)
      .offset((page - 1) * limit),
    db
      .select({ count: sql<number>`COUNT(*)` })
      .from(jobs)
      .where(and(...conditions)),
  ]);
  results = dataResults;
  total = countResult[0]?.count ?? 0;
}

const hasMore = results.length > limit;
const displayJobs = hasMore ? results.slice(0, limit) : results;
---

<SiteLayout
  title={config.seo.defaultTitle}
  description={config.seo.defaultDescription}
  config={config}
>
  <SearchHero
    query={q}
    country={country}
    industry={industry}
    jobCount={total}
  />
  <JobList
    jobs={displayJobs}
    hasMore={hasMore}
    query={q}
    country={country}
    industry={industry}
    page={page}
  />
</SiteLayout>
