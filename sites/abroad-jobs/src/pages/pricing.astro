---
import '../styles/global.css';
import SiteLayout from '../layouts/SiteLayout.astro';
import config from '../../site.config';
import { formatTitle } from '@agency/utils/seo';
---

<SiteLayout
  title={formatTitle('Pricing', config.seo.titleTemplate)}
  description="Post a job on AbroadJobs.eu for EUR 89 per listing. No subscriptions, no hidden fees."
  config={config}
>
  <section class="mx-auto max-w-2xl px-4 py-12 sm:px-6 sm:py-16">
    <h1 class="text-2xl font-bold text-neutral-900 sm:text-3xl">Pricing</h1>
    <p class="mt-3 text-neutral-500">Simple, transparent pricing. No subscriptions.</p>

    <div class="mt-8 rounded-lg border border-neutral-200 bg-white p-6 sm:p-8">
      <div class="flex items-baseline gap-2">
        <span class="text-4xl font-bold text-neutral-900">&euro;89</span>
        <span class="text-neutral-500">per job listing</span>
      </div>

      <ul class="mt-6 space-y-3 text-sm text-neutral-600">
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Live for 30 days
        </li>
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Appears in search results immediately
        </li>
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Dedicated job page with SEO
        </li>
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Post multiple jobs at once — same price per listing
        </li>
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          No account required
        </li>
      </ul>

      <a
        href="/post"
        class="mt-8 inline-flex items-center rounded-lg bg-primary-700 px-6 py-3 text-sm font-semibold text-white hover:bg-primary-800 transition-colors"
      >
        Post a job
      </a>
    </div>
  </section>
</SiteLayout>
