---
export interface TestimonialItem {
  quote: string;
  author: string;
  role?: string;
  image?: string;
}

export interface Props {
  variant?: 'default' | 'carousel' | 'featured';
  testimonials: TestimonialItem[];
  class?: string;
}

const { variant = 'default', testimonials, class: className } = Astro.props;
---

{/* BrightMind-style testimonial cards */}
<div class:list={['relative', className]}>
  {/* Horizontal scrolling carousel */}
  <div class="flex gap-6 overflow-x-auto pb-4 scrollbar-hide snap-x snap-mandatory">
    {testimonials.map((t) => (
      <figure class="min-w-[320px] max-w-[400px] flex-shrink-0 snap-start rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm">
        {/* Quote icon */}
        <svg class="mb-4 h-8 w-8 text-primary-300" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
          <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
        </svg>

        <blockquote class="text-base leading-relaxed text-neutral-700">
          {t.quote}
        </blockquote>

        <figcaption class="mt-6 flex items-center gap-4">
          {/* Avatar */}
          {t.image ? (
            <img src={t.image} alt={t.author} class="h-12 w-12 flex-shrink-0 rounded-full object-cover" />
          ) : (
            <div class="h-12 w-12 flex-shrink-0 rounded-full bg-gradient-to-br from-primary-200 to-primary-100" />
          )}
          <div>
            <p class="text-sm font-bold text-[--color-dark]">{t.author}</p>
            {t.role && (
              <p class="text-sm text-neutral-500">{t.role}</p>
            )}
          </div>
        </figcaption>
      </figure>
    ))}
  </div>

  {/* Navigation arrows */}
  <div class="mt-6 flex justify-center gap-3">
    <button type="button" class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 text-neutral-600 transition-colors hover:border-primary-500 hover:text-primary-500" aria-label="Previous testimonial">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    </button>
    <button type="button" class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 text-neutral-600 transition-colors hover:border-primary-500 hover:text-primary-500" aria-label="Next testimonial">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </button>
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
