---
export interface ProgramCard {
  title: string;
  ageRange: string;
  description: string;
  features: string[];
  icon: string;
  href: string;
  bgColor?: string;
}

export interface Props {
  programs: ProgramCard[];
  class?: string;
}

const { programs, class: className } = Astro.props;

const iconMap: Record<string, string> = {
  'young-learners': 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25',
  'teenagers': 'M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5',
  'adults': 'M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z',
  'exam-prep': 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z',
};

const pastelColors = [
  'var(--color-purple-light)',
  'var(--color-coral-light)',
  'var(--color-mint-light)',
  'var(--color-yellow-light)',
];
---

{/* BrightMind-style horizontal scrolling category cards */}
<div class:list={['relative', className]}>
  <div class="flex gap-5 overflow-x-auto pb-4 scrollbar-hide sm:grid sm:grid-cols-2 sm:overflow-visible lg:grid-cols-4">
    {programs.map((program, i) => (
      <a
        href={program.href}
        class="group flex min-w-[260px] flex-col items-center rounded-2xl p-8 text-center transition-transform hover:scale-[1.02] sm:min-w-0"
        style={`background-color: ${program.bgColor || pastelColors[i % pastelColors.length]}`}
      >
        {/* Icon */}
        <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-white/60">
          <svg class="h-7 w-7 text-[--color-dark]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[program.icon] || iconMap['young-learners']} />
          </svg>
        </div>

        {/* Title */}
        <h3 class="text-lg font-bold text-[--color-dark]">
          {program.title}
        </h3>

        {/* Age range / subtitle */}
        <p class="mt-1 text-sm font-medium text-neutral-600">
          {program.ageRange}
        </p>
      </a>
    ))}
  </div>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
