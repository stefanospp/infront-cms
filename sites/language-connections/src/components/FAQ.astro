---
export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  variant?: 'default' | 'two-column';
  items: FAQItem[];
  class?: string;
}

const { variant = 'default', items, class: className } = Astro.props;
---

{/* BrightMind-style FAQ accordion — clean, generous whitespace */}
<div class:list={['mx-auto max-w-3xl', className]}>
  <div class="divide-y divide-neutral-200">
    {items.map((item) => (
      <details class="group">
        <summary class="flex cursor-pointer list-none items-center justify-between py-6 text-left [&::-webkit-details-marker]:hidden">
          <h3 class="pr-4 text-lg font-bold text-[--color-dark]">
            {item.question}
          </h3>
          <span class="ml-4 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full border border-neutral-300 text-neutral-500 transition-all duration-200 group-open:rotate-45 group-open:border-primary-500 group-open:text-primary-500" aria-hidden="true">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </span>
        </summary>
        <div class="pb-6 pr-12">
          <p class="text-base leading-relaxed text-neutral-600">
            {item.answer}
          </p>
        </div>
      </details>
    ))}
  </div>
</div>
