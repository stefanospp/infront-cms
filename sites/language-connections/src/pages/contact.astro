---
import "../styles/global.css";
import BaseLayout from '@agency/ui/layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import ContactForm from '@agency/ui/islands/ContactForm';
import config from '../../site.config';

const title = 'Contact Us';
const description = `Get in touch with ${config.name}. Book a free trial lesson or ask about our programs.`;
---

<BaseLayout title={title} description={description} config={config}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  </Fragment>

  <Nav config={config} />

  <main id="main-content">
    <Hero
      variant="minimal"
      heading="Get in Touch"
      headingHighlight="Touch"
      subheading="Book a free trial lesson, ask about our programs, or enquire about fees. Serving families from Paralimni, Deryneia, Sotira, Protaras, and the wider Famagusta district."
    />

    {/* Contact form + info */}
    <div class="section-spacing">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-2">
          {/* Form */}
          <div>
            <h2 class="mb-2 text-2xl font-bold">Send us a <span class="text-primary-500">Message</span></h2>
            <p class="mb-8 text-neutral-600">Fill out the form and we'll get back to you within 24 hours.</p>
            <ContactForm client:visible />
          </div>

          {/* Contact info cards */}
          <div class="space-y-6">
            {/* Email */}
            <div class="flex items-start gap-4 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-[--color-purple-light]">
                <svg class="h-6 w-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold">Email us</h3>
                <p class="mt-1 text-sm text-neutral-500">Email us for enquiries</p>
                <a href={`mailto:${config.contact.email}`} class="mt-2 block text-sm font-semibold text-primary-500 hover:underline">{config.contact.email}</a>
              </div>
            </div>

            {/* Location */}
            <div class="flex items-start gap-4 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-[--color-coral-light]">
                <svg class="h-6 w-6 text-[--color-coral]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold">Visit us</h3>
                <p class="mt-1 text-sm text-neutral-500">Come say hello</p>
                <p class="mt-2 text-sm text-neutral-700">
                  {config.contact.address?.street}<br />
                  {config.contact.address?.city}, {config.contact.address?.postcode}
                </p>
              </div>
            </div>

            {/* Phone */}
            <div class="flex items-start gap-4 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-[--color-mint-light]">
                <svg class="h-6 w-6 text-[--color-mint]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold">Call us</h3>
                <p class="mt-1 text-sm text-neutral-500">Mon–Fri, 14:00–20:00</p>
                <a href={`tel:${config.contact.phone}`} class="mt-2 block text-sm font-semibold text-primary-500 hover:underline">{config.contact.phone}</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <CTA
      heading="Take the First Step – Start Learning Today!"
      buttonText="View Programs"
      buttonHref="/programs"
    />
  </main>

  <Footer config={config} />
</BaseLayout>
