---
import "../styles/global.css";
import BaseLayout from '@agency/ui/layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import config from '../../site.config';

const title = 'About Us';
const description = 'Learn about Language Connections, Annie Petrou, and our approach to teaching English in Paralimni.';
---

<BaseLayout title={title} description={description} config={config}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  </Fragment>

  <Nav config={config} />

  <main id="main-content">
    <Hero
      variant="minimal"
      heading="About Language Connections"
      headingHighlight="Language Connections"
      subheading="Founded in 2009 by Annie Petrou, Language Connections has been the trusted choice for English education in Paralimni, Deryneia, Sotira, and the wider Famagusta district for over 15 years."
    />

    {/* Stats row */}
    <div class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
        {[
          { value: '500+', label: 'Students Taught' },
          { value: '15+', label: 'Years Experience' },
          { value: '93%', label: 'Exam Pass Rate' },
          { value: '6–10', label: 'Students Per Class' },
        ].map((stat) => (
          <div class="text-center">
            <p class="text-4xl font-bold text-primary-500">{stat.value}</p>
            <p class="mt-2 text-sm font-medium text-neutral-500">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Core values */}
    <div class="section-spacing bg-neutral-50">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mb-12 text-center">
          <h2>Why Parents <span class="text-primary-500">Trust Us</span></h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { icon: '👥', title: 'Small Classes', desc: 'Maximum 6–10 students per group. Your child is never just a number.' },
            { icon: '🎯', title: 'Exam-Focused Results', desc: '93% Cambridge pass rate. We prepare students to succeed.' },
            { icon: '💬', title: 'Communicative Method', desc: 'Students learn to actually speak English, not just memorise grammar rules.' },
            { icon: '📋', title: 'Continuous Feedback', desc: 'Regular progress reports and parent updates every term.' },
          ].map((item) => (
            <div class="rounded-2xl bg-white p-6 text-center shadow-sm">
              <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-[--color-purple-light] text-2xl">
                {item.icon}
              </div>
              <h3 class="text-lg font-bold">{item.title}</h3>
              <p class="mt-2 text-sm text-neutral-600">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    {/* Story section */}
    <div class="section-spacing">
      <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-16 lg:px-8">
        <div>
          <h2>Our Story in <span class="text-primary-500">Paralimni</span></h2>
          <p class="mt-5 text-neutral-600">
            Language Connections was founded in 2009 when Annie Petrou saw that families in the Famagusta district needed more than what public school English could offer. What started as a small group of students has grown into a thriving institute serving over 500 graduates from Paralimni, Deryneia, Sotira, and Protaras.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              'Cambridge exam preparation from Starters to CPE',
              'Afternoon and evening classes to fit school and work schedules',
              'Small groups of 6–10 for real speaking practice',
              'Supplementing school English for stronger exam results',
            ].map((item) => (
              <li class="flex items-start gap-3 text-neutral-700">
                <svg class="mt-1 h-5 w-5 flex-shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="/programs" class="btn-primary">Explore Programs</a>
          </div>
        </div>
        <div class="overflow-hidden rounded-2xl">
          <img src="/images/about-teaching.jpg" alt="Teacher with students in classroom" class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>

    {/* Team — Annie */}
    <div class="section-spacing bg-neutral-50">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mb-12 text-center">
          <h2>Meet Your <span class="text-primary-500">Instructor</span></h2>
        </div>
        <div class="mx-auto max-w-md text-center">
          <img src="/images/annie-placeholder.jpg" alt="Annie Petrou" class="mx-auto mb-6 h-32 w-32 rounded-full object-cover shadow-md" />
          <h3 class="text-xl font-bold">Annie Petrou</h3>
          <p class="mt-1 text-sm font-medium text-primary-500">Founder & Head Instructor</p>
          {/* Qualification badges */}
          <div class="mt-4 flex flex-wrap justify-center gap-2">
            {['BA English Literature', 'Cambridge CELTA', 'Cambridge Speaking Examiner', 'Teaching in Paralimni since 2009'].map((q) => (
              <span class="rounded-full bg-[--color-purple-light] px-3 py-1 text-xs font-semibold text-primary-700">{q}</span>
            ))}
          </div>
          <p class="mt-4 text-neutral-600">
            Annie brings both academic rigour and practical teaching expertise to every lesson. She is passionate about helping students achieve their language goals in a supportive, encouraging environment.
          </p>
        </div>
      </div>
    </div>

    {/* FAQ */}
    <div class="section-spacing">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mb-12 text-center">
          <h2>Frequently Asked <span class="text-primary-500">Questions</span></h2>
        </div>
        <FAQ
          items={[
            { question: 'What is the communicative approach?', answer: 'The communicative approach focuses on developing real-world communication skills. Students practise using English in meaningful contexts — discussions, role-plays, and practical tasks.' },
            { question: 'What qualifications does Annie have?', answer: 'Annie holds a degree in English Language and Literature, a Cambridge CELTA, and has served as a Cambridge Speaking Examiner.' },
            { question: 'How do you track student progress?', answer: 'We use regular progress assessments, mock exams, and detailed feedback reports. Parents of younger students receive termly progress updates.' },
            { question: 'Do you offer individual lessons?', answer: 'Yes, we offer both group classes and one-to-one private lessons tailored to specific needs such as interview preparation or intensive exam revision.' },
          ]}
        />
      </div>
    </div>

    <CTA
      heading="Let's Find the Right Program for You"
      description="Get in touch and we'll help you choose the best path forward."
      buttonText="Get in Touch"
      buttonHref="/contact"
    />
  </main>

  <Footer config={config} />
</BaseLayout>
