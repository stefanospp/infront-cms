---
import "../styles/global.css";
import VideoLayout from '../components/VideoLayout.astro';
import ContactFormDark from '../components/ContactFormDark';
import { getSiteSettings, buildConfig } from '../lib/cms';
const settings = await getSiteSettings();
const config = buildConfig(settings);
---

<VideoLayout
  title="Contact"
  description="Let's create something amazing together."
  config={config}
>
  <section class="relative min-h-screen bg-neutral-950">
    {/* Subtle gradient background */}
    <div class="absolute inset-0 bg-gradient-to-br from-neutral-950 via-neutral-900 to-neutral-950" />

    {/* Content */}
    <div class="relative z-10 mx-auto max-w-6xl px-4 pt-32 pb-20 sm:px-6 sm:pt-40 sm:pb-28 lg:px-8">

      {/* Header */}
      <div class="mb-16 max-w-2xl">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500">Get in touch</p>
        <h1 class="mt-4 text-4xl font-bold leading-[1.1] text-white sm:text-5xl lg:text-6xl">
          Let's create<br />something together.
        </h1>
        <p class="mt-5 max-w-lg text-base leading-relaxed text-neutral-400">
          Have a project in mind? I'd love to hear about it. Fill out the form below and I'll get back to you as soon as possible.
        </p>
      </div>

      {/* Two-column: form + contact info */}
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-5">

        {/* Form — takes 3 columns */}
        <div class="lg:col-span-3">
          <ContactFormDark client:visible />
        </div>

        {/* Contact info — takes 2 columns */}
        <div class="lg:col-span-2 lg:pl-8">
          <div class="sticky top-32 space-y-10">

            {/* Email */}
            <div>
              <p class="text-xs font-medium uppercase tracking-[0.15em] text-neutral-500">Email</p>
              <a
                href={`mailto:${config.contact.email}`}
                class="mt-2 block text-lg font-medium text-white transition-colors hover:text-neutral-300"
              >
                {config.contact.email}
              </a>
            </div>

            {/* Social */}
            {config.footer.socials && (
              <div>
                <p class="text-xs font-medium uppercase tracking-[0.15em] text-neutral-500">Social</p>
                <div class="mt-3 flex gap-4">
                  {config.footer.socials.instagram && (
                    <a
                      href={config.footer.socials.instagram}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-sm font-medium text-neutral-400 transition-colors hover:text-white"
                    >
                      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                      </svg>
                      Instagram
                    </a>
                  )}
                  {config.footer.socials.facebook && (
                    <a
                      href={config.footer.socials.facebook}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-sm font-medium text-neutral-400 transition-colors hover:text-white"
                    >
                      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                      </svg>
                      Facebook
                    </a>
                  )}
                </div>
              </div>
            )}

            {/* Availability */}
            <div>
              <p class="text-xs font-medium uppercase tracking-[0.15em] text-neutral-500">Availability</p>
              <p class="mt-2 text-sm text-neutral-400">Available for freelance projects worldwide. Typically respond within 24 hours.</p>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>
</VideoLayout>
