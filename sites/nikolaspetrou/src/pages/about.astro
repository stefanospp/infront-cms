---
import "../styles/global.css";
import VideoLayout from '../components/VideoLayout.astro';
import Hero from '../components/Hero.astro';
import ValuesSection from '../components/ValuesSection.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getSiteSettings, buildConfig, getAbout, getProjects } from '../lib/cms';

const settings = await getSiteSettings();
const config = buildConfig(settings);
const aboutItem = await getAbout();
const about = aboutItem?.data;
const cmsProjects = await getProjects();

const values = [
  { number: '01.', title: 'Creativity Without Limits' },
  { number: '02.', title: 'Authentic Storytelling' },
  { number: '03.', title: 'Excellence in Every Frame' },
  { number: '04.', title: 'Passion-Driven Work' },
];

const valueVideos = [
  { image: '/images/project-1.jpg', title: 'Visual Stories' },
  { image: '/images/project-2.jpg', title: 'Creative Direction' },
  { image: '/images/project-3.jpg', title: 'Cinematic Quality' },
  { image: '/images/project-4.jpg', title: 'Brand Content' },
];

const works = cmsProjects.map((p, i) => ({
  title: p.title,
  subtitle: p.data.subtitle || '',
  image: `/images/project-${i + 1}.jpg`,
  videoSrc: p.data.video_url || '',
}));
---

<VideoLayout
  title="About Nikolas"
  description="Videographer and content creator telling stories through film."
  config={config}
>
  {/* Hero */}
  <Hero
    variant="minimal"
    eyebrow={about?.subheading ? "The story behind the lens." : "The story behind the lens."}
    heading={about?.heading || "I tell stories through film."}
    subheading={about?.subheading || "I'm Nikolas Petrou — a videographer and content creator focused on crafting cinematic visuals that capture real moments and deliver results for brands."}
    ctaText="Get in touch"
    ctaHref="/contact"
  />

  {/* Featured image with testimonial */}
  <section class="bg-white pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <img
          src="/images/about-hero.jpg"
          alt="Nikolas Petrou filming on location"
          class="h-[400px] w-full rounded-xl object-cover sm:h-[500px]"
          loading="lazy"
        />
        <div class="absolute bottom-3 right-3 max-w-[calc(100%-1.5rem)] rounded-xl bg-white/95 p-4 shadow-lg backdrop-blur-sm sm:bottom-6 sm:right-6 sm:max-w-sm sm:p-6">
          <p class="text-sm leading-relaxed text-neutral-700">
            &ldquo;His creative vision and attention to detail exceeded my expectations. He didn&rsquo;t just produce a video&mdash;he brought my message to life.&rdquo;
          </p>
          <p class="mt-3 text-xs font-semibold text-neutral-500">— Happy Client</p>
        </div>
      </div>
    </div>
  </section>

  {/* Values */}
  <ValuesSection
    heading={about?.values_heading || "I believe every project deserves the same passion, creativity, and attention to detail — no matter the size."}
    description={about?.values_description || "My approach is simple: understand the story, capture it authentically, and edit it to perfection. Every frame matters."}
    linkText="Work with me"
    linkHref="/contact"
    values={values}
    videos={valueVideos}
  />

  {/* Portfolio Grid */}
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 flex items-center justify-between">
        <div>
          <p class="text-sm font-medium uppercase tracking-widest text-neutral-500">Selected work</p>
          <h2 class="mt-2 text-3xl font-bold text-neutral-900 sm:text-4xl">Recent projects.</h2>
        </div>
        <a href="/works" class="text-sm font-semibold text-neutral-900 underline underline-offset-4 transition-colors hover:text-neutral-600">
          View all
        </a>
      </div>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {works.map((work) => (
          <ProjectCard
            title={work.title}
            subtitle={work.subtitle}
            image={work.image}
            videoSrc={work.videoSrc}
          />
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-neutral-950 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <p class="text-sm font-medium uppercase tracking-widest text-neutral-400">Ready to create?</p>
      <h2 class="mt-4 text-3xl font-bold text-white sm:text-4xl">Got a project? Let's talk.</h2>
      <a
        href="/contact"
        class="mt-8 inline-flex items-center rounded-full border-2 border-white px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-white hover:text-neutral-900"
      >
        Get in touch
      </a>
    </div>
  </section>
</VideoLayout>
