---
import ElementTile from './ElementTile.astro';
import { getSiteSettings } from '../lib/cms';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const settings = await getSiteSettings();
const s = settings!.data;
const navItems = s.nav_items ?? [];
---

<nav
  class:list={[
    'sticky top-0 z-50 flex items-center justify-between border-b border-[var(--th-border)] bg-[var(--th-offwhite)] px-6 py-3 sm:px-10 lg:px-16',
    className,
  ]}
>
  <a href="/" class="flex items-center gap-3" aria-label={`${settings!.title} home`}>
    <ElementTile size="nav" />
    <span class="text-lg font-bold tracking-tight">{settings!.title.toUpperCase()}</span>
  </a>

  <!-- Nav links + CTA -->
  <div class="flex items-center gap-6">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="hidden text-sm font-semibold uppercase tracking-wider text-neutral-600 transition-colors hover:text-[var(--th-black)] sm:inline"
      >
        {item.label}
      </a>
    ))}
    <a
      href={s.nav_cta_href || '/#contact'}
      class="rounded-md border-2 border-[var(--th-black)] bg-[var(--th-yellow)] px-5 py-2.5 text-sm font-bold uppercase tracking-wider text-[var(--th-black)] shadow-[var(--th-shadow)] transition-all hover:shadow-none"
    >
      {s.nav_cta_label || 'Get in touch'}
    </a>
  </div>
</nav>
