---
import ElementTile from './ElementTile.astro';

interface Props {
  badge: string;
  heading: string;
  headingHighlight: string;
  subheading: string;
  ctaPrimaryText: string;
  ctaPrimaryHref: string;
  whatsappUrl: string;
  viberUrl: string;
}

const { badge, heading, headingHighlight, subheading, ctaPrimaryText, ctaPrimaryHref, whatsappUrl, viberUrl } = Astro.props;
---

<section class="relative overflow-hidden border-b border-[var(--th-border)]">
  <div class="relative z-10 grid min-h-[calc(100vh-58px)] lg:grid-cols-[1fr_360px]">
    <!-- Left column: content -->
    <div class="flex flex-col justify-center px-6 py-16 sm:px-10 sm:py-20 lg:px-16">
      <!-- Badge -->
      <span class="mb-8 inline-flex w-fit rounded-md bg-[var(--th-green)] px-3.5 py-1.5 font-mono text-[10px] font-bold uppercase tracking-[0.15em]">
        {badge}
      </span>

      <!-- H1 -->
      <h1 class="text-[32px] uppercase leading-[0.95] tracking-[-1px] sm:text-[52px] md:text-[60px] lg:text-[72px]">
        {heading}<br />
        <mark>{headingHighlight}</mark>
      </h1>

      <!-- Subheadline -->
      <p class="mt-8 max-w-xl text-lg leading-relaxed text-neutral-500 sm:text-xl" set:html={subheading} />

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href={ctaPrimaryHref}
          class="rounded-md border-2 border-[var(--th-black)] bg-[var(--th-black)] px-7 py-3.5 text-sm font-bold uppercase tracking-wider text-white transition-all hover:bg-[var(--th-yellow)] hover:text-[var(--th-black)]"
        >
          {ctaPrimaryText}
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border-2 border-[var(--th-green-vivid)] bg-[var(--th-green-vivid)] px-7 py-3.5 text-sm font-bold uppercase tracking-wider text-white shadow-[var(--th-shadow)] transition-all hover:shadow-none"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          WhatsApp
        </a>
        <a
          href={viberUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border-2 border-[#7360F2] bg-[#7360F2] px-7 py-3.5 text-sm font-bold uppercase tracking-wider text-white shadow-[var(--th-shadow)] transition-all hover:shadow-none"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.4 0C5.112 0 0 5.098 0 11.374c0 3.073 1.228 5.86 3.224 7.9L1.118 23.65a.5.5 0 00.631.614l4.822-1.58A11.37 11.37 0 0011.4 24c6.288 0 11.4-5.098 11.4-11.374V11.4C22.8 5.098 17.688 0 11.4 0zm5.6 16.4c-.3.85-1.75 1.626-2.4 1.7-.6.075-1.376.106-2.22-.14a20.3 20.3 0 01-2.012-.744c-3.544-1.53-5.86-5.098-6.036-5.334-.176-.236-1.4-1.862-1.4-3.554 0-1.692.886-2.524 1.2-2.868.314-.344.686-.43.914-.43.228 0 .458.002.658.012.212.01.496-.08.776.592.28.674.952 2.326 1.036 2.494.084.168.14.364.028.588-.112.224-.168.364-.336.56-.168.196-.354.438-.504.588-.168.168-.344.35-.148.686.196.336.872 1.438 1.872 2.33 1.288 1.148 2.374 1.504 2.71 1.672.336.168.532.14.728-.084.196-.224.84-.98 1.064-1.316.224-.336.448-.28.756-.168.308.112 1.952.92 2.286 1.088.336.168.558.252.642.392.084.14.084.812-.216 1.662z"/>
          </svg>
          Viber
        </a>
      </div>
    </div>

    <!-- Right column: Element tile panel -->
    <div class="hidden border-l border-[var(--th-border)] bg-[var(--th-yellow)] lg:flex lg:items-center lg:justify-center">
      <ElementTile size="hero" />
    </div>
  </div>
</section>
