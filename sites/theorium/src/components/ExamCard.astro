---
import type { ExamDestination } from '../lib/directus';

interface Props {
  exam: ExamDestination;
}

const { exam } = Astro.props;

const tagColorMap: Record<string, string> = {
  green: 'bg-[var(--th-green)]',
  yellow: 'bg-[var(--th-yellow)]',
  blue: 'bg-[var(--th-blue)]',
  orange: 'bg-[var(--th-orange)]',
  purple: 'bg-[var(--th-purple)]',
};
---

<div class="flex h-full flex-col overflow-hidden rounded-lg border border-[var(--th-border)] bg-white shadow-[var(--th-shadow-lg)]">
  <!-- Header -->
  <div class="border-b border-neutral-200 px-7 py-6">
    <span class="font-mono text-[11px] uppercase tracking-wider text-neutral-400">
      {exam.flag} {exam.destination}
    </span>
    <h3 class="mt-1 text-2xl font-extrabold uppercase sm:text-3xl">{exam.exam_name}</h3>
    <span
      class:list={[
        'mt-3 inline-block rounded border border-neutral-300 px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-wider',
        tagColorMap[exam.tag_color],
      ]}
    >
      {exam.tag_label}
    </span>
  </div>

  <!-- Description -->
  <div class="flex-1 px-7 py-6">
    <p class="text-[15px] font-medium leading-relaxed text-neutral-500">{exam.description}</p>
  </div>

  <!-- Subject pills -->
  <div class="flex flex-wrap gap-2 border-t border-neutral-200 px-7 py-6">
    {exam.subjects.map((subject) => (
      <span class="rounded border border-neutral-300 bg-neutral-100 px-3 py-1.5 font-mono text-[11px] font-bold">
        {subject}
      </span>
    ))}
  </div>
</div>
