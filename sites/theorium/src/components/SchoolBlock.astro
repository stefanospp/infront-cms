---
import type { School } from '../data/schools';
import QualBadge from './QualBadge.astro';
import SubjectCell from './SubjectCell.astro';

interface Props {
  school: School;
}

const { school } = Astro.props;
---

<div class="border-2 border-[var(--th-black)] bg-white shadow-[6px_6px_0_var(--th-black)]">
  <!-- Header row -->
  <div class="flex flex-col border-b-2 border-[var(--th-black)] sm:flex-row sm:items-center">
    <!-- School name -->
    <div class="bg-[var(--th-black)] px-5 py-3 sm:shrink-0">
      <h3 class="text-base font-bold text-white sm:text-lg">{school.name}</h3>
    </div>

    <!-- Type + badges -->
    <div class="flex flex-1 flex-wrap items-center justify-end gap-2 px-5 py-2">
      <span class="mr-auto font-mono text-[10px] uppercase tracking-wider text-neutral-500 sm:mr-3">
        {school.type}
      </span>
      <div class="flex flex-wrap gap-1.5">
        {school.qualifications.map((qual) => (
          <QualBadge label={qual.label} color={qual.color} />
        ))}
      </div>
    </div>
  </div>

  <!-- Subject grid — borders handled by dividers between cells -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
    {school.subjects.map((subject, i) => (
      <div class:list={[
        i > 0 && 'border-t-2 border-[var(--th-black)] sm:border-l-2',
        i < 2 ? 'sm:border-t-0' : 'lg:border-t-0',
        i === 2 && 'sm:border-l-0 lg:border-l-2',
      ]}>
        <SubjectCell
          name={subject.name}
          accentColor={subject.accentColor}
          topics={subject.topics}
        />
      </div>
    ))}
  </div>
</div>
