---
import type { School, BadgeColor, SubjectColor } from '../data/schools';
import { schools } from '../data/schools';

const accentColors: Record<SubjectColor, string> = {
  green: 'var(--th-green)',
  blue: 'var(--th-blue)',
  orange: 'var(--th-orange)',
};

const badgeColors: Record<BadgeColor, string> = {
  yellow: 'var(--th-yellow)',
  green: 'var(--th-green)',
  blue: 'var(--th-blue)',
  orange: 'var(--th-orange)',
  purple: 'var(--th-purple)',
  default: '#E5E2DE',
};

const tabLabels = schools.map(s =>
  s.name
    .replace(' — Lyceum', '')
    .replace(' Private School Larnaka', '')
    .replace(' Private English School', '')
    .replace(' Larnaca', '')
);
---

<div id="school-tabs">
  <!-- Tab buttons -->
  <div class="hide-scrollbar flex gap-2 mb-8 overflow-x-auto pb-2 sm:flex-wrap sm:overflow-visible sm:pb-0">
    {tabLabels.map((label, i) => (
      <button
        data-tab={i}
        data-active={i === 0 ? 'true' : 'false'}
        class="school-tab shrink-0 rounded-md border px-5 py-3 text-sm font-bold uppercase tracking-wider transition-all cursor-pointer"
        onclick={`(function(idx){var c=document.getElementById('school-tabs');var ts=c.querySelectorAll('.school-tab');var cs=c.querySelectorAll('.school-card');for(var j=0;j<ts.length;j++){ts[j].setAttribute('data-active',j===idx?'true':'false');if(j===idx)cs[j].classList.remove('hidden');else cs[j].classList.add('hidden')}})(${i})`}
      >
        {label}
      </button>
    ))}
  </div>

  <!-- School cards (all rendered, only first visible) -->
  {schools.map((school, idx) => (
    <div data-school={idx} class:list={['school-card overflow-hidden rounded-lg border border-[var(--th-border)] bg-white shadow-[var(--th-shadow-lg)]', idx > 0 && 'hidden']}>
      <!-- Header -->
      <div class="flex flex-col gap-3 border-b border-neutral-200 sm:flex-row sm:items-center">
        <div class="bg-[var(--th-black)] px-7 py-5 sm:shrink-0 sm:rounded-br-lg">
          <h3 class="text-lg font-extrabold text-white">{school.name}</h3>
        </div>
        <div class="flex flex-1 flex-wrap items-center justify-end gap-2 px-6 py-3">
          <span class="mr-auto font-mono text-[11px] font-medium uppercase tracking-wider text-neutral-400 sm:mr-3">
            {school.type}
          </span>
          <div class="flex flex-wrap gap-1.5">
            {school.qualifications.map((qual) => (
              <span
                class="inline-block rounded border border-neutral-300 px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.1em]"
                style={`background-color: ${badgeColors[qual.color]}`}
              >
                {qual.label}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Subject grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        {school.subjects.map((subject, i) => (
          <div class:list={[
            i > 0 && 'border-t border-neutral-200 sm:border-l',
            i < 2 && 'sm:border-t-0',
            i >= 2 && 'lg:border-t-0',
            i === 2 && 'sm:border-l-0 lg:border-l',
          ]}>
            <div class="h-[4px]" style={`background-color: ${accentColors[subject.accentColor]}`} />
            <div class="p-6">
              <h4 class="text-lg font-extrabold">{subject.name}</h4>
              <p class="mt-3 text-[15px] font-medium leading-relaxed text-neutral-500">{subject.topics}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .school-tab[data-active="true"] {
    background-color: var(--th-black);
    color: white;
    border-color: var(--th-black);
    box-shadow: none;
  }
  .school-tab[data-active="false"] {
    background-color: white;
    color: var(--th-black);
    border-color: #DBD5D6;
    box-shadow: var(--th-shadow);
  }
  .school-tab[data-active="false"]:hover {
    box-shadow: none;
  }
</style>

