---
import type { SubjectColor } from '../data/schools';

interface Props {
  name: string;
  accentColor: SubjectColor;
  topics: string;
}

const { name, accentColor, topics } = Astro.props;

const accentMap: Record<SubjectColor, string> = {
  green: 'bg-[var(--th-green)]',
  blue: 'bg-[var(--th-blue)]',
  orange: 'bg-[var(--th-orange)]',
};
---

<div>
  <div class:list={['h-[3px]', accentMap[accentColor]]} />
  <div class="p-5">
    <h4 class="text-base font-bold">{name}</h4>
    <p class="mt-2 text-sm leading-relaxed text-neutral-500">{topics}</p>
  </div>
</div>
