---
interface Props {
  size?: 'nav' | 'hero' | 'footer';
  class?: string;
}

const { size = 'nav', class: className } = Astro.props;

const sizeClasses = {
  nav: 'w-[36px] h-[36px]',
  hero: 'w-[140px] h-[140px] sm:w-[180px] sm:h-[180px]',
  footer: 'w-[30px] h-[30px]',
};

const symbolSize = {
  nav: 'text-[20px]',
  hero: 'text-[64px] sm:text-[80px]',
  footer: 'text-[16px]',
};

const nameSize = {
  nav: 'hidden',
  hero: 'text-[10px] sm:text-[12px]',
  footer: 'hidden',
};
---

<div
  class:list={[
    'flex flex-col items-center justify-center rounded-md border-2 border-[var(--th-black)] bg-[var(--th-yellow)] font-mono select-none',
    sizeClasses[size],
    className,
  ]}
>
  <span class:list={['leading-none font-bold', symbolSize[size]]}>Th</span>
  {size === 'hero' && (
    <span class:list={['uppercase tracking-[0.15em] leading-none mt-1', nameSize[size]]}>Theorium</span>
  )}
</div>
