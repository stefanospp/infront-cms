---
import type { Resource } from '../lib/directus';

interface Props {
  resource: Resource;
}

const { resource } = Astro.props;

const subjectColors: Record<string, string> = {
  Biology: 'var(--th-green)',
  Chemistry: 'var(--th-green)',
  Physics: 'var(--th-blue)',
  Mathematics: 'var(--th-orange)',
};

const typeIcons: Record<string, string> = {
  'Revision Notes': '📝',
  'Past Papers': '📄',
  'Topic Summary': '📋',
  'Formula Sheet': '🔢',
  'Checklist': '✅',
};
---

<div
  class="flex h-full flex-col overflow-hidden rounded-lg border border-[var(--th-border)] bg-white shadow-[var(--th-shadow)] transition-all hover:shadow-none"
  data-subject={resource.subject}
  data-board={resource.exam_board}
>
  <!-- Color bar -->
  <div class="h-[4px]" style={`background-color: ${subjectColors[resource.subject] || 'var(--th-green)'}`} />

  <div class="flex flex-1 flex-col p-5">
    <!-- Type + Board badges -->
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <span class="rounded border border-neutral-300 bg-neutral-100 px-2 py-0.5 font-mono text-[10px] font-bold uppercase">
        {typeIcons[resource.resource_type] || '📄'} {resource.resource_type}
      </span>
      <span
        class="rounded border border-neutral-300 px-2 py-0.5 font-mono text-[10px] font-bold uppercase"
        style={`background-color: ${subjectColors[resource.subject] || 'var(--th-green)'}40`}
      >
        {resource.exam_board}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-base font-bold leading-snug">{resource.title}</h3>

    <!-- Description -->
    {resource.description && (
      <p class="mt-2 flex-1 text-sm text-neutral-500">{resource.description}</p>
    )}

    <!-- Download button -->
    <a
      href={resource.drive_url}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-4 inline-flex items-center gap-2 self-start rounded-md border-2 border-[var(--th-black)] bg-[var(--th-black)] px-4 py-2 text-xs font-bold uppercase tracking-wider text-white transition-all hover:bg-[var(--th-yellow)] hover:text-[var(--th-black)]"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      Download Free
    </a>
  </div>
</div>
