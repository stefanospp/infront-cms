---
import '../styles/global.css';
import BaseLayout from '@agency/ui/layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import CourseCard from '../components/CourseCard.astro';
import Footer from '../components/Footer.astro';
import { getCourses } from '../lib/directus';
import config from '../../site.config';

const courses = await getCourses();
const upcoming = courses.filter(c => c.course_status === 'upcoming');
const inProgress = courses.filter(c => c.course_status === 'in-progress');
const past = courses.filter(c => c.course_status === 'completed' || c.course_status === 'full');
---

<BaseLayout
  title="Online Revision Courses | Theorium"
  description="Live online revision courses for IGCSE, A-Level, IB, and UCAT via Zoom. Small groups, exam-focused, taught by an experienced science and maths tutor."
  config={config}
>
  <Nav />

  <main id="main-content">
    <PageHero
      badge="Online Courses"
      badgeColor="var(--th-blue)"
      title="ONLINE REVISION <mark>COURSES.</mark>"
      subtitle="Live group revision sessions via Zoom. Small classes, exam-focused, with personalised feedback. Book your place through Zoom Events."
    />

    <section class="px-6 py-16 sm:px-10 sm:py-20 lg:px-16">
      <!-- How it works -->
      <div class="mb-12 grid gap-6 sm:grid-cols-3">
        <div class="rounded-lg border border-[var(--th-border)] bg-white p-6 text-center">
          <span class="text-3xl">📹</span>
          <h3 class="mt-3 text-base font-bold uppercase">Live on Zoom</h3>
          <p class="mt-1 text-sm text-neutral-500">Interactive sessions with screen sharing, Q&A, and real-time problem solving.</p>
        </div>
        <div class="rounded-lg border border-[var(--th-border)] bg-white p-6 text-center">
          <span class="text-3xl">👥</span>
          <h3 class="mt-3 text-base font-bold uppercase">Small Groups</h3>
          <p class="mt-1 text-sm text-neutral-500">8–12 students per session for personalised attention and questions.</p>
        </div>
        <div class="rounded-lg border border-[var(--th-border)] bg-white p-6 text-center">
          <span class="text-3xl">💳</span>
          <h3 class="mt-3 text-base font-bold uppercase">Easy Booking</h3>
          <p class="mt-1 text-sm text-neutral-500">Register and pay securely through Zoom Events. Instant confirmation.</p>
        </div>
      </div>

      <!-- Upcoming courses -->
      {upcoming.length > 0 && (
        <div class="mb-16">
          <h2 class="mb-6 text-2xl font-extrabold uppercase">Upcoming Courses</h2>
          <div class="grid gap-6 lg:grid-cols-2">
            {upcoming.map((course) => (
              <CourseCard course={course} />
            ))}
          </div>
        </div>
      )}

      <!-- In progress -->
      {inProgress.length > 0 && (
        <div class="mb-16">
          <h2 class="mb-6 text-2xl font-extrabold uppercase">Currently Running</h2>
          <div class="grid gap-6 lg:grid-cols-2">
            {inProgress.map((course) => (
              <CourseCard course={course} />
            ))}
          </div>
        </div>
      )}

      <!-- No courses fallback -->
      {courses.length === 0 && (
        <div class="py-20 text-center">
          <p class="text-lg text-neutral-500">New courses will be announced soon. Check back shortly.</p>
        </div>
      )}

      <!-- Past/full courses -->
      {past.length > 0 && (
        <div class="mt-12 opacity-60">
          <h2 class="mb-6 text-xl font-bold uppercase text-neutral-400">Past Courses</h2>
          <div class="grid gap-6 lg:grid-cols-2">
            {past.map((course) => (
              <CourseCard course={course} />
            ))}
          </div>
        </div>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>
