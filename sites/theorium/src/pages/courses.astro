---
import '../styles/global.css';
import BaseLayout from '@agency/ui/layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import CourseCard from '../components/CourseCard.astro';
import Footer from '../components/Footer.astro';
import { getCourses, getPageContent, getTutoringSteps, getSiteSettings } from '../lib/cms';

const settings = await getSiteSettings();
const s = settings!.data;
const page = await getPageContent('courses');
const courses = await getCourses();
const howItWorks = await getTutoringSteps('courses');
const upcoming = courses.filter(c => c.data.course_status === 'upcoming');
const inProgress = courses.filter(c => c.data.course_status === 'in-progress');
const past = courses.filter(c => c.data.course_status === 'completed' || c.data.course_status === 'full');
const config = { seo: { defaultTitle: s.meta_default_title, defaultDescription: s.meta_default_description }, url: s.url, contact: { phone: s.contact_phone, email: s.contact_email, address: { city: s.contact_city, country: s.contact_country } } };
const siteContent = { courses_page_title: page?.data.page_title ?? '', courses_page_subtitle: page?.data.page_subtitle ?? '' };
---

<BaseLayout
  title="Online Revision Courses | Theorium"
  description="Live online revision courses for IGCSE, A-Level, IB, and UCAT via Zoom. Small groups, exam-focused, taught by an experienced science and maths tutor."
  config={config}
>
  <Nav />

  <main id="main-content">
    <PageHero
      badge="Online Courses"
      badgeColor="var(--th-blue)"
      title={siteContent.courses_page_title}
      subtitle={siteContent.courses_page_subtitle}
    />

    <section class="px-6 py-16 sm:px-10 sm:py-20 lg:px-16">
      <!-- How it works -->
      <div class="mb-12 grid gap-6 sm:grid-cols-3">
        {howItWorks.map((step) => (
          <div class="rounded-lg border border-[var(--th-border)] bg-white p-6 text-center">
            <span class="text-3xl">{step.data.emoji}</span>
            <h3 class="mt-3 text-base font-bold uppercase">{step.title}</h3>
            <p class="mt-1 text-sm text-neutral-500">{step.data.description}</p>
          </div>
        ))}
      </div>

      <!-- Upcoming courses -->
      {upcoming.length > 0 && (
        <div class="mb-16">
          <h2 class="mb-6 text-2xl font-extrabold uppercase">Upcoming Courses</h2>
          <div class="grid gap-6 lg:grid-cols-2">
            {upcoming.map((course) => (
              <CourseCard course={course} />
            ))}
          </div>
        </div>
      )}

      <!-- In progress -->
      {inProgress.length > 0 && (
        <div class="mb-16">
          <h2 class="mb-6 text-2xl font-extrabold uppercase">Currently Running</h2>
          <div class="grid gap-6 lg:grid-cols-2">
            {inProgress.map((course) => (
              <CourseCard course={course} />
            ))}
          </div>
        </div>
      )}

      <!-- No courses fallback -->
      {courses.length === 0 && (
        <div class="py-20 text-center">
          <p class="text-lg text-neutral-500">New courses will be announced soon. Check back shortly.</p>
        </div>
      )}

      <!-- Past/full courses -->
      {past.length > 0 && (
        <div class="mt-12 opacity-60">
          <h2 class="mb-6 text-xl font-bold uppercase text-neutral-400">Past Courses</h2>
          <div class="grid gap-6 lg:grid-cols-2">
            {past.map((course) => (
              <CourseCard course={course} />
            ))}
          </div>
        </div>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>
