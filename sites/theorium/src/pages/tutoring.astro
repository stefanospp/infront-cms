---
import '../styles/global.css';
import BaseLayout from '@agency/ui/layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
import {
  getSiteSettings,
  getPageContent,
  getTutoringTiers,
  getTutoringSteps,
  getTutoringSubjects,
} from '../lib/cms';

const settings = await getSiteSettings();
const s = settings!.data;
const page = await getPageContent('tutoring');
const tiers = await getTutoringTiers();
const steps = await getTutoringSteps('tutoring');
const subjects = await getTutoringSubjects();
const config = { seo: { defaultTitle: s.meta_default_title, defaultDescription: s.meta_default_description }, url: s.url, contact: { phone: s.contact_phone, email: s.contact_email, address: { city: s.contact_city, country: s.contact_country } } };
const siteContent = { tutoring_page_title: page?.data.page_title ?? '', tutoring_page_subtitle: page?.data.page_subtitle ?? '' };
---

<BaseLayout
  title="Online Tutoring — Private & Small Group | Theorium"
  description="Private 1-on-1 and small group online science and maths tutoring via Zoom. IGCSE, A-Level, IB, and Pancyprian exam preparation from an experienced tutor."
  config={config}
>
  <Nav />

  <main id="main-content">
    <PageHero
      badge="Online Tutoring"
      badgeColor="var(--th-purple)"
      title={siteContent.tutoring_page_title}
      subtitle={siteContent.tutoring_page_subtitle}
    />

    <!-- Tutoring tiers -->
    <section class="px-6 py-20 sm:px-10 sm:py-28 lg:px-16">
      <div class="grid gap-8 lg:grid-cols-2">
        {tiers.map((tier, idx) => (
          <div class="flex h-full flex-col overflow-hidden rounded-lg border border-[var(--th-border)] bg-white shadow-[var(--th-shadow-lg)]">
            <div class="h-[4px]" style={`background-color: ${tier.data.accent_color}`} />
            <div class="flex flex-1 flex-col p-8">
              <span class="text-4xl">{tier.data.emoji}</span>
              <h2 class="mt-4 text-2xl font-extrabold uppercase">
                {tier.title}
                {tier.data.size_label && <span class="text-lg font-bold text-neutral-400"> {tier.data.size_label}</span>}
              </h2>
              <p class="mt-3 text-[15px] font-medium leading-relaxed text-neutral-500">
                {tier.data.description}
              </p>

              <ul class="mt-6 space-y-3">
                {tier.data.benefits.map((item) => (
                  <li class="flex items-start gap-3 text-sm">
                    <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full" style={`background-color: ${tier.data.accent_color}`}>
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    </span>
                    <span class="font-medium">{item}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-6 rounded-lg border border-neutral-200 bg-neutral-100 p-4">
                <span class="font-mono text-[10px] uppercase tracking-wider text-neutral-400">Best for</span>
                <p class="mt-1 text-sm text-neutral-600">{tier.data.best_for}</p>
              </div>

              <div class="mt-auto pt-8">
                <p class="font-mono text-[10px] uppercase tracking-wider text-neutral-400">Starting from</p>
                <p class="text-3xl font-extrabold">{tier.data.price}<span class="text-base font-medium text-neutral-400">{tier.data.price_unit}</span></p>

                <a
                  href={tier.data.cta_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={[
                    'mt-4 inline-flex w-full items-center justify-center gap-2 rounded-md border-2 px-6 py-3 text-sm font-bold uppercase tracking-wider transition-all',
                    idx === 0
                      ? 'border-[var(--th-black)] bg-[var(--th-black)] text-white hover:bg-[var(--th-yellow)] hover:text-[var(--th-black)]'
                      : 'border-[var(--th-black)] bg-white text-[var(--th-black)] shadow-[var(--th-shadow)] hover:shadow-none',
                  ]}
                >
                  {tier.data.cta_text}
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section class="border-t border-[var(--th-border)] px-6 py-20 sm:px-10 sm:py-28 lg:px-16">
      <div class="mb-12 text-center">
        <span class="mb-4 inline-block rounded-md border border-neutral-300 bg-[var(--th-orange)] px-4 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.2em]">
          How it works
        </span>
        <h2 class="text-[32px] font-bold uppercase tracking-[-1px] sm:text-[40px]">
          THREE SIMPLE <mark>STEPS.</mark>
        </h2>
      </div>

      <div class="grid gap-8 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="text-center">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-[var(--th-border)] bg-white text-2xl font-extrabold shadow-[var(--th-shadow)]">
              {step.data.emoji}
            </div>
            <h3 class="mt-5 text-lg font-extrabold uppercase">{step.title}</h3>
            <p class="mt-2 text-sm text-neutral-500">{step.data.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Subjects -->
    <section class="border-t border-[var(--th-border)] px-6 py-20 sm:px-10 sm:py-28 lg:px-16">
      <div class="mb-12 text-center">
        <h2 class="text-[32px] font-bold uppercase tracking-[-1px] sm:text-[40px]">
          SUBJECTS <mark>AVAILABLE.</mark>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-neutral-500">All subjects taught across IGCSE, A-Level, IB Diploma, SAT, and Pancyprian curricula.</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {subjects.map((subject) => (
          <div class="overflow-hidden rounded-lg border border-[var(--th-border)] bg-white shadow-[var(--th-shadow)]">
            <div class="h-[4px]" style={`background-color: ${subject.data.accent_color}`} />
            <div class="p-6">
              <h3 class="text-lg font-extrabold">{subject.title}</h3>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {subject.data.levels.map((level) => (
                  <span class="rounded border border-neutral-300 bg-neutral-100 px-2 py-0.5 font-mono text-[10px] font-bold uppercase">
                    {level}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-[var(--th-border)] px-6 py-20 sm:px-10 sm:py-28 lg:px-16">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-[32px] font-bold uppercase tracking-[-1px] sm:text-[40px]">
          READY TO <mark>START?</mark>
        </h2>
        <p class="mt-4 text-base text-neutral-500">
          Send a message with your school, subject, and level. Theodora will get back to you to arrange your first session.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href={siteContent.hero_whatsapp_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md border-2 border-[var(--th-green-vivid)] bg-[var(--th-green-vivid)] px-7 py-3.5 text-sm font-bold uppercase tracking-wider text-white shadow-[var(--th-shadow)] transition-all hover:shadow-none"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
            WhatsApp
          </a>
          <a
            href={siteContent.hero_viber_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md border-2 border-[#7360F2] bg-[#7360F2] px-7 py-3.5 text-sm font-bold uppercase tracking-wider text-white shadow-[var(--th-shadow)] transition-all hover:shadow-none"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.4 0C5.112 0 0 5.098 0 11.374c0 3.073 1.228 5.86 3.224 7.9L1.118 23.65a.5.5 0 00.631.614l4.822-1.58A11.37 11.37 0 0011.4 24c6.288 0 11.4-5.098 11.4-11.374V11.4C22.8 5.098 17.688 0 11.4 0zm5.6 16.4c-.3.85-1.75 1.626-2.4 1.7-.6.075-1.376.106-2.22-.14a20.3 20.3 0 01-2.012-.744c-3.544-1.53-5.86-5.098-6.036-5.334-.176-.236-1.4-1.862-1.4-3.554 0-1.692.886-2.524 1.2-2.868.314-.344.686-.43.914-.43.228 0 .458.002.658.012.212.01.496-.08.776.592.28.674.952 2.326 1.036 2.494.084.168.14.364.028.588-.112.224-.168.364-.336.56-.168.196-.354.438-.504.588-.168.168-.344.35-.148.686.196.336.872 1.438 1.872 2.33 1.288 1.148 2.374 1.504 2.71 1.672.336.168.532.14.728-.084.196-.224.84-.98 1.064-1.316.224-.336.448-.28.756-.168.308.112 1.952.92 2.286 1.088.336.168.558.252.642.392.084.14.084.812-.216 1.662z"/></svg>
            Viber
          </a>
          <a
            href="/#contact"
            class="inline-flex items-center gap-2 rounded-md border-2 border-[var(--th-black)] bg-white px-7 py-3.5 text-sm font-bold uppercase tracking-wider text-[var(--th-black)] shadow-[var(--th-shadow)] transition-all hover:shadow-none"
          >
            Send a message
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
