---
import '../styles/global.css';
import BaseLayout from '@agency/ui/layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import SubjectFilter from '../components/SubjectFilter.astro';
import ResourceCard from '../components/ResourceCard.astro';
import Footer from '../components/Footer.astro';
import { getResources, getPageContent, getSiteSettings } from '../lib/cms';

const settings = await getSiteSettings();
const s = settings!.data;
const page = await getPageContent('resources');
const resources = await getResources();
const subjects = ['Biology', 'Chemistry', 'Physics', 'Mathematics'];
const config = { seo: { defaultTitle: s.meta_default_title, defaultDescription: s.meta_default_description }, url: s.url, contact: { phone: s.contact_phone, email: s.contact_email, address: { city: s.contact_city, country: s.contact_country } } };
---

<BaseLayout
  title="Free Study Resources | Theorium"
  description="Free revision notes, past papers, formula sheets, and topic summaries for IGCSE, A-Level, IB, and Pancyprian exams. Download and study for free."
  config={config}
>
  <Nav />

  <main id="main-content">
    <PageHero
      badge="Free Resources"
      badgeColor="var(--th-green)"
      title={page?.data.page_title ?? 'FREE STUDY <mark>RESOURCES.</mark>'}
      subtitle={page?.data.page_subtitle}
    />

    <section class="px-6 py-16 sm:px-10 sm:py-20 lg:px-16">
      <!-- Subject filter -->
      <SubjectFilter
        subjects={subjects}
        containerId="resource-filters"
        cardSelector=".resource-card"
      />

      <!-- Resource grid -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {resources.map((resource) => (
          <div class="resource-card" data-subject={resource.data.subject}>
            <ResourceCard resource={resource} />
          </div>
        ))}
      </div>

      {resources.length === 0 && (
        <div class="py-20 text-center">
          <p class="text-lg text-neutral-500">Resources coming soon. Check back shortly.</p>
        </div>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>
