---
import '../styles/global.css';
import BaseLayout from '@agency/ui/layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import SchoolTabs from '../components/SchoolTabs.astro';
import ExamCard from '../components/ExamCard.astro';
import MedicalBlock from '../components/MedicalBlock.astro';
import ResourceCard from '../components/ResourceCard.astro';
import CourseCard from '../components/CourseCard.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import { schools } from '../data/schools';
import { examCards, medicalBlock } from '../data/exams';
import { getResources, getCourses } from '../lib/directus';
import config from '../../site.config';

const featuredResources = await getResources({ limit: 3 });
const upcomingCourses = (await getCourses({ limit: 3 })).filter(c => c.course_status === 'upcoming');

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Theorium',
  description: config.seo.defaultDescription,
  url: config.url,
  telephone: config.contact.phone,
  email: config.contact.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Larnaca',
    addressCountry: 'CY',
  },
  areaServed: {
    '@type': 'City',
    name: 'Larnaca',
  },
  priceRange: '$$',
  knowsAbout: [
    'Science tutoring',
    'Mathematics tutoring',
    'IGCSE preparation',
    'A-Level preparation',
    'IB Diploma preparation',
    'UCAT preparation',
    'SAT preparation',
    'Pancyprian exam preparation',
    'Medical school preparation',
  ],
};
---

<BaseLayout
  title={config.seo.defaultTitle}
  description={config.seo.defaultDescription}
  structuredData={structuredData}
  config={config}
>
  <Nav />

  <main id="main-content">
    <Hero />
    <Ticker />

    <!-- Curriculum by School -->
    <section id="subjects" class="px-6 py-20 sm:px-10 sm:py-28 lg:px-16">
      <div class="mb-12 text-center">
        <span class="mb-4 inline-block rounded-md border border-neutral-300 bg-[var(--th-yellow)] px-4 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.2em]">
          Curriculum Coverage
        </span>
        <h2 class="text-[32px] font-bold uppercase tracking-[-1px] sm:text-[40px] lg:text-[48px]">
          Your school. <mark>Your subjects.</mark>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-neutral-500 sm:text-lg">
          Lessons tailored to the specific curriculum, exam board, and syllabus at each school.
        </p>
      </div>

      <SchoolTabs />
    </section>

    <!-- University Entrance Exam Preparation band -->
    <div class="flex items-center justify-center border-y border-[var(--th-border)] bg-[var(--th-black)] py-4 rounded-none">
      <span class="font-mono text-[10px] font-bold uppercase tracking-[0.25em] text-white sm:text-xs">
        ■&nbsp; University Entrance Exam Preparation
      </span>
    </div>

    <!-- University Exams -->
    <section id="exams" class="px-6 py-20 sm:px-10 sm:py-28 lg:px-16">
      <div class="mb-12 text-center">
        <span class="mb-4 inline-block rounded-md border border-neutral-300 bg-[var(--th-orange)] px-4 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.2em]">
          Higher Education
        </span>
        <h2 class="text-[32px] font-bold uppercase tracking-[-1px] sm:text-[40px] lg:text-[48px]">
          University exams &<br /><mark>medical school.</mark>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-neutral-500 sm:text-lg">
          Preparation for entrance exams and admissions to universities in the UK, US, Netherlands, Germany, and Cyprus.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {examCards.map((exam) => (
          <ExamCard exam={exam} />
        ))}
      </div>

      <div class="mt-8">
        <MedicalBlock block={medicalBlock} />
      </div>
    </section>

    <!-- Free Resources Teaser -->
    {featuredResources.length > 0 && (
      <section class="px-6 py-20 sm:px-10 sm:py-28 lg:px-16">
        <div class="mb-12 text-center">
          <span class="mb-4 inline-block rounded-md border border-neutral-300 bg-[var(--th-green)] px-4 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.2em]">
            Free Resources
          </span>
          <h2 class="text-[32px] font-bold uppercase tracking-[-1px] sm:text-[40px] lg:text-[48px]">
            STUDY <mark>MATERIALS.</mark>
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-base text-neutral-500 sm:text-lg">
            Free revision notes, past papers, and topic summaries. Download and study at your own pace.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredResources.map((resource) => (
            <ResourceCard resource={resource} />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/resources" class="inline-flex items-center gap-2 rounded-md border-2 border-[var(--th-black)] bg-white px-6 py-3 text-sm font-bold uppercase tracking-wider text-[var(--th-black)] shadow-[var(--th-shadow)] transition-all hover:shadow-none">
            View all resources
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </section>
    )}

    <!-- Online Courses Teaser -->
    {upcomingCourses.length > 0 && (
      <section class="border-t border-[var(--th-border)] px-6 py-20 sm:px-10 sm:py-28 lg:px-16">
        <div class="mb-12 text-center">
          <span class="mb-4 inline-block rounded-md border border-neutral-300 bg-[var(--th-blue)] px-4 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.2em]">
            Online Courses
          </span>
          <h2 class="text-[32px] font-bold uppercase tracking-[-1px] sm:text-[40px] lg:text-[48px]">
            REVISION <mark>COURSES.</mark>
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-base text-neutral-500 sm:text-lg">
            Live group revision sessions on Zoom. Small classes, exam-focused, with expert guidance.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {upcomingCourses.slice(0, 2).map((course) => (
            <CourseCard course={course} />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/courses" class="inline-flex items-center gap-2 rounded-md border-2 border-[var(--th-black)] bg-white px-6 py-3 text-sm font-bold uppercase tracking-wider text-[var(--th-black)] shadow-[var(--th-shadow)] transition-all hover:shadow-none">
            View all courses
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </section>
    )}

    <!-- Contact -->
    <ContactSection />
  </main>

  <Footer />
</BaseLayout>
