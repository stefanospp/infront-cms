---
export interface ReelItem {
  url: string;
  image: string;
  date?: string;
}

export interface Props {
  heading?: string;
  username?: string;
  profileImage?: string;
  postCount?: number;
  reels: ReelItem[];
  class?: string;
}

const {
  heading = 'Latest Instagram Posts',
  username = 'nikolaspetrouu',
  profileImage,
  postCount = 221,
  reels,
  class: className,
} = Astro.props;
---

<section class:list={['bg-neutral-950 py-20 sm:py-28', className]}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    {/* Header — profile row */}
    <div class="mb-8 flex items-center justify-center gap-4">
      {/* Profile pic */}
      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-neutral-800 text-white">
        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </div>
      <div class="text-center">
        <h2 class="text-lg font-bold text-white">{heading}</h2>
        <p class="text-sm text-neutral-400">{postCount} Posts</p>
      </div>
      <a
        href={`https://instagram.com/${username}`}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-white px-5 py-2 text-sm font-semibold text-neutral-900 transition-colors hover:bg-neutral-200"
      >
        Follow us
      </a>
    </div>

    {/* Slider */}
    <div class="relative" data-ig-slider>
      {/* Left arrow */}
      <button
        type="button"
        class="absolute left-2 top-1/2 z-20 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-white/90 text-neutral-800 shadow-lg transition-all hover:bg-white hover:scale-110 sm:left-0 sm:-translate-x-1/2"
        data-ig-prev
        aria-label="Previous"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      {/* Right arrow */}
      <button
        type="button"
        class="absolute right-2 top-1/2 z-20 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-white/90 text-neutral-800 shadow-lg transition-all hover:bg-white hover:scale-110 sm:right-0 sm:translate-x-1/2"
        data-ig-next
        aria-label="Next"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      {/* Cards track */}
      <div
        class="flex gap-4 overflow-x-auto scrollbar-hide snap-x snap-mandatory px-1 sm:gap-5"
        data-ig-track
        style="-webkit-overflow-scrolling: touch; scroll-behavior: smooth;"
      >
        {reels.map((reel) => (
          <a
            href={reel.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative w-[260px] flex-shrink-0 snap-start overflow-hidden rounded-2xl sm:w-[290px]"
          >
            {/* Image */}
            <div class="relative aspect-[3/4]">
              <img
                src={reel.image}
                alt=""
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              {/* Dark gradient at bottom */}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent" />

              {/* Play button — center */}
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="flex h-14 w-14 items-center justify-center rounded-full bg-black/30 backdrop-blur-sm transition-transform duration-300 group-hover:scale-110">
                  <svg class="ml-1 h-6 w-6 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>

              {/* Instagram icon — top right */}
              <div class="absolute top-3 right-3">
                <svg class="h-6 w-6 text-white/70" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </div>

              {/* Bottom info — profile + date */}
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <div class="flex items-center gap-2.5">
                  <div class="flex h-8 w-8 items-center justify-center rounded-full bg-neutral-700 text-xs font-bold text-white">
                    N
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-white">{username}</p>
                    {reel.date && <p class="text-xs text-neutral-400">{reel.date}</p>}
                  </div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-ig-slider]').forEach((slider) => {
    const track = slider.querySelector('[data-ig-track]') as HTMLElement;
    const prev = slider.querySelector('[data-ig-prev]');
    const next = slider.querySelector('[data-ig-next]');
    if (!track) return;

    const scrollAmount = () => {
      const child = track.firstElementChild as HTMLElement | null;
      return child ? child.offsetWidth + 20 : 300;
    };

    prev?.addEventListener('click', () => track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left: scrollAmount(), behavior: 'smooth' }));
  });
</script>
