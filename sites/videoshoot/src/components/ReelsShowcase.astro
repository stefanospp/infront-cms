---
export interface Props {
  heading?: string;
  eyebrow?: string;
  reelIds: string[];
  class?: string;
}

const { heading = 'Follow the journey.', eyebrow = '@nikolaspetrouu', reelIds, class: className } = Astro.props;
---

<section class:list={['bg-neutral-950 py-20 sm:py-28', className]}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {/* Header */}
    <div class="mb-12 flex items-end justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-neutral-500">{eyebrow}</p>
        <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">{heading}</h2>
      </div>
      <a
        href="https://instagram.com/nikolaspetrouu"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center gap-2 rounded-full border border-neutral-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:border-white hover:bg-white hover:text-neutral-900 sm:inline-flex"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        Follow me
      </a>
    </div>

    {/* Reels grid — seamless, cropped to hide IG chrome */}
    <div class="flex gap-4 overflow-x-auto pb-4 scrollbar-hide snap-x snap-mandatory sm:gap-6" style="-webkit-overflow-scrolling: touch; scroll-behavior: smooth;">
      {reelIds.map((id) => (
        <div class="w-[260px] flex-shrink-0 snap-start sm:w-[300px]">
          <div class="relative overflow-hidden rounded-xl bg-neutral-900" style="aspect-ratio: 9/16;">
            <iframe
              src={`https://www.instagram.com/reel/${id}/embed/`}
              class="absolute border-0"
              style="top: -60px; left: 0; width: 100%; height: calc(100% + 120px);"
              scrolling="no"
              allowtransparency="true"
              allow="autoplay; encrypted-media"
              loading="lazy"
              title="Instagram Reel"
            />
          </div>
        </div>
      ))}
    </div>

    {/* Mobile follow CTA */}
    <div class="mt-8 text-center sm:hidden">
      <a
        href="https://instagram.com/nikolaspetrouu"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-neutral-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:border-white"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        Follow @nikolaspetrouu
      </a>
    </div>
  </div>
</section>
