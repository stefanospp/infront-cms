---
export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const scrollerId = `scroller-${Math.random().toString(36).slice(2, 8)}`;
---

<div class:list={['relative', className]} data-horizontal-scroller>
  {/* Navigation arrows */}
  <div class="mb-6 flex items-center justify-end gap-3">
    <button
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 bg-white text-neutral-600 transition-colors hover:bg-neutral-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
      aria-label="Scroll left"
      data-scroller-prev
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 bg-white text-neutral-600 transition-colors hover:bg-neutral-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
      aria-label="Scroll right"
      data-scroller-next
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>

  {/* Scrollable container */}
  <div
    id={scrollerId}
    class="flex snap-x snap-mandatory gap-6 overflow-x-auto scrollbar-hide pb-4"
    role="region"
    aria-label="Scrollable content"
    data-scroller-track
  >
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll('[data-horizontal-scroller]').forEach((wrapper) => {
    const track = wrapper.querySelector('[data-scroller-track]') as HTMLElement | null;
    const prevBtn = wrapper.querySelector('[data-scroller-prev]');
    const nextBtn = wrapper.querySelector('[data-scroller-next]');

    if (!track) return;

    function scrollByAmount(direction: 1 | -1) {
      const child = track!.firstElementChild as HTMLElement | null;
      const scrollAmount = child ? child.offsetWidth + 24 : track!.offsetWidth * 0.8;
      track!.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
    }

    prevBtn?.addEventListener('click', () => scrollByAmount(-1));
    nextBtn?.addEventListener('click', () => scrollByAmount(1));
  });
</script>
