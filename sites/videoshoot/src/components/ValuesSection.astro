---
export interface VideoItem {
  image?: string;
  title?: string;
  videoSrc?: string;
}

export interface Props {
  heading: string;
  description: string;
  linkText?: string;
  linkHref?: string;
  videos?: VideoItem[];
  class?: string;
}

const { heading, description, linkText, linkHref, videos = [], class: className } = Astro.props;
---

<section class:list={['bg-neutral-950 py-20 sm:py-28', className]}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-stretch lg:gap-16">
      {/* Left column — Text, stretches to match video grid height */}
      <div class="flex flex-col justify-center">
        <h2 class="text-2xl font-bold leading-snug text-white sm:text-3xl lg:text-4xl">
          {heading}
        </h2>
        <p class="mt-6 text-base leading-relaxed text-neutral-400">
          {description}
        </p>
        {linkText && linkHref && (
          <div class="mt-8">
            <a
              href={linkHref}
              class="inline-flex items-center rounded-full border border-neutral-600 px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:border-white hover:bg-white hover:text-neutral-900"
            >
              {linkText}
            </a>
          </div>
        )}
      </div>

      {/* Right column — Video grid with expand-on-hover */}
      {videos.length > 0 && (
        <div class="video-expand-grid" style="display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 8px; position: relative; aspect-ratio: 4/3;">
          {videos.map((video, i) => (
            <div
              class="video-expand-item relative overflow-hidden rounded-lg cursor-pointer"
              data-video-src={video.videoSrc}
              data-index={i}
            >
              {video.image && (
                <img
                  src={video.image}
                  alt={video.title || ''}
                  class="absolute inset-0 h-full w-full object-cover video-expand-img"
                  loading="lazy"
                />
              )}
              <div class="absolute inset-0 bg-black/30 transition-opacity duration-300 video-expand-overlay" />
              {/* Play button */}
              <div class="absolute inset-0 flex items-center justify-center video-expand-play" style="transition: opacity 0.3s ease;">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/80 shadow-lg sm:h-12 sm:w-12">
                  <svg class="ml-0.5 h-4 w-4 text-neutral-900 sm:h-5 sm:w-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
              {/* Title */}
              {video.title && (
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 p-3 z-10">
                  <p class="text-xs font-semibold text-white sm:text-sm">{video.title}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .video-expand-item {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
  }

  .video-expand-grid:hover .video-expand-item {
    opacity: 0.4;
  }

  .video-expand-grid .video-expand-item:hover {
    opacity: 1;
    grid-column: 1 / -1;
    grid-row: 1 / -1;
    z-index: 10;
    border-radius: 0.75rem;
  }

  .video-expand-item:hover .video-expand-overlay {
    opacity: 0.1;
  }

  .video-expand-item:hover .video-expand-play {
    opacity: 0;
  }
</style>

<script>
  // Hover → play video, expand item
  document.querySelectorAll('.video-expand-item').forEach((el) => {
    const htmlEl = el as HTMLElement;
    const src = htmlEl.dataset.videoSrc;
    if (!src) return;

    let video: HTMLVideoElement | null = null;

    el.addEventListener('mouseenter', () => {
      if (!video) {
        video = document.createElement('video');
        video.muted = true;
        video.loop = true;
        video.playsInline = true;
        video.className = 'absolute inset-0 h-full w-full object-cover z-[2]';
        video.style.transition = 'opacity 0.3s ease';
        video.style.opacity = '0';
        video.src = src;
        const img = htmlEl.querySelector('.video-expand-img');
        if (img) img.after(video);
      }
      video.currentTime = 0;
      video.play().catch(() => {});
      requestAnimationFrame(() => { if (video) video.style.opacity = '1'; });
    });

    el.addEventListener('mouseleave', () => {
      if (video) { video.pause(); video.style.opacity = '0'; }
    });
  });
</script>
