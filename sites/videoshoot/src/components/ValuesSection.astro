---
import VideoThumbnail from './VideoThumbnail.astro';

export interface ValueItem {
  number: string;
  title: string;
}

export interface VideoItem {
  image?: string;
  title?: string;
  videoSrc?: string;
  reelUrl?: string;
}

export interface Props {
  heading: string;
  description: string;
  linkText?: string;
  linkHref?: string;
  values: ValueItem[];
  videos?: VideoItem[];
  class?: string;
}

const { heading, description, linkText, linkHref, values, videos = [], class: className } = Astro.props;
---

<section class:list={['bg-neutral-950 py-20 sm:py-28', className]}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-start lg:gap-16">
      {/* Left column — Statement + values */}
      <div>
        <h2 class="text-2xl font-bold leading-snug text-white sm:text-3xl lg:text-4xl">
          {heading}
        </h2>
        <p class="mt-6 text-base leading-relaxed text-neutral-400">
          {description}
        </p>
        {linkText && linkHref && (
          <a
            href={linkHref}
            class="mt-8 inline-flex items-center rounded-full border border-neutral-600 px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:border-white hover:bg-white hover:text-neutral-900"
          >
            {linkText}
          </a>
        )}

        {/* Numbered values */}
        <div class="mt-12 space-y-6 border-t border-neutral-800 pt-8">
          {values.map((v) => (
            <div class="flex items-start gap-4">
              <span class="text-2xl font-bold text-neutral-600">{v.number}</span>
              <h3 class="text-lg font-semibold text-white">{v.title}</h3>
            </div>
          ))}
        </div>
      </div>

      {/* Right column — Video thumbnails grid */}
      {videos.length > 0 && (
        <div class="grid grid-cols-2 gap-4">
          {videos.map((video) => (
            <VideoThumbnail
              image={video.image}
              title={video.title}
              videoSrc={video.videoSrc}
              reelUrl={video.reelUrl}
              class="aspect-[4/3]"
            />
          ))}
        </div>
      )}
    </div>
  </div>
</section>
