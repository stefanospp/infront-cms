---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  href: string;
  number?: string;
  class?: string;
}

const { title, description, tags, href, number, class: className } = Astro.props;
---

<a
  href={href}
  class:list={[
    'group relative block overflow-hidden rounded-2xl border border-neutral-200 bg-white p-8 transition-all duration-300 hover:border-neutral-300 hover:shadow-xl hover:-translate-y-1 sm:p-10',
    className,
  ]}
>
  {/* Large decorative number */}
  {number && (
    <span class="absolute -top-4 -right-2 text-[8rem] font-bold leading-none text-neutral-100 select-none transition-colors duration-300 group-hover:text-neutral-200 sm:text-[10rem]">
      {number}
    </span>
  )}

  <div class="relative z-10">
    {/* Title with arrow */}
    <div class="flex items-start justify-between gap-4">
      <h3 class="text-2xl font-bold text-neutral-900 sm:text-3xl">{title}</h3>
      <div class="mt-2 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-neutral-100 transition-all duration-300 group-hover:bg-neutral-900 group-hover:text-white">
        <svg class="h-5 w-5 text-neutral-400 transition-all duration-300 group-hover:text-white group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
        </svg>
      </div>
    </div>

    <p class="mt-4 max-w-md text-base leading-relaxed text-neutral-600">{description}</p>

    {/* Tags */}
    <div class="mt-6 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="inline-flex items-center rounded-full bg-neutral-100 px-3.5 py-1.5 text-xs font-medium text-neutral-700 transition-colors duration-300 group-hover:bg-neutral-200">
          {tag}
        </span>
      ))}
    </div>
  </div>

  {/* Bottom accent line */}
  <div class="absolute bottom-0 left-0 h-1 w-0 bg-neutral-900 transition-all duration-500 group-hover:w-full" />
</a>
