---
export interface TestimonialItem {
  quote: string;
  author: string;
  role?: string;
  image?: string;
}

export interface Props {
  testimonials: TestimonialItem[];
  class?: string;
}

const { testimonials, class: className } = Astro.props;
---

<section class:list={['bg-white py-20 sm:py-28', className]}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-neutral-500">Testimonials</p>
        <h2 class="mt-2 text-3xl font-bold text-neutral-900 sm:text-4xl">Clients about our work.</h2>
      </div>

      {testimonials.length > 1 && (
        <div class="hidden items-center gap-3 sm:flex">
          <button
            type="button"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 bg-white text-neutral-600 transition-colors hover:bg-neutral-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
            aria-label="Previous testimonial"
            data-testimonial-prev
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button
            type="button"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 bg-white text-neutral-600 transition-colors hover:bg-neutral-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
            aria-label="Next testimonial"
            data-testimonial-next
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      )}
    </div>

    <div class="flex snap-x snap-mandatory gap-8 overflow-x-auto scrollbar-hide pb-4" data-testimonial-track>
      {testimonials.map((t, i) => (
        <div class="w-full flex-shrink-0 snap-center sm:w-[calc(100%-2rem)]" role="group" aria-label={`Testimonial ${i + 1} of ${testimonials.length}`}>
          <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:gap-12">
            {/* Portrait */}
            {t.image && (
              <div class="flex-shrink-0">
                <div class="relative">
                  <img
                    src={t.image}
                    alt={t.author}
                    class="h-64 w-48 rounded-lg object-cover sm:h-80 sm:w-60"
                    loading="lazy"
                  />
                  <div class="absolute bottom-0 left-0 right-0 rounded-b-lg bg-gradient-to-t from-black/70 p-4">
                    <p class="font-semibold text-white">{t.author}</p>
                    {t.role && <p class="text-sm text-neutral-300">{t.role}</p>}
                  </div>
                </div>
              </div>
            )}

            {/* Quote */}
            <div class="flex flex-col justify-center">
              <svg class="mb-6 h-8 w-8 text-neutral-300" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
                <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
              </svg>
              <blockquote class="text-xl font-semibold leading-relaxed text-neutral-900 sm:text-2xl">
                &ldquo;{t.quote}&rdquo;
              </blockquote>
              {!t.image && (
                <div class="mt-6">
                  <p class="font-semibold text-neutral-900">{t.author}</p>
                  {t.role && <p class="text-sm text-neutral-500">{t.role}</p>}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-testimonial-track]').forEach((track) => {
    const wrapper = track.closest('section');
    const prevBtn = wrapper?.querySelector('[data-testimonial-prev]');
    const nextBtn = wrapper?.querySelector('[data-testimonial-next]');

    if (!track || !wrapper) return;

    function scrollByOne(direction: 1 | -1) {
      const el = track as HTMLElement;
      const slideWidth = el.firstElementChild
        ? (el.firstElementChild as HTMLElement).offsetWidth + 32
        : el.offsetWidth;
      el.scrollBy({ left: direction * slideWidth, behavior: 'smooth' });
    }

    prevBtn?.addEventListener('click', () => scrollByOne(-1));
    nextBtn?.addEventListener('click', () => scrollByOne(1));
  });
</script>
