---
import "../styles/global.css";
import VideoLayout from '../components/VideoLayout.astro';
import ContactForm from '@agency/ui/islands/ContactForm';
import config from '../../site.config';
---

<VideoLayout
  title="Contact"
  description="Let's create something amazing together."
  config={config}
>
  {/* Full-screen dark cinematic contact section */}
  <section class="relative -mt-[72px] min-h-screen bg-neutral-950">
    {/* Background image */}
    <img
      src="/images/contact-bg.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/70" />

    {/* Content */}
    <div class="relative z-10 mx-auto flex min-h-screen max-w-7xl flex-col justify-center px-4 pt-24 pb-12 sm:px-6 sm:pt-32 sm:pb-16 lg:px-8">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-20">
        {/* Left — info */}
        <div class="flex flex-col justify-center">
          <p class="text-sm font-medium uppercase tracking-widest text-neutral-400">
            Lights, Camera, Connect!
          </p>
          <h1 class="mt-4 text-4xl font-bold leading-tight text-white sm:text-5xl">
            Let&rsquo;s create something amazing together.
          </h1>

          <div class="mt-12 space-y-6">
            <div class="flex items-start gap-4">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <p class="text-neutral-300">
                {config.contact.address.street}, {config.contact.address.city}, {config.contact.address.country}
              </p>
            </div>
            <div class="flex items-center gap-4">
              <svg class="h-5 w-5 flex-shrink-0 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <a href={`tel:${config.contact.phone}`} class="text-neutral-300 transition-colors hover:text-white">
                {config.contact.phone}
              </a>
            </div>
            <div class="flex items-center gap-4">
              <svg class="h-5 w-5 flex-shrink-0 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              <a href={`mailto:${config.contact.email}`} class="text-neutral-300 transition-colors hover:text-white">
                {config.contact.email}
              </a>
            </div>
          </div>
        </div>

        {/* Right — contact form */}
        <div class="flex flex-col justify-center">
          <ContactForm
            client:visible
            endpoint="/api/contact"
            className="contact-form-dark"
          />
        </div>
      </div>
    </div>
  </section>
</VideoLayout>

<style is:global>
  /* Dark theme overrides for the contact form */
  .contact-form-dark label {
    color: #a3a3a3 !important;
  }
  .contact-form-dark input,
  .contact-form-dark textarea {
    background: transparent !important;
    border-color: #404040 !important;
    color: #ffffff !important;
  }
  .contact-form-dark input::placeholder,
  .contact-form-dark textarea::placeholder {
    color: #737373 !important;
  }
  .contact-form-dark input:focus,
  .contact-form-dark textarea:focus {
    border-color: #ffffff !important;
    box-shadow: none !important;
    outline: none !important;
  }
  .contact-form-dark button[type="submit"] {
    background: #ffffff !important;
    color: #171717 !important;
    border-radius: 9999px !important;
  }
  .contact-form-dark button[type="submit"]:hover {
    background: #f5f5f5 !important;
  }
</style>
