---
import "../styles/global.css";
import VideoLayout from '../components/VideoLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import config from '../../site.config';

const services = [
  {
    title: 'Cinematic Travel Content',
    description: 'Stunning cinematic reels and videos that showcase destinations, resorts, and experiences with a storytelling-first approach.',
    tags: ['Travel Reels', 'Destination Films', 'Resort Showcases', 'Drone Footage'],
    href: '/services',
  },
  {
    title: 'Brand Collaborations',
    description: 'Authentic content creation for travel brands, hotels, and lifestyle companies. Reaching engaged audiences across Instagram and social platforms.',
    tags: ['Influencer Campaigns', 'Sponsored Content', 'Brand Stories', 'UGC'],
    href: '/services',
  },
  {
    title: 'Content Creation & Editing',
    description: 'End-to-end video production from concept to final cut. Professional editing, color grading, and sound design that brings your vision to life.',
    tags: ['Video Editing', 'Color Grading', 'Aerial & Drone', 'Social Media'],
    href: '/services',
  },
  {
    title: 'Aerial & Drone Filming',
    description: 'Breathtaking aerial perspectives from Bali, Indonesia, and beyond. Cinematic drone footage that adds depth and scale to any project.',
    tags: ['Drone Cinematography', 'Aerial Tours', 'FPV Filming', 'Landscape & Nature'],
    href: '/services',
  },
  {
    title: 'Social Media Management',
    description: 'Content strategy and creation for Instagram, TikTok, and YouTube. Growing your audience with consistent, engaging visual content.',
    tags: ['Instagram Reels', 'TikTok', 'YouTube Shorts', 'Content Strategy'],
    href: '/services',
  },
  {
    title: 'Destination Marketing',
    description: 'Helping tourism boards, resorts, and travel companies attract visitors through compelling visual storytelling and influencer reach.',
    tags: ['Tourism Campaigns', 'Hotel Content', 'Experience Films', 'Cultural Stories'],
    href: '/services',
  },
];
---

<VideoLayout
  title="Services"
  description="Bringing stories to life with cinematic precision."
  config={config}
>
  {/* Hero */}
  <Hero
    variant="minimal"
    eyebrow="What I offer"
    heading="From concept to final cut, I bring your vision to life."
    subheading="Whether it's a travel reel, brand collaboration, or destination campaign — I create cinematic content that captures attention and tells authentic stories."
    ctaText="Get in touch"
    ctaHref="/contact"
  />

  {/* Featured image with testimonial */}
  <section class="bg-white pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <img
          src="/images/services-hero.jpg"
          alt="Professional video production setup"
          class="h-[400px] w-full rounded-xl object-cover sm:h-[500px]"
          loading="lazy"
        />
        <div class="absolute bottom-3 right-3 max-w-[calc(100%-1.5rem)] rounded-xl bg-white/95 p-4 shadow-lg backdrop-blur-sm sm:bottom-6 sm:right-6 sm:max-w-sm sm:p-6">
          <div class="mb-3 flex items-center gap-3">
            <img
              src="/images/testimonial-2.jpg"
              alt="Rebeca Ma"
              class="h-10 w-10 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p class="text-sm font-semibold text-neutral-900">Rebeca Ma</p>
              <p class="text-xs text-neutral-500">Content Creator</p>
            </div>
          </div>
          <p class="text-sm leading-relaxed text-neutral-700">
            &ldquo;Their creative vision, attention to detail, and ability to tell a compelling story exceeded our expectations.&rdquo;
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Services Grid */}
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-4xl font-bold text-neutral-900 sm:text-5xl">Our services.</h2>

      <div class="grid grid-cols-1 gap-0 md:grid-cols-2 md:gap-x-12">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            tags={service.tags}
            href={service.href}
          />
        ))}
      </div>
    </div>
  </section>
</VideoLayout>
