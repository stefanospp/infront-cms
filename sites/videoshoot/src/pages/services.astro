---
import "../styles/global.css";
import VideoLayout from '../components/VideoLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import config from '../../site.config';

const services = [
  {
    title: 'Video Production',
    description: 'From concept to final cut, I handle the entire production process. Scripting, filming, editing — delivering polished content that tells your story.',
    tags: ['Commercials', 'Brand Films', 'Short Films', 'Reels'],
    href: '/contact',
  },
  {
    title: 'Creative Direction',
    description: 'I work closely with you to develop unique concepts and visual narratives that resonate with your audience and elevate your brand.',
    tags: ['Concept Development', 'Storyboarding', 'Art Direction', 'Brand Identity'],
    href: '/contact',
  },
  {
    title: 'Content Creation',
    description: 'Professional content for social media, websites, and campaigns. Optimized for engagement and crafted to stand out in crowded feeds.',
    tags: ['Social Media', 'Instagram Reels', 'YouTube', 'Campaign Content'],
    href: '/contact',
  },
  {
    title: 'Aerial & Drone Filming',
    description: 'Cinematic drone footage that adds depth, scale, and a unique perspective to any project. Breathtaking aerial shots for any occasion.',
    tags: ['Drone Cinematography', 'Aerial Shots', 'FPV Filming', 'Landscape'],
    href: '/contact',
  },
  {
    title: 'Post-Production & Editing',
    description: 'Expert editing, color grading, motion graphics, and sound design. Every frame polished to perfection for maximum impact.',
    tags: ['Video Editing', 'Color Grading', 'Motion Graphics', 'Sound Design'],
    href: '/contact',
  },
  {
    title: 'Brand Partnerships',
    description: 'Authentic content creation for brands and businesses. Reaching engaged audiences through compelling visual storytelling across platforms.',
    tags: ['Sponsored Content', 'Brand Stories', 'UGC', 'Campaign Content'],
    href: '/contact',
  },
];
---

<VideoLayout
  title="Services"
  description="Bringing stories to life with cinematic precision."
  config={config}
>
  {/* Hero */}
  <Hero
    variant="minimal"
    eyebrow="What I offer"
    heading="From concept to final cut, I bring your vision to life."
    subheading="Whether it's a brand film, social media content, or a creative campaign — I produce high-quality video that captures attention and delivers results."
    ctaText="Get in touch"
    ctaHref="/contact"
  />

  {/* Featured image with testimonial */}
  <section class="bg-white pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <img
          src="/images/services-hero.jpg"
          alt="Professional video production setup"
          class="h-[400px] w-full rounded-xl object-cover sm:h-[500px]"
          loading="lazy"
        />
        <div class="absolute bottom-3 right-3 max-w-[calc(100%-1.5rem)] rounded-xl bg-white/95 p-4 shadow-lg backdrop-blur-sm sm:bottom-6 sm:right-6 sm:max-w-sm sm:p-6">
          <div class="mb-3 flex items-center gap-3">
            <img
              src="/images/testimonial-2.jpg"
              alt="Rebeca Ma"
              class="h-10 w-10 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p class="text-sm font-semibold text-neutral-900">Rebeca Ma</p>
              <p class="text-xs text-neutral-500">Content Creator</p>
            </div>
          </div>
          <p class="text-sm leading-relaxed text-neutral-700">
            &ldquo;Their creative vision, attention to detail, and ability to tell a compelling story exceeded our expectations.&rdquo;
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Services Grid */}
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-4xl font-bold text-neutral-900 sm:text-5xl">My services.</h2>

      <div class="grid grid-cols-1 gap-0 md:grid-cols-2 md:gap-x-12">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            tags={service.tags}
            href={service.href}
          />
        ))}
      </div>
    </div>
  </section>
</VideoLayout>
