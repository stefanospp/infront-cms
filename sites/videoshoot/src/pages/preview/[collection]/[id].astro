---
import "../../../styles/global.css";
import VideoLayout from '../../../components/VideoLayout.astro';
import Hero from '../../../components/Hero.astro';
import HeroInteractive from '../../../components/HeroInteractive';
import ValuesSection from '../../../components/ValuesSection.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import config from '../../../../site.config';

export const prerender = false;

const PREVIEW_TOKEN = import.meta.env.PREVIEW_TOKEN || 'preview-secret';
const DIRECTUS_URL = import.meta.env.DIRECTUS_URL;
const DIRECTUS_TOKEN = import.meta.env.DIRECTUS_TOKEN;

const { collection, id } = Astro.params;
const token = Astro.url.searchParams.get('token');

if (token !== PREVIEW_TOKEN) {
  return new Response('Unauthorized', { status: 401 });
}

if (!DIRECTUS_URL) {
  return new Response('CMS not configured', { status: 500 });
}

// Fetch item directly by ID via REST — no status filter, shows drafts
async function fetchItem(coll: string, itemId: string) {
  const headers: Record<string, string> = { 'Content-Type': 'application/json' };
  if (DIRECTUS_TOKEN) headers['Authorization'] = `Bearer ${DIRECTUS_TOKEN}`;
  const res = await fetch(`${DIRECTUS_URL}/items/${coll}/${itemId}`, { headers });
  if (!res.ok) return null;
  const json = await res.json();
  return json.data;
}

const item = await fetchItem(collection!, id!);
if (!item) {
  return new Response('Item not found', { status: 404 });
}

const pageTitle = item.title || item.heading || item.name || 'Preview';

// Allow Directus to embed this page in an iframe
Astro.response.headers.set('X-Frame-Options', 'ALLOWALL');
Astro.response.headers.set('Content-Security-Policy', "frame-ancestors https://cms.nikolaspetrou.com");
---

<VideoLayout title={`Preview: ${pageTitle}`} description={item.subtitle || ''} config={config}>
  {/* Preview banner */}
  <div class="fixed top-0 left-0 right-0 z-[9999] bg-amber-400 px-4 py-1.5 text-center shadow-md">
    <p class="text-xs font-semibold text-amber-900">Draft Preview — Not live yet</p>
  </div>

  {/* ============================================================ */}
  {/* PROJECTS — mirrors works/[slug].astro exactly                */}
  {/* ============================================================ */}
  {collection === 'projects' && (
    <>
      <Hero
        variant="minimal"
        eyebrow={`${item.category || ''} · ${item.year || ''}`}
        heading={item.title}
        subheading={item.subtitle}
      />

      <section class="bg-white pb-12">
        <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
          <div class="relative overflow-hidden rounded-xl bg-neutral-900" style="aspect-ratio: 16/9;">
            <video
              controls
              playsinline
              preload="metadata"
              class="absolute inset-0 h-full w-full object-cover"
              poster={item.image || ''}
            >
              <source src={item.video_url || ''} type="video/mp4" />
            </video>
          </div>
        </div>
      </section>

      <section class="bg-white py-12 sm:py-16">
        <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">
            <div class="lg:col-span-1">
              <div class="sticky top-24 space-y-6">
                {item.client && (
                  <div>
                    <p class="text-xs font-medium uppercase tracking-widest text-neutral-500">Client</p>
                    <p class="mt-1 text-base font-semibold text-neutral-900">{item.client}</p>
                  </div>
                )}
                {item.year && (
                  <div>
                    <p class="text-xs font-medium uppercase tracking-widest text-neutral-500">Year</p>
                    <p class="mt-1 text-base font-semibold text-neutral-900">{item.year}</p>
                  </div>
                )}
                {item.category && (
                  <div>
                    <p class="text-xs font-medium uppercase tracking-widest text-neutral-500">Category</p>
                    <p class="mt-1 text-base font-semibold text-neutral-900">{item.category}</p>
                  </div>
                )}
                <div class="pt-4">
                  <a
                    href="/contact"
                    class="inline-flex items-center rounded-full bg-neutral-900 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-neutral-800"
                  >
                    Start a project like this
                  </a>
                </div>
              </div>
            </div>
            <div class="lg:col-span-2">
              {item.description && (
                <div class="prose prose-lg max-w-none text-neutral-700" set:html={item.description} />
              )}
            </div>
          </div>
        </div>
      </section>

      <section class="bg-neutral-50 py-12">
        <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
          <a href="/works" class="inline-flex items-center gap-2 text-sm font-semibold text-neutral-600 transition-colors hover:text-neutral-900">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back to all projects
          </a>
        </div>
      </section>
    </>
  )}

  {/* ============================================================ */}
  {/* HERO — mirrors the homepage hero section                     */}
  {/* ============================================================ */}
  {collection === 'hero' && (
    <HeroInteractive
      client:load
      eyebrow={item.eyebrow || ''}
      heading={item.heading || ''}
      subheading={item.subheading || ''}
      ctaText={item.cta_text || 'Get in touch'}
      ctaHref={item.cta_href || '/contact'}
      secondaryCtaText={item.secondary_cta_text || ''}
      secondaryCtaHref={item.secondary_cta_href || ''}
      backgroundVideo={item.background_video || ''}
      backgroundPoster="/images/hero-bg.jpg"
      projects={[]}
    />
  )}

  {/* ============================================================ */}
  {/* ABOUT — mirrors about.astro                                  */}
  {/* ============================================================ */}
  {collection === 'about' && (
    <>
      <Hero
        variant="minimal"
        eyebrow="The story behind the lens."
        heading={item.heading || 'About'}
        subheading={item.subheading || ''}
        ctaText={item.cta_text || 'Get in touch'}
        ctaHref="/contact"
      />

      <section class="bg-white pb-20">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="relative">
            <img
              src="/images/about-hero.jpg"
              alt="Nikolas Petrou filming on location"
              class="h-[400px] w-full rounded-xl object-cover sm:h-[500px]"
              loading="lazy"
            />
          </div>
        </div>
      </section>

      <ValuesSection
        heading={item.values_heading || ''}
        description={item.values_description || ''}
        linkText="Work with me"
        linkHref="/contact"
        values={[
          { number: '01.', title: 'Creativity Without Limits' },
          { number: '02.', title: 'Authentic Storytelling' },
          { number: '03.', title: 'Excellence in Every Frame' },
          { number: '04.', title: 'Passion-Driven Work' },
        ]}
        videos={[
          { image: '/images/project-1.jpg', title: 'Visual Stories' },
          { image: '/images/project-2.jpg', title: 'Creative Direction' },
          { image: '/images/project-3.jpg', title: 'Cinematic Quality' },
          { image: '/images/project-4.jpg', title: 'Brand Content' },
        ]}
      />
    </>
  )}

  {/* ============================================================ */}
  {/* SERVICES — mirrors services.astro service card               */}
  {/* ============================================================ */}
  {collection === 'services' && (
    <>
      <Hero
        variant="minimal"
        eyebrow="What I offer"
        heading="From concept to final cut, I bring your vision to life."
        subheading="Whether it's a brand film, social media content, or a creative campaign — I produce high-quality video that captures attention and delivers results."
        ctaText="Get in touch"
        ctaHref="/contact"
      />

      <section class="bg-white py-20 sm:py-28">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="mb-12 text-4xl font-bold text-neutral-900 sm:text-5xl">My services.</h2>
          <div class="grid grid-cols-1 gap-0 md:grid-cols-2 md:gap-x-12">
            <ServiceCard
              title={item.title}
              description={item.description || ''}
              tags={item.tags || []}
              href="/contact"
            />
          </div>
        </div>
      </section>
    </>
  )}

  {/* ============================================================ */}
  {/* TESTIMONIALS — quote card matching VideoTestimonials style   */}
  {/* ============================================================ */}
  {collection === 'testimonials' && (
    <>
      <Hero variant="minimal" eyebrow="Client testimonial" heading={item.name} />

      <section class="bg-neutral-950 py-20">
        <div class="mx-auto max-w-2xl px-4">
          <div class="text-center">
            <svg class="mx-auto mb-6 h-10 w-10 text-white/30" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <blockquote class="text-xl font-light leading-relaxed text-white sm:text-2xl">
              {item.quote}
            </blockquote>
            <div class="mt-8">
              <p class="text-sm font-semibold text-white">{item.name}</p>
              {item.role && <p class="mt-1 text-sm text-white/60">{item.role}</p>}
            </div>
          </div>
          {item.video_url && (
            <div class="mt-10">
              <video controls class="w-full rounded-xl" src={item.video_url} />
            </div>
          )}
        </div>
      </section>
    </>
  )}

  {/* ============================================================ */}
  {/* REELS — reel link card                                       */}
  {/* ============================================================ */}
  {collection === 'reels' && (
    <>
      <Hero variant="minimal" eyebrow="Instagram reel" heading="Reel Preview" />

      <section class="bg-white py-16">
        <div class="mx-auto max-w-md px-4 text-center">
          <div class="rounded-2xl bg-neutral-50 p-8">
            <p class="text-sm font-medium uppercase tracking-widest text-neutral-500">Instagram Reel</p>
            <a href={item.url} target="_blank" rel="noopener" class="mt-4 block text-lg font-semibold text-blue-600 underline break-all">
              {item.url}
            </a>
            {item.date_label && <p class="mt-3 text-sm text-neutral-500">{item.date_label}</p>}
          </div>
        </div>
      </section>
    </>
  )}

  {/* ============================================================ */}
  {/* SITE SETTINGS — overview of all settings                     */}
  {/* ============================================================ */}
  {collection === 'site_settings' && (
    <>
      <Hero variant="minimal" eyebrow="Site settings" heading={item.name || 'Settings'} subheading={item.tagline || ''} />

      <section class="bg-white py-16">
        <div class="mx-auto max-w-2xl px-4">
          <div class="space-y-6 rounded-2xl bg-neutral-50 p-8">
            {item.email && (
              <div>
                <p class="text-xs font-medium uppercase tracking-widest text-neutral-500">Email</p>
                <p class="mt-1 text-base text-neutral-900">{item.email}</p>
              </div>
            )}
            {item.seo_title && (
              <div>
                <p class="text-xs font-medium uppercase tracking-widest text-neutral-500">SEO Title</p>
                <p class="mt-1 text-base text-neutral-900">{item.seo_title}</p>
              </div>
            )}
            {item.seo_description && (
              <div>
                <p class="text-xs font-medium uppercase tracking-widest text-neutral-500">SEO Description</p>
                <p class="mt-1 text-base text-neutral-700">{item.seo_description}</p>
              </div>
            )}
            {item.instagram_url && (
              <div>
                <p class="text-xs font-medium uppercase tracking-widest text-neutral-500">Instagram</p>
                <a href={item.instagram_url} class="mt-1 block text-base text-blue-600">{item.instagram_url}</a>
              </div>
            )}
            {item.facebook_url && (
              <div>
                <p class="text-xs font-medium uppercase tracking-widest text-neutral-500">Facebook</p>
                <a href={item.facebook_url} class="mt-1 block text-base text-blue-600">{item.facebook_url}</a>
              </div>
            )}
          </div>
        </div>
      </section>
    </>
  )}
</VideoLayout>
