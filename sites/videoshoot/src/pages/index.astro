---
import "../styles/global.css";
import VideoLayout from '../components/VideoLayout.astro';
import Hero from '../components/Hero.astro';
import HeroInteractive from '../components/HeroInteractive';
import ReelsShowcase from '../components/ReelsShowcase.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import ValuesSection from '../components/ValuesSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import HorizontalScroller from '../components/HorizontalScroller.astro';
import ProjectCard from '../components/ProjectCard.astro';
import config from '../../site.config';

const projects = [
  { title: 'Stay True to Yourself', video: '/images/pv1.mp4', poster: '/images/project-1.jpg' },
  { title: 'Madeira', video: '/images/pv2.mp4', poster: '/images/project-2.jpg' },
  { title: 'Love Cyprus', video: '/images/pv3.mp4', poster: '/images/project-3.jpg' },
  { title: 'Mountain Adventures', video: '/images/pv4.mp4', poster: '/images/project-4.jpg' },
];

const testimonials = [
  {
    quote: 'Nikolas has an incredible eye for storytelling. He understood our vision instantly and delivered content that exceeded every expectation. Highly recommend.',
    author: 'Satisfied Client',
    role: 'Brand Partnership',
    image: '/images/testimonial-1.jpg',
  },
  {
    quote: 'Professional, creative, and incredibly easy to work with. The final videos were stunning — exactly what we needed to elevate our brand presence online.',
    author: 'Happy Client',
    role: 'Content Campaign',
    image: '/images/testimonial-2.jpg',
  },
  {
    quote: 'The quality of Nikolas\'s work speaks for itself. His reels consistently perform well and his attention to detail in every frame is unmatched.',
    author: 'Returning Client',
    role: 'Ongoing Collaboration',
    image: '/images/testimonial-3.jpg',
  },
];

const values = [
  { number: '01.', title: 'Creativity Without Limits' },
  { number: '02.', title: 'Authentic Storytelling' },
  { number: '03.', title: 'Excellence in Every Frame' },
  { number: '04.', title: 'Passion-Driven Work' },
];

const valueVideos = [
  { image: '/images/project-1.jpg', title: 'Turquoise Waters', videoSrc: 'https://videos.pexels.com/video-files/32860581/14006554_640_360_60fps.mp4' },
  { image: '/images/project-2.jpg', title: 'Underwater World', videoSrc: 'https://videos.pexels.com/video-files/36473015/15465933_640_360_30fps.mp4' },
  { image: '/images/project-3.jpg', title: 'Bali Temples', videoSrc: 'https://videos.pexels.com/video-files/36473011/15466001_640_360_30fps.mp4' },
  { image: '/images/project-4.jpg', title: 'Island Life', videoSrc: 'https://videos.pexels.com/video-files/36473811/15466323_640_360_30fps.mp4' },
];

const services = [
  {
    title: 'Video Production',
    description: 'From concept to final cut, I handle the entire production process. Scripting, filming, editing — delivering polished content that tells your story.',
    tags: ['Commercials', 'Brand Films', 'Short Films', 'Reels'],
    href: '/services',
  },
  {
    title: 'Creative Direction',
    description: 'I work closely with you to develop unique concepts and visual narratives that resonate with your audience and elevate your brand.',
    tags: ['Concept Development', 'Storyboarding', 'Art Direction', 'Brand Identity'],
    href: '/services',
  },
  {
    title: 'Content Creation',
    description: 'Professional content for social media, websites, and campaigns. Optimized for engagement and crafted to stand out in crowded feeds.',
    tags: ['Social Media', 'Instagram Reels', 'YouTube', 'Campaign Content'],
    href: '/services',
  },
];

const works = [
  { title: 'Stay True to Yourself', subtitle: 'Cinematic Self-Expression', image: '/images/project-1.jpg', videoSrc: 'https://videos.pexels.com/video-files/5544413/5544413-sd_640_360_24fps.mp4' },
  { title: 'Coastal Stories', subtitle: 'Where Land Meets Sea', image: '/images/project-2.jpg', videoSrc: 'https://videos.pexels.com/video-files/6981425/6981425-sd_640_360_25fps.mp4' },
  { title: 'Aerial Perspectives', subtitle: 'A View From Above', image: '/images/project-3.jpg', videoSrc: 'https://videos.pexels.com/video-files/4232189/4232189-sd_640_360_24fps.mp4' },
  { title: 'Mountain Adventures', subtitle: 'Exploring New Heights', image: '/images/project-4.jpg', videoSrc: 'https://videos.pexels.com/video-files/34085713/14457217_640_360_60fps.mp4' },
  { title: 'Underwater World', subtitle: 'Beneath the Surface', image: '/images/project-5.jpg', videoSrc: 'https://videos.pexels.com/video-files/36473015/15465933_640_360_30fps.mp4' },
  { title: 'Golden Hour', subtitle: 'Chasing the Light', image: '/images/project-6.jpg', videoSrc: 'https://videos.pexels.com/video-files/36473005/15465944_640_360_30fps.mp4' },
];

---

<VideoLayout
  title={config.seo.defaultTitle}
  description={config.seo.defaultDescription}
  config={config}
>
  {/* Interactive Hero */}
  <HeroInteractive
      client:load
      eyebrow="Videographer · Content Creator"
      heading="Stay true to yourself."
      subheading="High-quality video content that engages, inspires, and tells stories worth sharing."
      ctaText="Get in touch"
      ctaHref="/contact"
      secondaryCtaText="Watch showreel"
      secondaryCtaHref="/works"
      backgroundVideo="https://videos.pexels.com/video-files/5933986/5933986-sd_960_506_24fps.mp4"
      backgroundPoster="/images/hero-bg.jpg"
      projects={projects}
  />

  {/* Values / About Section */}
  <ValuesSection
    heading="I create visual content that captures moments and tells stories that move people."
    description="Every project is an opportunity to push creative boundaries. I turn ideas into powerful visual stories that leave a lasting impact and deliver real results."
    linkText="About me"
    linkHref="/about"
    values={values}
    videos={valueVideos}
  />

  {/* Services Section */}
  <section class="bg-neutral-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 flex items-end justify-between">
        <div>
          <p class="text-sm font-medium uppercase tracking-widest text-neutral-500">What I offer</p>
          <h2 class="mt-2 text-3xl font-bold text-neutral-900 sm:text-4xl lg:text-5xl">My services.</h2>
        </div>
        <a
          href="/services"
          class="hidden items-center gap-2 rounded-full bg-neutral-900 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-neutral-800 sm:inline-flex"
        >
          View all
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service, i) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            tags={service.tags}
            href={service.href}
            number={String(i + 1).padStart(2, '0')}
          />
        ))}
      </div>
    </div>
  </section>

  {/* Latest Works */}
  <section class="bg-neutral-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="text-3xl font-bold text-neutral-900 sm:text-4xl">Latest works.</h2>
      </div>

      <HorizontalScroller>
        {works.map((work) => (
          <div class="w-64 flex-shrink-0 snap-start sm:w-72 md:w-80">
            <ProjectCard
              title={work.title}
              subtitle={work.subtitle}
              image={work.image}
              videoSrc={work.videoSrc}
            />
          </div>
        ))}
      </HorizontalScroller>
    </div>
  </section>

  {/* Instagram Reels */}
  <ReelsShowcase
    eyebrow="@nikolaspetrouu"
    heading="Follow the journey."
    reelIds={['C14N94RKhK_', 'DFM7L9Uugq9', 'CjA5aKVguYE', 'DDBQo9sTKR0', 'DB_ZIJTh3Fe']}
  />

  {/* Testimonials */}
  <TestimonialCarousel testimonials={testimonials} />
</VideoLayout>
