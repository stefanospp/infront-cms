---
import "../styles/global.css";
import VideoLayout from '../components/VideoLayout.astro';
import Hero from '../components/Hero.astro';
import HeroInteractive from '../components/HeroInteractive';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import ValuesSection from '../components/ValuesSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import HorizontalScroller from '../components/HorizontalScroller.astro';
import ProjectCard from '../components/ProjectCard.astro';
import config from '../../site.config';

const projects = [
  { title: 'Stay True to Yourself', video: '/images/pv1.mp4', poster: '/images/project-1.jpg' },
  { title: 'Madeira', video: '/images/pv2.mp4', poster: '/images/project-2.jpg' },
  { title: 'Love Cyprus', video: '/images/pv3.mp4', poster: '/images/project-3.jpg' },
  { title: 'Mountain Adventures', video: '/images/pv4.mp4', poster: '/images/project-4.jpg' },
];

const testimonials = [
  {
    quote: 'Nikolas captured our resort in a way we never imagined. His drone work and editing turned our property into a cinematic experience that boosted our bookings overnight.',
    author: 'Maya Suryani',
    role: 'Resort Owner, Bali',
    image: '/images/testimonial-1.jpg',
  },
  {
    quote: 'Working with Nikolas was effortless. He understood the vibe of our brand instantly and delivered content that truly resonated with our audience. A real creative force.',
    author: 'Luca Martins',
    role: 'Travel Brand Director',
    image: '/images/testimonial-2.jpg',
  },
  {
    quote: 'The reels Nikolas created for our destination campaign reached over a million views. His eye for storytelling and natural beauty is unmatched.',
    author: 'Elena Vasiliou',
    role: 'Tourism Board, Cyprus',
    image: '/images/testimonial-3.jpg',
  },
];

const values = [
  { number: '01.', title: 'Creativity Without Limits' },
  { number: '02.', title: 'Authentic Storytelling' },
  { number: '03.', title: 'Excellence in Every Frame' },
  { number: '04.', title: 'Passion-Driven Work' },
];

const valueVideos = [
  { title: 'Turquoise Waters', videoSrc: 'https://videos.pexels.com/video-files/32860581/14006554_640_360_60fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/DKRuKXIy2n9/' },
  { title: 'Underwater World', videoSrc: 'https://videos.pexels.com/video-files/36473015/15465933_640_360_30fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/DB_ZIJTh3Fe/' },
  { title: 'Bali Temples', videoSrc: 'https://videos.pexels.com/video-files/36473011/15466001_640_360_30fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/C8Ccm9_Bg-4/' },
  { title: 'Island Life', videoSrc: 'https://videos.pexels.com/video-files/36473811/15466323_640_360_30fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/C7wQGUihiG7/' },
];

const services = [
  {
    title: 'Cinematic Travel Content',
    description: 'Stunning cinematic reels and videos that showcase destinations, resorts, and experiences with a storytelling-first approach.',
    tags: ['Travel Reels', 'Destination Films', 'Resort Showcases', 'Drone Footage'],
    href: '/services',
  },
  {
    title: 'Brand Collaborations',
    description: 'Authentic content creation for travel brands, hotels, and lifestyle companies. Reaching engaged audiences across Instagram and social platforms.',
    tags: ['Influencer Campaigns', 'Sponsored Content', 'Brand Stories', 'UGC'],
    href: '/services',
  },
  {
    title: 'Content Creation & Editing',
    description: 'End-to-end video production from concept to final cut. Professional editing, color grading, and sound design that brings your vision to life.',
    tags: ['Video Editing', 'Color Grading', 'Aerial & Drone', 'Social Media'],
    href: '/services',
  },
];

const works = [
  { title: 'Stay True to Yourself', subtitle: 'Cinematic Self-Expression', videoSrc: 'https://videos.pexels.com/video-files/5544413/5544413-sd_640_360_24fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/C14N94RKhK_/' },
  { title: 'Madeira', subtitle: 'Rocky Coast Adventures', videoSrc: 'https://videos.pexels.com/video-files/6981425/6981425-sd_640_360_25fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/CjA5aKVguYE/' },
  { title: 'Love Cyprus', subtitle: 'Aerial Paradise', videoSrc: 'https://videos.pexels.com/video-files/4232189/4232189-sd_640_360_24fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/DFM7L9Uugq9/' },
  { title: 'Mountain Adventures', subtitle: 'Exploring New Heights', videoSrc: 'https://videos.pexels.com/video-files/34085713/14457217_640_360_60fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/DDBQo9sTKR0/' },
  { title: 'Underwater World', subtitle: 'Beneath the Surface', videoSrc: 'https://videos.pexels.com/video-files/36473015/15465933_640_360_30fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/DB_ZIJTh3Fe/' },
  { title: 'Turquoise Waters', subtitle: 'Aerial Perspectives', videoSrc: 'https://videos.pexels.com/video-files/36473005/15465944_640_360_30fps.mp4', reelUrl: 'https://www.instagram.com/nikolaspetrouu/reel/DKRuKXIy2n9/' },
];

---

<VideoLayout
  title={config.seo.defaultTitle}
  description={config.seo.defaultDescription}
  config={config}
>
  {/* Interactive Hero — video changes on click, previews on hover */}
  <div class="-mt-[72px]">
    <HeroInteractive
      client:load
      eyebrow="Digital Creator · Bali Influencer"
      heading="Stay true to yourself."
      subheading="Cinematic travel content from Bali, Cyprus, Madeira, and beyond. Capturing the beauty of the world, one frame at a time."
      ctaText="Get in touch"
      ctaHref="/contact"
      secondaryCtaText="Watch showreel"
      secondaryCtaHref="/works"
      backgroundVideo="https://videos.pexels.com/video-files/5933986/5933986-sd_960_506_24fps.mp4"
      backgroundPoster="/images/hero-bg.jpg"
      projects={projects}
    />
  </div>

  {/* Values / About Section */}
  <ValuesSection
    heading="I create cinematic content that captures the soul of every destination and tells stories that move people."
    description="From the rice terraces of Bali to the shores of Cyprus, I turn travel experiences into visual stories that inspire wanderlust and authentic connection."
    linkText="About me"
    linkHref="/about"
    values={values}
    videos={valueVideos}
  />

  {/* Services Section */}
  <section class="bg-neutral-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 flex items-end justify-between">
        <div>
          <p class="text-sm font-medium uppercase tracking-widest text-neutral-500">What we do</p>
          <h2 class="mt-2 text-3xl font-bold text-neutral-900 sm:text-4xl lg:text-5xl">Our services.</h2>
        </div>
        <a
          href="/services"
          class="hidden items-center gap-2 rounded-full bg-neutral-900 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-neutral-800 sm:inline-flex"
        >
          View all
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service, i) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            tags={service.tags}
            href={service.href}
            number={String(i + 1).padStart(2, '0')}
          />
        ))}
      </div>
    </div>
  </section>

  {/* Latest Works */}
  <section class="bg-neutral-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h2 class="text-3xl font-bold text-neutral-900 sm:text-4xl">Latest works.</h2>
      </div>

      <HorizontalScroller>
        {works.map((work) => (
          <div class="w-64 flex-shrink-0 snap-start sm:w-72 md:w-80">
            <ProjectCard
              title={work.title}
              subtitle={work.subtitle}
              videoSrc={work.videoSrc}
              reelUrl={work.reelUrl}
            />
          </div>
        ))}
      </HorizontalScroller>
    </div>
  </section>

  {/* Testimonials */}
  <TestimonialCarousel testimonials={testimonials} />
</VideoLayout>
