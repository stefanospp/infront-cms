---
/**
 * Login page — redirects to central auth service.
 * Kept as a local route so bookmarks and direct links still work.
 */
import { env } from '@/lib/env';

const authBaseUrl = env('AUTH_SERVICE_URL') ?? 'https://auth.infront.cy';
const publicAdminUrl = env('PUBLIC_ADMIN_URL') ?? 'https://web.infront.cy';

// Validate redirect to prevent open redirect attacks
const rawRedirect = Astro.url.searchParams.get('redirect');
let redirect = publicAdminUrl;
if (rawRedirect) {
  try {
    const redirectUrl = new URL(rawRedirect);
    const publicOrigin = new URL(publicAdminUrl).origin;
    const authOrigin = new URL(authBaseUrl).origin;
    // Only allow redirects to public admin origin or auth service
    if (redirectUrl.origin === publicOrigin || redirectUrl.origin === authOrigin) {
      redirect = rawRedirect;
    }
  } catch {
    // Invalid URL — use default
  }
}

const loginUrl = `${authBaseUrl}/login?redirect=${encodeURIComponent(redirect)}`;
return Astro.redirect(loginUrl, 302);
---
