---
import AdminLayout from '@/layouts/AdminLayout.astro';
import SiteWizard from '@/islands/SiteWizard';
import ErrorBoundary from '@/islands/ErrorBoundary';

const templateParam = Astro.url.searchParams.get('template') ?? undefined;
---

<AdminLayout title="Create New Site">
  <ErrorBoundary client:load>
    <SiteWizard client:load initialTemplateId={templateParam} />
  </ErrorBoundary>
</AdminLayout>
