---
import AdminLayout from '@/layouts/AdminLayout.astro';
import SiteDetail from '@/islands/SiteDetail';
import ErrorBoundary from '@agency/ui/islands/ErrorBoundary';

const slug = Astro.params.slug!;
---

<AdminLayout title="Site Details">
  <ErrorBoundary client:load>
    <SiteDetail client:load slug={slug} />
  </ErrorBoundary>
</AdminLayout>
