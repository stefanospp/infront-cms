---
export const prerender = false;

import '@/styles/global.css';
import SiteEditor from '@/islands/SiteEditor';

const slug = Astro.params.slug!;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Editor — {slug}</title>
    <style is:global>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <SiteEditor client:load slug={slug} />
  </body>
</html>
