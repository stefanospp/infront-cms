# BetterAuth SSO service URL (e.g. https://auth.infront.cy)
AUTH_SERVICE_URL=

# Cloudflare API token with Pages and DNS permissions
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID (found in dashboard URL or overview page)
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare zone ID for the infront.cy domain
CLOUDFLARE_ZONE_ID=

# Secret used to sign session cookies (min 32 characters)
SESSION_SECRET=

# Absolute path to the monorepo root (used for site generation and builds)
MONOREPO_ROOT=
